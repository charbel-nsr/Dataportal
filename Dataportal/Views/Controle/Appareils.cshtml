@model Dataportal.ViewModels.AppareilViewModel
@{
    ViewData["Title"] = "Gestion des appareils";
}

<div class="container">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row bg-light rounded shadow p-4 mb-4">
        <form method="get" class="row gx-3 gy-2 align-items-center">
            <div class="col-md-6">
                <div class="form-floating">
                    <input type="text" class="form-control" id="search" name="search" placeholder="Recherche" value="@Model.Search">
                    <label for="search">Nom, description, capacité, modèle ou fabricant</label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating">
                    <select class="form-select" name="actif" id="actif">
                        <option value="">Tous</option>
                        <option value="true" selected="@(Model.Actif == true ? "selected" : null)">Actifs</option>
                        <option value="false" selected="@(Model.Actif == false ? "selected" : null)">Inactifs</option>
                    </select>
                    <label for="actif">Statut actif</label>
                </div>
            </div>
            <div class="col-md-6 offset-md-6 mt-2 d-flex flex-column flex-md-row">
                <button type="submit" class="btn btn-primary flex-grow-1 w-100 mb-2 mb-md-0 me-md-2">
                    Filtrer
                </button>
                <a href="@Url.Action("Appareils", "Controle")" class="btn btn-outline-primary flex-grow-1 w-100">
                    Réinitialiser
                </a>
            </div>
        </form>
    </div>

    <div class="col-12 col-md-auto mb-3">
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="bi bi-plus-circle"></i> Créer un appareil
        </button>
    </div>

    <div class="row">
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm">
                <thead class="table-light">
                    <tr>
                        <th>Nom</th>
                        <th>Modèle</th>
                        <th>Actif</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appareil in Model.Appareils)
                    {
                        <tr>
                            <td>@appareil.Nom</td>
                            <td>@appareil.Model</td>
                            <td>
                                @if (appareil.Actif)
                                {
                                    <span class="badge bg-success">Actif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactif</span>
                                }
                            </td>
                            <td>
                                @if (!appareil.Actif)
                                {
                                    <form method="post" asp-action="ActivateAppareil" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@appareil.Id" />
                                        <button class="btn btn-sm btn-outline-success" title="Activer">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-action="DeactivateAppareil" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@appareil.Id" />
                                        <button class="btn btn-sm btn-outline-warning" title="Désactiver">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </form>
                                }
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#detailsModal"
                                        data-nom="@appareil.Nom"
                                        data-description="@appareil.Description"
                                        data-capacite="@appareil.Capacite"
                                        data-model="@appareil.Model"
                                        data-manufacturer="@appareil.Manufacturer"
                                        data-actif="@appareil.Actif">
                                    <i class="bi bi-exclamation-circle"></i>
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editAppareilModal"
                                        data-id="@appareil.Id"
                                        data-nom="@appareil.Nom"
                                        data-description="@appareil.Description"
                                        data-capacite="@appareil.Capacite"
                                        data-model="@appareil.Model"
                                        data-manufacturer="@appareil.Manufacturer"
                                        data-actif="@appareil.Actif">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="CreateAppareil">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createModalLabel">Créer un appareil</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Nom" name="Nom" placeholder="Nom" required>
                        <label for="Nom">Nom</label>
                    </div>
                    <div class="form-floating mb-3">
                        <textarea class="form-control" id="Description" name="Description" placeholder="Description" style="height: 100px;" required></textarea>
                        <label for="Description">Description</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Capacite" name="Capacite" placeholder="Capacité">
                        <label for="Capacite">Capacité</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Model" name="Model" placeholder="Modèle">
                        <label for="Model">Modèle</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Manufacturer" name="Manufacturer" placeholder="Fabricant">
                        <label for="Manufacturer">Fabricant</label>
                    </div>
                    <div class="form-floating mb-3">
                        <select class="form-select" id="Actif" name="Actif" required>
                            <option value="true">Actif</option>
                            <option value="false">Inactif</option>
                        </select>
                        <label for="Actif">Statut</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-success">Créer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-labelledby="detailsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailsModalLabel">Détails de l'appareil</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong>Nom:</strong> <span id="detailNom"></span></p>
                <p><strong>Description:</strong> <span id="detailDescription"></span></p>
                <p><strong>Capacité:</strong> <span id="detailCapacite"></span></p>
                <p><strong>Modèle:</strong> <span id="detailModel"></span></p>
                <p><strong>Fabricant:</strong> <span id="detailManufacturer"></span></p>
                <p><strong>Statut:</strong> <span id="detailActif"></span></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Appareil Modal -->
<div class="modal fade" id="editAppareilModal" tabindex="-1" aria-labelledby="editAppareilModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="EditAppareil">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editAppareilId" name="Id" />

                <div class="modal-header">
                    <h5 class="modal-title" id="editAppareilModalLabel">Modifier l'appareil</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editAppareilNom" name="Nom" placeholder="Nom" required>
                        <label for="editAppareilNom">Nom</label>
                    </div>

                    <div class="form-floating mb-3">
                        <textarea class="form-control" id="editAppareilDescription" name="Description" placeholder="Description" style="height: 100px;" required></textarea>
                        <label for="editAppareilDescription">Description</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editAppareilCapacite" name="Capacite" placeholder="Capacité">
                        <label for="editAppareilCapacite">Capacité</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editAppareilModel" name="Model" placeholder="Modèle">
                        <label for="editAppareilModel">Modèle</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editAppareilManufacturer" name="Manufacturer" placeholder="Fabricant">
                        <label for="editAppareilManufacturer">Fabricant</label>
                    </div>

                    <div class="form-floating mb-3">
                        <select class="form-select" id="editAppareilActif" name="Actif" required>
                            <option value="true">Actif</option>
                            <option value="false">Inactif</option>
                        </select>
                        <label for="editAppareilActif">Statut</label>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const detailsModal = document.getElementById('detailsModal');
        detailsModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            document.getElementById('detailNom').textContent = button.getAttribute('data-nom') || '—';
            document.getElementById('detailDescription').textContent = button.getAttribute('data-description') || '—';
            document.getElementById('detailCapacite').textContent = button.getAttribute('data-capacite') || '—';
            document.getElementById('detailModel').textContent = button.getAttribute('data-model') || '—';
            document.getElementById('detailManufacturer').textContent = button.getAttribute('data-manufacturer') || '—';
            document.getElementById('detailActif').textContent = button.getAttribute('data-actif') === 'True' ? 'Actif' : 'Inactif';
        });
        const editAppareilModal = document.getElementById('editAppareilModal');
        editAppareilModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            document.getElementById('editAppareilId').value = button.getAttribute('data-id');
            document.getElementById('editAppareilNom').value = button.getAttribute('data-nom') || '';
            document.getElementById('editAppareilDescription').value = button.getAttribute('data-description') || '';
            document.getElementById('editAppareilCapacite').value = button.getAttribute('data-capacite') || '';
            document.getElementById('editAppareilModel').value = button.getAttribute('data-model') || '';
            document.getElementById('editAppareilManufacturer').value = button.getAttribute('data-manufacturer') || '';
            document.getElementById('editAppareilActif').value = button.getAttribute('data-actif') === 'True' ? 'true' : 'false';
        });
    </script>
}