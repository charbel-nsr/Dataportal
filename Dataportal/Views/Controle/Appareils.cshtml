@model Dataportal.ViewModels.AppareilViewModel
@{
    ViewData["Title"] = "Device management";
}

<div class="container">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row bg-light rounded shadow p-4 mb-4">
        <form method="get" class="row gx-3 gy-2 align-items-center">
            <div class="col-md-6">
                <div class="form-floating">
                    <input type="text" class="form-control" id="search" name="search" placeholder="Search" value="@Model.Search">
                    <label for="search">Name, description, capacity, model or manufacturer</label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating">
                    <select class="form-select" name="actif" id="actif">
                        <option value="">All</option>
                        <option value="true" selected="@(Model.Actif == true ? "selected" : null)">Active</option>
                        <option value="false" selected="@(Model.Actif == false ? "selected" : null)">Inactive</option>
                    </select>
                    <label for="actif">Active status</label>
                </div>
            </div>
            <div class="col-md-6 offset-md-6 mt-2 d-flex flex-column flex-md-row">
                <button type="submit" class="btn btn-primary flex-grow-1 w-100 mb-2 mb-md-0 me-md-2">
                    Filter
                </button>
                <a href="@Url.Action("Appareils", "Controle")" class="btn btn-outline-primary flex-grow-1 w-100">
                    Reset
                </a>
            </div>
        </form>
    </div>

    <div class="col-12 col-md-auto mb-3">
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="bi bi-plus-circle"></i> Create a device
        </button>
    </div>

    @if (Model.Appareils != null && Model.Appareils.Any()){
        <div class="row">
            <div class="table-responsive">
                <table class="table table-hover align-middle shadow-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Model</th>
                            <th>Active</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appareil in Model.Appareils)
                        {
                            <tr>
                                <td>@appareil.Nom</td>
                                <td>@appareil.Model</td>
                                <td>
                                    @if (appareil.Actif)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (!appareil.Actif)
                                    {
                                        <form method="post" asp-action="ActivateAppareil" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@appareil.Id" />
                                            <button class="btn btn-sm btn-outline-success" title="Activate">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-action="DeactivateAppareil" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@appareil.Id" />
                                            <button class="btn btn-sm btn-outline-warning" title="Deactivate">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#detailsModal"
                                            data-nom="@appareil.Nom"
                                            data-description="@appareil.Description"
                                            data-capacite="@appareil.Capacite"
                                            data-model="@appareil.Model"
                                            data-manufacturer="@appareil.Manufacturer"
                                            data-actif="@appareil.Actif">
                                        <i class="bi bi-exclamation-circle"></i>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editAppareilModal"
                                            data-id="@appareil.Id"
                                            data-nom="@appareil.Nom"
                                            data-description="@appareil.Description"
                                            data-capacite="@appareil.Capacite"
                                            data-model="@appareil.Model"
                                            data-manufacturer="@appareil.Manufacturer"
                                            data-actif="@appareil.Actif">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center">
            <img src="/illustration/empty-search.svg" alt="No data found" class="img-fluid" style="max-height:200px;" />
            <p class="text-muted mt-2">No data found.</p>
        </div>
    }
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="CreateAppareil">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createModalLabel">Create a device</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Nom" name="Nom" placeholder="Name" required>
                        <label for="Nom">Name</label>
                    </div>
                    <div class="form-floating mb-3">
                        <textarea class="form-control" id="Description" name="Description" placeholder="Description" style="height: 100px;" required></textarea>
                        <label for="Description">Description</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Capacite" name="Capacite" placeholder="Capacity">
                        <label for="Capacite">Capacity</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Model" name="Model" placeholder="Model">
                        <label for="Model">Model</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Manufacturer" name="Manufacturer" placeholder="Manufacturer">
                        <label for="Manufacturer">Manufacturer</label>
                    </div>
                    <div class="form-floating mb-3">
                        <select class="form-select" id="Actif" name="Actif" required>
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                        <label for="Actif">Status</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-labelledby="detailsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailsModalLabel">Device details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong>Name:</strong> <span id="detailNom"></span></p>
                <p><strong>Description:</strong> <span id="detailDescription"></span></p>
                <p><strong>Capacity:</strong> <span id="detailCapacite"></span></p>
                <p><strong>Model:</strong> <span id="detailModel"></span></p>
                <p><strong>Manufacturer:</strong> <span id="detailManufacturer"></span></p>
                <p><strong>Status:</strong> <span id="detailActif"></span></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Appareil Modal -->
<div class="modal fade" id="editAppareilModal" tabindex="-1" aria-labelledby="editAppareilModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="EditAppareil">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editAppareilId" name="Id" />

                <div class="modal-header">
                    <h5 class="modal-title" id="editAppareilModalLabel">Edit device</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editAppareilNom" name="Nom" placeholder="Name" required>
                        <label for="editAppareilNom">Name</label>
                    </div>

                    <div class="form-floating mb-3">
                        <textarea class="form-control" id="editAppareilDescription" name="Description" placeholder="Description" style="height: 100px;" required></textarea>
                        <label for="editAppareilDescription">Description</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editAppareilCapacite" name="Capacite" placeholder="Capacity">
                        <label for="editAppareilCapacite">Capacity</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editAppareilModel" name="Model" placeholder="Model">
                        <label for="editAppareilModel">Model</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editAppareilManufacturer" name="Manufacturer" placeholder="Manufacturer">
                        <label for="editAppareilManufacturer">Manufacturer</label>
                    </div>

                    <div class="form-floating mb-3">
                        <select class="form-select" id="editAppareilActif" name="Actif" required>
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                        <label for="editAppareilActif">Status</label>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const detailsModal = document.getElementById('detailsModal');
        detailsModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            document.getElementById('detailNom').textContent = button.getAttribute('data-nom') || '—';
            document.getElementById('detailDescription').textContent = button.getAttribute('data-description') || '—';
            document.getElementById('detailCapacite').textContent = button.getAttribute('data-capacite') || '—';
            document.getElementById('detailModel').textContent = button.getAttribute('data-model') || '—';
            document.getElementById('detailManufacturer').textContent = button.getAttribute('data-manufacturer') || '—';
            document.getElementById('detailActif').textContent = button.getAttribute('data-actif') === 'True' ? 'Active' : 'Inactive';
        });
        const editAppareilModal = document.getElementById('editAppareilModal');
        editAppareilModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            document.getElementById('editAppareilId').value = button.getAttribute('data-id');
            document.getElementById('editAppareilNom').value = button.getAttribute('data-nom') || '';
            document.getElementById('editAppareilDescription').value = button.getAttribute('data-description') || '';
            document.getElementById('editAppareilCapacite').value = button.getAttribute('data-capacite') || '';
            document.getElementById('editAppareilModel').value = button.getAttribute('data-model') || '';
            document.getElementById('editAppareilManufacturer').value = button.getAttribute('data-manufacturer') || '';
            document.getElementById('editAppareilActif').value = button.getAttribute('data-actif') === 'True' ? 'true' : 'false';
        });
    </script>
}