@model Dataportal.ViewModels.SiteViewModel
@{
    ViewData["Title"] = "Site management";
}

<div class="container">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row bg-light rounded shadow p-4 mb-4">
        <form method="get" class="row gx-3 gy-2 align-items-center">
            <div class="col-md-6">
                <div class="form-floating">
                    <input type="text" class="form-control" id="search" name="search" placeholder="Search" value="@Model.Search">
                    <label for="search">Name, description or location</label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating">
                    <select class="form-select" name="actif" id="actif">
                        <option value="">All</option>
                        <option value="true" selected="@(Model.Actif == true ? "selected" : null)">Active</option>
                        <option value="false" selected="@(Model.Actif == false ? "selected" : null)">Inactive</option>
                    </select>
                    <label for="actif">Active status</label>
                </div>
            </div>
            <div class="col-md-6 offset-md-6 mt-2 d-flex flex-column flex-md-row">
                <button type="submit" class="btn btn-primary flex-grow-1 w-100 mb-2 mb-md-0 me-md-2">
                    Filter
                </button>
                <a href="@Url.Action("Sites", "Controle")" class="btn btn-outline-primary flex-grow-1 w-100">
                    Reset
                </a>
            </div>
        </form>
    </div>

    <div class="col-12 col-md-auto mb-3">
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="bi bi-plus-circle"></i> Create a site
        </button>
    </div>

    @if (Model.Sites != null && Model.Sites.Any()){
        <div class="row">
            <div class="paginated-table-wrapper" data-page-size="20">
                <div class="table-responsive">
                    <table class="table table-hover align-middle shadow-sm paginated-table">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Name
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Location
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="boolean">
                                    <button type="button" class="table-sort-button">
                                        Active
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var site in Model.Sites)
                            {
                            var locationDisplay = string.IsNullOrWhiteSpace(site.Emplacement) ? "—" : site.Emplacement;
                            <tr>
                                <td data-sort-value="@site.Nom">@site.Nom</td>
                                <td data-sort-value="@locationDisplay">@locationDisplay</td>
                                <td data-sort-value="@(site.Actif ? 1 : 0)">
                                    @if (site.Actif)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (!site.Actif)
                                    {
                                        <form method="post" asp-action="ActivateSite" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@site.Id" />
                                            <button class="btn btn-sm btn-outline-success" title="Activate">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-action="DeactivateSite" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@site.Id" />
                                            <button class="btn btn-sm btn-outline-warning" title="Deactivate">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#detailsModal"
                                            data-nom="@site.Nom"
                                            data-description="@site.Description"
                                            data-emplacement="@site.Emplacement"
                                            data-actif="@site.Actif">
                                        <i class="bi bi-exclamation-circle"></i>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editModal"
                                            data-id="@site.Id"
                                            data-nom="@site.Nom"
                                            data-description="@site.Description"
                                            data-emplacement="@site.Emplacement"
                                            data-actif="@site.Actif">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <div class="table-pagination-controls d-flex justify-content-end align-items-center gap-2 mt-3 d-none">
                    <button type="button" class="table-pagination-button table-pagination-prev" aria-label="Previous page" disabled>
                        <span class="material-symbols-outlined">
                            arrow_circle_left
                        </span>
                    </button>
                    <div class="d-flex align-items-center gap-1">
                        <input type="number" class="form-control table-pagination-input" value="1" min="1" />
                        <span>/</span>
                        <span class="table-pagination-total">1</span>
                    </div>
                    <button type="button" class="table-pagination-button table-pagination-next" aria-label="Next page" disabled>
                        <span class="material-symbols-outlined">
                            arrow_circle_right
                        </span>
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center">
            <img src="/illustration/empty-search.svg" alt="No data found" class="img-fluid" style="max-height:200px;" />
            <p class="text-muted mt-2">No data found.</p>
        </div>
    }
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="CreateSite">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createModalLabel">Create a site</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Nom" name="Nom" placeholder="Name" required>
                        <label for="Nom">Site name</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Emplacement" name="Emplacement" placeholder="Location">
                        <label for="Emplacement">Location</label>
                    </div>
                    <div class="form-floating mb-3">
                        <textarea class="form-control" id="Description" name="Description" placeholder="Description" style="height: 100px;"></textarea>
                        <label for="Description">Description</label>
                    </div>
                    <div class="form-floating mb-3">
                        <select class="form-select" id="Actif" name="Actif" required>
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                        <label for="Actif">Site status</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-labelledby="detailsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailsModalLabel">Site details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p><strong>Name:</strong> <span id="detailNom"></span></p>
                <p><strong>Location:</strong> <span id="detailEmplacement"></span></p>
                <p><strong>Description:</strong> <span id="detailDescription"></span></p>
                <p><strong>Status:</strong> <span id="detailActif"></span></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="EditSite">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id" />

                <div class="modal-header">
                    <h5 class="modal-title" id="editModalLabel">Edit site</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editNom" name="Nom" placeholder="Name" required>
                        <label for="editNom">Site name</label>
                    </div>

                    <div class="form-floating mb-3">
                        <textarea class="form-control" id="editDescription" name="Description" placeholder="Description" style="height: 100px;"></textarea>
                        <label for="editDescription">Description</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editEmplacement" name="Emplacement" placeholder="Location">
                        <label for="editEmplacement">Location</label>
                    </div>

                    <div class="form-floating mb-3">
                        <select class="form-select" id="editActif" name="Actif" required>
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                        <label for="editActif">Site status</label>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const detailsModal = document.getElementById('detailsModal');
        detailsModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            document.getElementById('detailNom').textContent = button.getAttribute('data-nom') || '—';
            document.getElementById('detailEmplacement').textContent = button.getAttribute('data-emplacement') || '—';
            document.getElementById('detailDescription').textContent = button.getAttribute('data-description') || '—';
            document.getElementById('detailActif').textContent = button.getAttribute('data-actif') === 'True' ? 'Active' : 'Inactive';
        });
        const editModal = document.getElementById('editModal');
        editModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            document.getElementById('editId').value = button.getAttribute('data-id');
            document.getElementById('editNom').value = button.getAttribute('data-nom') || '';
            document.getElementById('editDescription').value = button.getAttribute('data-description') || '';
            document.getElementById('editEmplacement').value = button.getAttribute('data-emplacement') || '';
            document.getElementById('editActif').value = button.getAttribute('data-actif') === 'True' ? 'true' : 'false';
        });
    </script>
}
