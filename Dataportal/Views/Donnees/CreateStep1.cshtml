@model Dataportal.ViewModels.MetadonneeCreateViewModel

@{
    ViewData["Title"] = "Create a dataset - Step 1";
    ViewData["CurrentStep"] = 1;
}

<div class="container">
    <h2 class="mb-4">Create metadata (Step 1/5)</h2>
    @await Html.PartialAsync("_CreationProgress")
    <form method="post" class="bg-light p-4 rounded shadow-sm">
        @Html.AntiForgeryToken()

        <div class="form-floating mb-3">
            <input asp-for="Nom" class="form-control" placeholder="Name" required>
            <label asp-for="Nom"></label>
            <span asp-validation-for="Nom" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-semibold"></label>
            <div class="rich-text-editor" data-rich-text-editor data-target-input-id="Description">
                <div class="rich-text-editor__toolbar" role="toolbar" aria-label="Formatting options">
                    <div class="btn-group me-2" role="group" aria-label="Text emphasis">
                        <button type="button" class="btn btn-light btn-sm" data-command="bold" aria-label="Bold">
                            <span class="material-symbols-outlined align-middle">format_bold</span>
                        </button>
                        <button type="button" class="btn btn-light btn-sm" data-command="italic" aria-label="Italic">
                            <span class="material-symbols-outlined align-middle">format_italic</span>
                        </button>
                        <button type="button" class="btn btn-light btn-sm" data-command="underline" aria-label="Underline">
                            <span class="material-symbols-outlined align-middle">format_underlined</span>
                        </button>
                    </div>
                    <div class="btn-group me-2" role="group" aria-label="Lists">
                        <button type="button" class="btn btn-light btn-sm" data-command="insertUnorderedList" aria-label="Bulleted list">
                            <span class="material-symbols-outlined align-middle">format_list_bulleted</span>
                        </button>
                        <button type="button" class="btn btn-light btn-sm" data-command="insertOrderedList" aria-label="Numbered list">
                            <span class="material-symbols-outlined align-middle">format_list_numbered</span>
                        </button>
                    </div>
                    <div class="btn-group me-2" role="group" aria-label="Links">
                        <button type="button" class="btn btn-light btn-sm" data-command="createLink" aria-label="Insert link">
                            <span class="material-symbols-outlined align-middle">link</span>
                        </button>
                        <button type="button" class="btn btn-light btn-sm" data-command="unlink" aria-label="Remove link">
                            <span class="material-symbols-outlined align-middle">link_off</span>
                        </button>
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <select id="DescriptionFormat" class="form-select form-select-sm" data-format-block>
                            <option value="p">Paragraph</option>
                            <option value="h2">Heading 2</option>
                            <option value="h3">Heading 3</option>
                            <option value="h4">Heading 4</option>
                        </select>
                    </div>
                </div>
                <div id="Description-editor" class="rich-text-editor__content" contenteditable="true" role="textbox" aria-multiline="true" data-placeholder="Describe your dataset in detail, including sources, goals, and any context that helps others understand it."></div>
                <textarea asp-for="Description" class="d-none" required></textarea>
            </div>
            <small class="text-muted">Add rich formatting to make the dataset description clearer. You can use bold text, headings, bullet lists, and links.</small>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <select asp-for="IdLicence" class="form-select" asp-items="@(new SelectList(Model.Licences, "Id", "Libelle"))" required>
                <option value="">Select a license</option>
            </select>
            <label asp-for="IdLicence"></label>
            <span asp-validation-for="IdLicence" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <select asp-for="IdSite" class="form-select" asp-items="@(new SelectList(Model.Sites, "Id", "Nom"))" required>
                <option value="">Select a site</option>
            </select>
            <label asp-for="IdSite"></label>
            <span asp-validation-for="IdSite" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3 position-relative" id="appareilsMultiSelectWrapper">
            <select asp-for="SelectedAppareils" asp-items="@(new MultiSelectList(Model.Appareils, "Id", "Nom"))" class="d-none" multiple></select>
            <div id="appareilsSelectDisplay" class="form-control multi-select-container">
                <input type="text" id="appareilsFilterInput" class="multi-select-input" placeholder="Search..." />
            </div>
            <div id="appareilsSelectOptions" class="multi-select-dropdown"></div>
            <label asp-for="SelectedAppareils"></label>
            <span asp-validation-for="SelectedAppareils" class="text-danger"></span>
        </div>
        <div id="appareilDetailsContainer" class="mb-3"></div>

        <div class="form-floating mb-3">
            <select asp-for="IdVisibilite" class="form-select" asp-items="@(new SelectList(Model.Visibilites, "Id", "Libelle"))" required>
                <option value="">Select a visibility</option>
            </select>
            <label asp-for="IdVisibilite"></label>
            <span asp-validation-for="IdVisibilite" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <select asp-for="IdTypeEnergieRenouvelable" class="form-select" asp-items="@(new SelectList(Model.TypesEnergieRenouvelable ?? new List<Dataportal.Models.TypeEnergieRenouvelable>(), "Id", "Libelle"))">
                <option value="">Select a renewable energy type (optional)</option>
            </select>
            <label asp-for="IdTypeEnergieRenouvelable"></label>
            <span asp-validation-for="IdTypeEnergieRenouvelable" class="text-danger"></span>
        </div>

        <div class="form-check mb-2">
            <input class="form-check-input" asp-for="SeriesTemporelles" />
            <label class="form-check-label" asp-for="SeriesTemporelles"></label>
        </div>

        <div class="form-check mb-2">
            <input class="form-check-input" asp-for="AutoriserApi" />
            <label class="form-check-label" asp-for="AutoriserApi"></label>
        </div>

        <div class="form-check mb-2">
            <input class="form-check-input" asp-for="Anonymiser" />
            <label class="form-check-label" asp-for="Anonymiser"></label>
        </div>

        <div class="form-check mb-4">
            <input class="form-check-input" asp-for="AutoriserLeTelechargement" />
            <label class="form-check-label" asp-for="AutoriserLeTelechargement"></label>
        </div>

        <button type="submit" class="btn btn-primary w-100">Next</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/richTextEditor.js" asp-append-version="true"></script>
    <script src="~/js/multiSelectTags.js" asp-append-version="true"></script>
}
