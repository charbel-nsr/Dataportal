@model Dataportal.ViewModels.IndexationPageViewModel

@{
    ViewData["Title"] = "Create index";
}

<div class="container" style="min-height: 50vh;">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row bg-light rounded shadow p-4 mb-4">
        <div class="col-12 d-flex flex-wrap gap-3">
            <div class="flex-grow-1 min-width-0">
            <h2 class="h4 mb-2">Request an index</h2>
            <p class="text-muted mb-2">
                Index requests are queued and run overnight during off-peak hours.
                If needed, administrators can also run them manually from the Indexation settings.
            </p>
            <div class="small text-muted">
                Dataset: <strong>@Model.DatasetName</strong>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
            {
                <a class="btn btn-link text-decoration-none text-muted d-inline-flex align-items-center justify-content-center p-2 close-details-link"
                   href="@Model.ReturnUrl"
                   title="Close index request">
                    <span class="material-symbols-outlined" aria-hidden="true">cancel</span>
                    <span class="visually-hidden">Return to the previous page</span>
                </a>
            }
        </div>
    </div>

    @if (Model.Requests.Any())
    {
        <ul class="nav nav-tabs" id="indexationTabs" role="tablist">
            @foreach (var request in Model.Requests)
            {
                var isActive = request.TabId == Model.ActiveTabId;
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(isActive ? "active" : string.Empty)" id="@request.TabId-tab" data-bs-toggle="tab" data-bs-target="#@request.TabId" type="button" role="tab" aria-controls="@request.TabId" aria-selected="@(isActive ? "true" : "false")">
                        @request.TabTitle
                    </button>
                </li>
            }
        </ul>
        <div class="tab-content border border-top-0 rounded-bottom bg-white shadow-sm p-4" id="indexationTabsContent">
            @foreach (var request in Model.Requests)
            {
                var isActive = request.TabId == Model.ActiveTabId;
                <div class="tab-pane fade @(isActive ? "show active" : string.Empty)" id="@request.TabId" role="tabpanel" aria-labelledby="@request.TabId-tab">
                    @if (request.IsIndexed)
                    {
                        <div class="alert alert-info mb-0">
                            An index is already enabled for this table.
                        </div>
                    }
                    else if (!request.IsTimeSeries)
                    {
                        <div class="alert alert-warning mb-0">
                            Indexation is only available for time-series datasets.
                        </div>
                    }
                    else
                    {
                        @await Html.PartialAsync("_IndexationRequestForm", request)
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            No tables are available for indexation.
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('form[data-index-form]').forEach(form => {
                const indexToggle = form.querySelector('[data-index-toggle]');
                const indexOptions = form.querySelector('[data-index-options]');

                const toggleIndexOptions = () => {
                    if (!indexOptions) {
                        return;
                    }

                    if (indexToggle?.checked) {
                        indexOptions.classList.remove('d-none');
                    } else {
                        indexOptions.classList.add('d-none');
                    }
                };

                if (indexToggle) {
                    indexToggle.addEventListener('change', toggleIndexOptions);
                }

                toggleIndexOptions();
            });
        });
    </script>
}