@model Dataportal.ViewModels.DonneesCreateStep2ViewModel
@using System.Text.Json
@using Dataportal.Classes
@using Dataportal.Services
@using System.Linq
@{
    ViewData["Title"] = "Create a dataset - Step 2";
    ViewData["CurrentStep"] = 2;
    var canConfigureIndex = User.IsInRole("administrator") || User.IsInRole("editor");
}

<div class="container">
    <h2 class="mb-4">Add data (Step 2/5)</h2>
    @await Html.PartialAsync("_CreationProgress")
    <form method="post" enctype="multipart/form-data" class="bg-light p-4 rounded shadow-sm upload-overlay-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UploadSessionId" />
        <input type="hidden" asp-for="ColumnTypesConfirmed" />
        <input type="hidden" asp-for="ProceedAfterImportErrors" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

        @if (Model.ColumnTypesConfirmed && Model.ColumnTypes?.Any() == true)
        {
            <div class="d-flex flex-column gap-2 mb-3">
                @if (Model.ImportErrors?.Any() == true)
                {
                    <div class="alert alert-warning d-flex flex-column gap-2" role="alert">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="mb-2">Some values could not be parsed with the selected types. Update your files or column types, then re-run the import, or continue to the next step with invalid values stored as <strong>NULL</strong>. If the list is too long, not all issues are included.</p>
                            </div>
                            <div>
                                <button type="button" class="btn btn-outline-secondary btn-sm" data-download-errors data-errors='@JsonSerializer.Serialize(Model.ImportErrors)'>Download log</button>
                            </div>
                        </div>
                        <ul class="mb-0">
                            @{
                                var errorPreview = Model.ImportErrors.Take(5).ToList();
                                var hasMore = Model.ImportErrors.Count > 5;
                            }
                            @foreach (var issue in errorPreview)
                            {
                                <li>
                                    <strong>@issue.ColumnName</strong> (row @issue.RowNumber, file @issue.FileName): @issue.Message
                                    @if (!string.IsNullOrWhiteSpace(issue.RawValue))
                                    {
                                        <span class="text-muted">Value: @issue.RawValue</span>
                                    }
                                </li>
                            }
                            @if (hasMore)
                            {
                                <li>...</li>
                            }
                        </ul>
                    </div>
                }
                <div class="alert alert-info" role="status">
                    Review the detected column types before creating the table. You can adjust them to avoid conversion errors during import.
                </div>
            </div>
        }

        <div class="form-floating mb-3">
            <select asp-for="IdExistingMetadonnee" class="form-select" data-existing-select data-default-code="@Model.Code" data-code-source="donnees">
                <option value="">Completely new data</option>
                @foreach (var option in Model.ExistingLabelOptions)
                {
                    <option value="@option.Value" data-libelle="@option.Libelle" data-code="@option.Code">@option.DisplayText</option>
                }
            </select>
            </select>
            <label asp-for="IdExistingMetadonnee" class="d-inline-flex gap-2">
                <span>Use existing data (optional)</span>
                <span class="info-tooltip-icon" role="img" aria-label="Existing data help" data-info-tooltip="If you are publishing an update or a new version, pick the existing data to reuse its label and bump today's code automatically. Otherwise, please use a completely new label." tabindex="0">
                    <span class="material-symbols-outlined" aria-hidden="true">help</span>
                </span>
            </label>
            <div class="mb-2">
                <small class="form-text text-muted">Choose "Completely new data" to provide a unique label and start from today's version 01.</small>
            </div>
            <span asp-validation-for="IdExistingMetadonnee" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Libelle" class="form-control" placeholder="Label" required data-next-code-input />
            <label asp-for="Libelle">
                <span>@Html.DisplayNameFor(m => m.Libelle)</span>
                <span class="info-tooltip-icon" role="img" aria-label="Existing data help" data-info-tooltip="If your label is already in use, it'll affect the code. If this dataset is totally new, you should expect the code to be the current date then 01: YYYYMMDD01." tabindex="0">
                    <span class="material-symbols-outlined" aria-hidden="true">help</span>
                </span>
            </label>
            <span asp-validation-for="Libelle" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Code" class="form-control" placeholder="Code" required readonly />
            <label asp-for="Code"></label>
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <textarea asp-for="Description" class="form-control" placeholder="Description" style="height: 100px;"></textarea>
            <label asp-for="Description"></label>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <select asp-for="IdQualiteDonnees"
                    class="form-select data-quality-select"
                    asp-items="Model.QualiteOptions"
                    data-descriptions='@Html.Raw(JsonSerializer.Serialize(Model.QualiteDescriptions))'></select>
            <label asp-for="IdQualiteDonnees"></label>
            <span asp-validation-for="IdQualiteDonnees" class="text-danger"></span>
            <div class="form-text text-muted mt-1 data-quality-description d-none" data-quality-description></div>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="NombreDeCapteurs" type="number" class="form-control" placeholder="Number of sensors" required />
            <label asp-for="NombreDeCapteurs"></label>
            <span asp-validation-for="NombreDeCapteurs" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="FrequenceDeCollect" class="form-control" placeholder="Collection frequency" />
            <label asp-for="FrequenceDeCollect"></label>
            <span asp-validation-for="FrequenceDeCollect" class="text-danger"></span>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="StartTimestamp" class="form-label"></label>
                <input asp-for="StartTimestamp" type="datetime-local" class="form-control" required />
                <span asp-validation-for="StartTimestamp" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="EndTimestamp" class="form-label"></label>
                <input asp-for="EndTimestamp" type="datetime-local" class="form-control" required />
                <span asp-validation-for="EndTimestamp" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-4">
            <label asp-for="UploadedFiles" class="form-label">Upload CSV, XLSX, Parquet, or CSV.zip files</label>
            @if (string.IsNullOrEmpty(Model.UploadSessionId))
            {
                <input asp-for="UploadedFiles" type="file" multiple class="form-control" accept=".csv,.xlsx,.parquet,.zip" required />
            }
            else
            {
                <input asp-for="UploadedFiles" type="file" multiple class="form-control" accept=".csv,.xlsx,.parquet,.zip" />
            }
            <small class="form-text text-muted">All files uploaded in this step must share the same format. Maximum total size per step: @UploadSizeLimits.StepUploadLimitDisplay.</small>
            <span asp-validation-for="UploadedFiles" class="text-danger"></span>
        </div>

        <div id="fileList" class="mb-3"></div>

        @if (Model.PersistedFiles?.Any() == true)
        {
            <div class="mb-3">
                <h5 class="h6">Uploaded files</h5>
                <table class="table table-sm table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Size</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in Model.PersistedFiles)
                        {
                            <tr>
                                <td>@file.Name</td>
                                <td>@string.Format("{0:N2} KB", file.SizeBytes / 1024.0)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.ColumnTypesConfirmed && Model.ColumnTypes?.Any() == true)
        {
            <div class="table-responsive mb-4">
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Column</th>
                            <th scope="col">Type</th>
                            <th scope="col">NVARCHAR length (if applicable)</th>
                            <th scope="col">Inference</th>
                            <th scope="col">Type description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.ColumnTypes.Count; i++)
                        {
                            var column = Model.ColumnTypes[i];
                            <tr>
                                <td>
                                    @column.ColumnName
                                    <input type="hidden" asp-for="ColumnTypes[@i].ColumnName" />
                                    <input type="hidden" asp-for="ColumnTypes[@i].InferredType" />
                                    <input type="hidden" asp-for="ColumnTypes[@i].InferredLength" />
                                </td>
                                <td>
                                    <select class="form-select column-type-select" asp-for="ColumnTypes[@i].SelectedType" data-length-target="length-@i">
                                        @foreach (TabularColumnType type in Enum.GetValues(typeof(TabularColumnType)))
                                        {
                                            <option value="@type">@type</option>
                                        }
                                    </select>
                                    <span asp-validation-for="ColumnTypes[@i].SelectedType" class="text-danger"></span>
                                </td>
                                <td>
                                    <input asp-for="ColumnTypes[@i].MaxLength" id="length-@i" type="number" class="form-control column-length-input @(column.SelectedType == TabularColumnType.NVarChar.ToString() ? "" : "d-none")" min="1" />
                                    <span class="form-text text-muted">Used only when NVARCHAR is selected.</span>
                                    <span asp-validation-for="ColumnTypes[@i].MaxLength" class="text-danger"></span>
                                </td>
                                <td>
                                    <div class="small text-muted">
                                        Inferred: @column.InferredType
                                        @if (column.InferredLength.HasValue)
                                        {
                                            <span>(length @column.InferredLength)</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @{
                                        string Describe(TabularColumnType t) => t switch
                                        {
                                            TabularColumnType.Bit => "Boolean (true/false, 0/1, yes/no).",
                                            TabularColumnType.Int => "32-bit integer numbers.",
                                            TabularColumnType.BigInt => "64-bit integer numbers.",
                                            TabularColumnType.Decimal => "High-precision decimal numbers.",
                                            TabularColumnType.Float => "Floating point numbers.",
                                            TabularColumnType.DateTime2 => "Date/time values (datetime2).",
                                            TabularColumnType.NVarChar => "Text values (NVARCHAR, length as specified).",
                                            _ => "Text values."
                                        };
                                        var parsed = Enum.TryParse<TabularColumnType>(column.SelectedType, out var parsedType) ? parsedType : TabularColumnType.NVarChar;
                                    }
                                    <div class="small text-muted">@Describe(parsed)</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.ColumnTypesConfirmed && Model.ColumnTypes?.Any() == true && Model.IsTimeSeries && canConfigureIndex)
        {
            <div class="border rounded bg-white p-3 mb-4">
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <h5 class="h6 mb-0">Indexing (optional)</h5>
                        <span class="info-tooltip-icon" role="img" aria-label="Indexing help" data-info-tooltip="Indexes are built on the database server to speed up time-based queries and ordering. If you will not use the table in the server JupyterHub, indexing is usually unnecessary because the benefits only apply to server-side functions." tabindex="0">
                            <span class="material-symbols-outlined" aria-hidden="true">help</span>
                        </span>
                    </div>
                    <p class="mb-2 text-muted">
                        The index is primarily based on the time column for fast time-range queries and ordering. Add a sensor/group ID column only when the values are repeated (not unique). Use the include column only if it is commonly looked up.
                    </p>
                    <div class="form-check">
                        <input asp-for="IndexEnabled" class="form-check-input" />
                        <label asp-for="IndexEnabled" class="form-check-label d-inline-flex gap-2 align-items-center">
                            <span>@Html.DisplayNameFor(m => m.IndexEnabled)</span>
                            <span class="info-tooltip-icon" role="img" aria-label="Indexing toggle help" data-info-tooltip="Creates a database index after import to speed up server-side time series queries in JupyterHub." tabindex="0">
                                <span class="material-symbols-outlined" aria-hidden="true">help</span>
                            </span>
                        </label>
                    </div>
                    <div class="row g-3 mt-1 d-none" data-index-options>
                        <div class="col-md-4">
                            <label asp-for="IndexTimeColumn" class="form-label d-inline-flex gap-2 align-items-center">
                                <span>@Html.DisplayNameFor(m => m.IndexTimeColumn)</span>
                                <span class="info-tooltip-icon" role="img" aria-label="Time column help" data-info-tooltip="Required. The primary time column used for sorting and time-range queries. Only datetime columns are available." tabindex="0">
                                    <span class="material-symbols-outlined" aria-hidden="true">help</span>
                                </span>
                            </label>
                            <select asp-for="IndexTimeColumn" class="form-select" asp-items="Model.IndexTimeColumnOptions">
                                <option value="">Select a time column</option>
                            </select>
                            @if (!Model.IndexTimeColumnOptions.Any())
                            {
                                <div class="form-text text-muted">No eligible datetime columns were detected.</div>
                            }
                            <span asp-validation-for="IndexTimeColumn" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IndexIdColumn" class="form-label d-inline-flex gap-2 align-items-center">
                                <span>@Html.DisplayNameFor(m => m.IndexIdColumn)</span>
                                <span class="info-tooltip-icon" role="img" aria-label="ID column help" data-info-tooltip="Optional. Use a sensor/group ID when the values repeat so the index can narrow down time ranges." tabindex="0">
                                    <span class="material-symbols-outlined" aria-hidden="true">help</span>
                                </span>
                            </label>
                            <select asp-for="IndexIdColumn" class="form-select" asp-items="Model.IndexIdColumnOptions">
                                <option value="">No ID column</option>
                            </select>
                            <div class="form-text text-muted">Large text columns are excluded from indexing.</div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IndexIncludeColumn" class="form-label d-inline-flex gap-2 align-items-center">
                                <span>@Html.DisplayNameFor(m => m.IndexIncludeColumn)</span>
                                <span class="info-tooltip-icon" role="img" aria-label="Include column help" data-info-tooltip="Optional. Add a frequently looked up column to keep queries on the server faster." tabindex="0">
                                    <span class="material-symbols-outlined" aria-hidden="true">help</span>
                                </span>
                            </label>
                            <select asp-for="IndexIncludeColumn" class="form-select" asp-items="Model.IndexIncludeColumnOptions">
                                <option value="">No include column</option>
                            </select>
                            <div class="form-text text-muted">Only non-large types are shown.</div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary @(Model.ImportErrors?.Any() == true ? string.Empty : "w-100")" data-reset-proceed>Next</button>
            @if (Model.ImportErrors?.Any() == true)
            {
                <button type="submit" class="btn btn-outline-secondary" data-proceed-errors>Continue to next step with NULL replacements</button>
            }
        </div>
    </form>
</div>

@await Html.PartialAsync("_UploadOverlay")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/upload-overlay.js" asp-append-version="true"></script>
    <script src="~/js/dataQualityDescription.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const fileInput = document.querySelector('input[type="file"][multiple]');
            const fileListDiv = document.getElementById('fileList');
            const form = document.querySelector('form.upload-overlay-form');
            const labelInput = document.querySelector('[data-next-code-input]');
            const codeInput = document.getElementById('Code');
            const existingSelect = document.querySelector('[data-existing-select]');
            const defaultCode = existingSelect?.dataset.defaultCode || codeInput?.value || '';
            const nextCodeUrl = '@Url.Action("NextCode", "Donnees")';
            const overlayMessage = @Html.Raw(JsonSerializer.Serialize(Model.ColumnTypesConfirmed
            ? "We will create the typed table and import your data. Do you want to continue?"
            : "We will analyze your files to infer column types. Do you want to continue?"));

            initUploadOverlay(form, {confirmMessage: overlayMessage});

            const buildTodayIncrementedCode = (baseCode) => {
                const today = new Date();
                const datePrefix = `${today.getFullYear()}${String(today.getMonth() + 1).padStart(2, '0')}${String(today.getDate()).padStart(2, '0')}`;
                const match = (baseCode || '').match(/(\d{2})(?!.*\d)/);
                const incremented = match ? parseInt(match[1], 10) + 1 : 1;
                const suffix = Number.isNaN(incremented) ? '01' : String(incremented).padStart(2, '0');

                return `${datePrefix}${suffix}`;
            };

            const applyExistingSelection = async () => {
                if (!existingSelect || !labelInput || !codeInput) {
                    return;
                }

                const selectedOption = existingSelect.selectedOptions[0];
                if (!selectedOption) {
                    return;
                }

                const hasExisting = Boolean(existingSelect.value);

                if (hasExisting) {
                    if (selectedOption.dataset.libelle) {
                        labelInput.value = selectedOption.dataset.libelle;
                    }
                    try {
                        const response = await fetch(`${nextCodeUrl}?libelle=${encodeURIComponent(labelInput.value.trim())}&source=${existingSelect?.dataset.codeSource ?? 'donnees'}`);
                        if (response.ok) {
                            const data = await response.json();
                            if (data?.code) {
                                codeInput.value = data.code;
                            }
                            else if (selectedOption.dataset.code) {
                                codeInput.value = buildTodayIncrementedCode(selectedOption.dataset.code);
                            }
                        }
                        else if (selectedOption.dataset.code) {
                            codeInput.value = buildTodayIncrementedCode(selectedOption.dataset.code);
                        }
                    }
                    catch {
                        if (selectedOption.dataset.code) {
                            codeInput.value = buildTodayIncrementedCode(selectedOption.dataset.code);
                        }
                    }
                }
                else {
                    // Keep the user's existing label/code if already entered.
                    if (!codeInput.value) {
                        codeInput.value = defaultCode;
                    }
                }

                labelInput.readOnly = hasExisting;
                labelInput.classList.toggle('bg-light', hasExisting);
                if (hasExisting) {
                    labelInput.setAttribute('aria-readonly', 'true');
                } else {
                    labelInput.removeAttribute('aria-readonly');
                }
            };

            const updateCode = async () => {
                if (!labelInput || !codeInput) {
                    return;
                }

                if (existingSelect && existingSelect.value) {
                    await applyExistingSelection();
                    return;
                }

                if (!labelInput.value.trim()) {
                    codeInput.value = defaultCode;
                    return;
                }

                try {
                    const response = await fetch(`${nextCodeUrl}?libelle=${encodeURIComponent(labelInput.value.trim())}&source=${existingSelect?.dataset.codeSource ?? 'donnees'}`);
                    if (!response.ok) {
                        return;
                    }

                    const data = await response.json();
                    if (data?.code) {
                        codeInput.value = data.code;
                    }
                }
                catch {
                    // Silently ignore errors; the server-side will still generate a code.
                }
            };

            if (labelInput) {
                labelInput.addEventListener('blur', updateCode);
                labelInput.addEventListener('change', updateCode);
            }

            if (existingSelect) {
                existingSelect.addEventListener('change', async () => {
                    await applyExistingSelection();
                    if (!existingSelect.value) {
                        await updateCode();
                    }
                });

                applyExistingSelection();
            }

            if (fileInput && fileListDiv) {
                fileInput.addEventListener('change', () => {
                    fileListDiv.innerHTML = '';
                    if (fileInput.files.length > 0) {
                        const table = document.createElement('table');
                        table.className = 'table table-sm table-bordered';
                        const thead = document.createElement('thead');
                        thead.innerHTML = '<tr><th>Name</th><th>Size</th><th>Type</th></tr>';
                        table.appendChild(thead);

                        const tbody = document.createElement('tbody');
                        Array.from(fileInput.files).forEach(file => {
                            const row = document.createElement('tr');
                            row.innerHTML = `<td>${file.name}</td><td>${(file.size / 1024).toFixed(2)} KB</td><td>${file.type}</td>`;
                            tbody.appendChild(row);
                        });
                        table.appendChild(tbody);
                        fileListDiv.appendChild(table);
                    }
                });
            }

            const proceedField = document.querySelector('input[name="ProceedAfterImportErrors"]');
            document.querySelectorAll('[data-proceed-errors]').forEach(button => {
                button.addEventListener('click', () => {
                    if (proceedField) {
                        proceedField.value = 'true';
                    }
                });
            });

            document.querySelectorAll('[data-reset-proceed]').forEach(button => {
                button.addEventListener('click', () => {
                    if (proceedField) {
                        proceedField.value = 'false';
                    }
                });
            });

            document.querySelectorAll('.column-type-select').forEach(select => {
                const targetId = select.dataset.lengthTarget;
                const lengthInput = targetId ? document.getElementById(targetId) : null;

                const toggleLength = () => {
                    if (!lengthInput) {
                        return;
                    }

                    if (select.value === 'NVarChar') {
                        lengthInput.classList.remove('d-none');
                    } else {
                        lengthInput.classList.add('d-none');
                        lengthInput.value = '';
                    }
                };

                select.addEventListener('change', toggleLength);
                toggleLength();
            });

            const indexToggle = document.getElementById('IndexEnabled');
            const indexOptions = document.querySelector('[data-index-options]');
            const timeSelect = document.getElementById('IndexTimeColumn');
            const idSelect = document.getElementById('IndexIdColumn');
            const includeSelect = document.getElementById('IndexIncludeColumn');

            const toggleIndexOptions = () => {
                if (!indexOptions) {
                    return;
                }

                if (indexToggle?.checked) {
                    indexOptions.classList.remove('d-none');
                    if (timeSelect) {
                        timeSelect.setAttribute('required', 'required');
                    }
                } else {
                    indexOptions.classList.add('d-none');
                    if (timeSelect) {
                        timeSelect.removeAttribute('required');
                        timeSelect.value = '';
                    }
                    if (idSelect) {
                        idSelect.value = '';
                    }
                    if (includeSelect) {
                        includeSelect.value = '';
                    }
                }
            };

            if (indexToggle) {
                indexToggle.addEventListener('change', toggleIndexOptions);
                toggleIndexOptions();
            }

            document.querySelectorAll('[data-download-errors]').forEach(button => {
                button.addEventListener('click', () => {
                    const raw = button.getAttribute('data-errors');
                    if (!raw) return;
                    try {
                        const errors = JSON.parse(raw);
                        if (!Array.isArray(errors) || errors.length === 0) return;
                        const lines = errors.map(err => {
                            const fileName = err.FileName || err.fileName || 'unknown file';
                            const column = err.ColumnName || err.columnName || 'unknown column';
                            const row = err.RowNumber || err.rowNumber || '?';
                            const value = (err.RawValue || err.rawValue) ? ` | Value: ${err.RawValue || err.rawValue}` : '';
                            const message = err.Message || err.message || '';
                            return `${fileName} | Row ${row} | Column ${column} | ${message}${value}`;
                        });
                        const blob = new Blob([lines.join('\n')], { type: 'text/plain;charset=utf-8' });
                        const url = URL.createObjectURL(blob);
                        const link = document.createElement('a');
                        link.href = url;
                        link.download = 'import-errors.txt';
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        URL.revokeObjectURL(url);
                    } catch {
                        // ignore
                    }
                });
            });
        });
    </script>
}