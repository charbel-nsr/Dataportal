@model Dataportal.ViewModels.AccueilIndexViewModel

@{
    ViewData["Title"] = "Home";
    var homeReturnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="hero" style="background-image: url(' /background/hero-background.jpg');">
    <div class="container h-100">
        <div class="row h-100 align-items-center justify-content-center">
            <div class="col-md-6 order-2 order-md-1 text-center text-md-start">
                <h1>ÉTS SCADA Data Portal</h1>
                <p>Access, explore, and share the data from your teams active in the renewable energy sector</p>
                <div class="d-flex flex-column flex-md-row align-items-center mt-3 gap-3 justify-content-center justify-content-md-start">
                    <a href="https://www.powerfactors.com/" target="_blank">
                        <img src="~/logo/pf-footer-logo.png" alt="Power Factors Logo" class="collaboration-logo" />
                    </a>
                    <div class="d-none d-md-block flex-grow-1"></div>
                    <a href="https://www.hydroquebec.com/" target="_blank">
                        <img src="~/logo/hq-footer-logo.png" alt="Hydro Quebec Logo" class="collaboration-logo" />
                    </a>
                </div>
                <div class="d-flex flex-column flex-md-row align-items-center mt-3 gap-3 justify-content-center justify-content-md-start">
                    <a href="https://www.mitacs.ca/" target="_blank">
                        <img src="~/logo/Mitacs_logo.png" alt="Mitacs Logo" class="collaboration-logo" />
                    </a>
                    <div class="d-none d-md-block flex-grow-1"></div>
                    @if (!User.Identity.IsAuthenticated)
                    {
                        <a href="/Compte/SeConnecter" class="btn btn-primary mt-4">Sign in</a>
                    }
                    else
                    {
                        <a href="/AccesDonnees/RechercheDonnees" class="btn btn-primary mt-4">View data</a>
                    }
                </div>
            </div>
            <div class="col-md-6 order-1 order-md-2 text-center mb-4 mb-md-0">
                <img src="/illustration/hero-animation.svg" alt="Illustration" class="img-fluid" />
            </div>
        </div>
    </div>
</div>

@if (Model?.LatestDatasets?.Count > 0)
{
    <section class="latest-datasets py-5">
        <div class="container">
            <h2 class="text-center mb-5">Latest datasets</h2>
            <div class="row g-5 justify-content-center">
                @foreach (var dataset in Model.LatestDatasets)
                {
                    <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <div class="card latest-dataset-card h-100 text-center">
                            <div class="card-body d-flex flex-column align-items-center">
                                <div class="dataset-icon-circle rounded-circle d-flex align-items-center justify-content-center mb-3">
                                    <span class="material-symbols-outlined dataset-icon">@dataset.IconName</span>
                                </div>
                                <h5 class="card-title mb-1">@dataset.Name</h5>
                                <p class="text-muted mb-4">@(string.IsNullOrWhiteSpace(dataset.EnergyType) ? "Other" : dataset.EnergyType)</p>
                                <a class="btn btn-outline-primary mt-auto" href="@Url.Action("Details", "Donnees", new { id = dataset.Id, returnUrl = homeReturnUrl })">See data set</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}