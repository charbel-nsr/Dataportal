@{
    ViewData["Title"] = "Notebook API";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var publicEndpoint = $"{baseUrl}/api/notebook/public/donnees/parquet";
    var privateEndpoint = $"{baseUrl}/api/notebook/private/donnees/parquet";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<section class="notebook-api-hero py-5">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <span class="badge rounded-pill text-bg-dark mb-3">Notebook API</span>
                <h1 class="display-5 fw-bold mb-3">Stream datasets directly into your notebooks</h1>
                <p class="lead text-muted mb-4">
                    Use the Notebook API to fetch dataset slices as Parquet, page through results with cursors, and
                    integrate data exploration directly in Python or R notebooks.
                </p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge text-bg-light border">Parquet streaming</span>
                    <span class="badge text-bg-light border">Cursor pagination</span>
                    <span class="badge text-bg-light border">Token authentication</span>
                    <span class="badge text-bg-light border">Rate limited</span>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="card notebook-api-hero-card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Quickstart</h5>
                        <p class="text-muted mb-3">Get a page of data with a single call.</p>
                        <pre class="code-block"><code>GET @publicEndpoint
  ?schema=donnees
  &amp;table=donnees_123
  &amp;limit=1000</code></pre>
                        <div class="text-muted small">Returns an application/x-parquet stream.</div>
                    </div>
                </div>
            </div>
        </div>
        @if (!isAuthenticated)
        {
            <div class="alert alert-info mt-4" role="alert">
                You are currently viewing the public endpoints. Sign in to see private API access and token usage.
            </div>
        }
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between">
                            <div>
                                <h2 class="h4 mb-2">Public API</h2>
                                <p class="text-muted">Use this endpoint for datasets marked as public and API-enabled.</p>
                            </div>
                            <span class="badge rounded-pill text-bg-success">Public</span>
                        </div>
                        <div class="notebook-api-endpoint mb-3">
                            <code>@publicEndpoint</code>
                        </div>
                        <h3 class="h6 text-uppercase text-muted">Query parameters</h3>
                        <ul class="list-unstyled">
                            <li><strong>schema</strong> (required) — One of <code>donnees</code>, <code>donnees_event_logs</code>, <code>donnees_contexte_environnemental</code>.</li>
                            <li><strong>table</strong> (required) — The table name to fetch.</li>
                            <li><strong>limit</strong> (required) — Number of rows per page (1 → 100,000).</li>
                            <li><strong>cursor</strong> (optional) — Cursor returned from the previous page.</li>
                        </ul>
                        <div class="alert alert-secondary small" role="alert">
                            <strong>Safety note:</strong> the API validates schema/table names against metadata and only
                            accepts alphanumeric, underscore, and dash table names. If the table is not linked to metadata, the
                            API returns a 404.
                        </div>
                        <h3 class="h6 text-uppercase text-muted">Example notebook (public)</h3>
                        <p class="text-muted small mb-3">
                            This notebook streams paginated Parquet pages without authentication. It also demonstrates
                            how to handle rate limits and aggregate all pages into a single DataFrame.
                        </p>
                        <div class="mb-3">
                            <div class="text-muted small">Part 1 — Setup and paging helper</div>
                            <pre class="code-block"><code>import io
import time
import pandas as pd
import requests

ENDPOINT = "@publicEndpoint"

def iter_table(schema: str, table: str, limit: int = 100_000, timeout: int = 60):
    """
    Yields (df, headers) for each page of the table using cursor pagination.
    - schema/table: dataset
    - limit: rows per page (1..100000)
    - timeout: seconds for requests
    """
    params = {"schema": schema, "table": table, "limit": limit}
    cursor = None

    while True:
        # Add/remove cursor param
        if cursor:
            params["cursor"] = cursor
        else:
            params.pop("cursor", None)

        r = requests.get(ENDPOINT, params=params, timeout=timeout)

        # Rate limit handling
        if r.status_code == 429:
            retry_after = int(r.headers.get("Retry-After", "2"))
            print(f"Rate limited (429). Sleeping {retry_after}s...")
            time.sleep(retry_after)
            continue

        # No data
        if r.status_code == 204:
            print("No content (204): table has no rows.")
            return

        r.raise_for_status()

        # Parse parquet page
        df = pd.read_parquet(io.BytesIO(r.content), engine="pyarrow")

        yield df, r.headers

        # Next cursor
        cursor = r.headers.get("X-Next-Cursor")
        if not cursor:
            break</code></pre>
                        </div>
                        <div>
                            <div class="text-muted small">Part 2 — Iterate pages and optionally concatenate</div>
                            <pre class="code-block"><code>SCHEMA = "schema"
TABLE = "label-code"

# Start with something safe; increase if stable (e.g., 50_000 or 100_000)
LIMIT = 25_000

total_rows = 0
page = 0

for df_page, headers in iter_table(SCHEMA, TABLE, limit=LIMIT, timeout=60):
    page += 1
    total_rows += len(df_page)

    row_count_hdr = headers.get("X-Row-Count")
    has_more = headers.get("X-Has-More")

    print(
        f"Page {page}: {len(df_page)} rows "
        f"(X-Row-Count={row_count_hdr}, X-Has-More={has_more})"
    )

print("Done. Total rows:", total_rows)

# If the table is not huge and you truly want one DataFrame at the end:
all_pages = []
for df_page, _ in iter_table(SCHEMA, TABLE, limit=LIMIT, timeout=60):
    all_pages.append(df_page)

df = pd.concat(all_pages, ignore_index=True)
df.shape</code></pre>
                        </div>
                        <p class="text-muted small mb-0">Public access does not require a token.</p>
                    </div>
                </div>
            </div>
            @if (isAuthenticated)
            {
                <div class="col-lg-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex align-items-start justify-content-between">
                                <div>
                                    <h2 class="h4 mb-2">Private API</h2>
                                    <p class="text-muted">Use this endpoint for private, internal, or personal datasets.</p>
                                </div>
                                <span class="badge rounded-pill text-bg-primary">Private</span>
                            </div>
                            <div class="notebook-api-endpoint mb-3">
                                <code>@privateEndpoint</code>
                            </div>
                            <h3 class="h6 text-uppercase text-muted">Authentication</h3>
                            <ul class="list-unstyled">
                                <li>Send your token via <strong>Authorization: Bearer</strong>.</li>
                                <li>Or use <strong>X-Notebook-Token</strong> / <strong>X-Api-Key</strong> headers.</li>
                            </ul>
                            <h3 class="h6 text-uppercase text-muted">Example notebook (private)</h3>
                            <p class="text-muted small mb-3">
                                This notebook uses a bearer token to access private datasets. It also shows how to
                                handle auth errors and assemble all pages into a single DataFrame.
                            </p>
                            <div class="mb-3">
                                <div class="text-muted small">Part 1 — Setup headers and paging helper</div>
                                <pre class="code-block"><code>import io
    import time
    import pandas as pd
    import requests

    ENDPOINT = "@privateEndpoint"

    NOTEBOOK_TOKEN = "token"

    HEADERS = {
        "Authorization": f"Bearer {NOTEBOOK_TOKEN}"
        # or alternatively:
        # "X-Notebook-Token": NOTEBOOK_TOKEN
        # "X-Api-Key": NOTEBOOK_TOKEN
    }

    def iter_table(schema: str, table: str, limit: int = 100_000, timeout: int = 60, headers: dict | None = None):
        """
        Yields (df, headers) for each page of the table using cursor pagination (PRIVATE API).
        """
        if headers is None:
            headers = {}

        params = {"schema": schema, "table": table, "limit": limit}
        cursor = None

        # Reuse TCP connection + keep headers
        session = requests.Session()
        session.headers.update(headers)

        while True:
            if cursor:
                params["cursor"] = cursor
            else:
                params.pop("cursor", None)

            r = session.get(ENDPOINT, params=params, timeout=timeout)

            # Rate limit handling
            if r.status_code == 429:
                retry_after = int(r.headers.get("Retry-After", "2"))
                print(f"Rate limited (429). Sleeping {retry_after}s...")
                time.sleep(retry_after)
                continue

            # No data
            if r.status_code == 204:
                print("No content (204): table has no rows.")
                return

            # Auth errors (nice message)
            if r.status_code in (401, 403):
                raise RuntimeError(
                    f"Auth/permission error ({r.status_code}). "
                    f"Check token + dataset permissions. Response: {r.text[:300]}"
                )

            r.raise_for_status()

            df = pd.read_parquet(io.BytesIO(r.content), engine="pyarrow")
            yield df, r.headers

            cursor = r.headers.get("X-Next-Cursor")
            if not cursor:
                break</code></pre>
                            </div>
                            <div>
                                <div class="text-muted small">Part 2 — Iterate pages and optionally concatenate</div>
                                <pre class="code-block"><code>SCHEMA = "schema"                 # or donnees_event_logs / donnees_contexte_environnemental
    TABLE = "label-code"          # change to your private table
    LIMIT = 25_000

    total_rows = 0
    page = 0

    for df_page, resp_headers in iter_table(SCHEMA, TABLE, limit=LIMIT, timeout=60, headers=HEADERS):
        page += 1
        total_rows += len(df_page)

        row_count_hdr = resp_headers.get("X-Row-Count")
        has_more = resp_headers.get("X-Has-More")

        print(
            f"Page {page}: {len(df_page)} rows "
            f"(X-Row-Count={row_count_hdr}, X-Has-More={has_more})"
        )

    print("Done. Total rows:", total_rows)

    # If the table is not huge and you truly want one DataFrame at the end:
    all_pages = []
    for df_page, _ in iter_table(SCHEMA, TABLE, limit=LIMIT, timeout=60, headers=HEADERS):
        all_pages.append(df_page)

    df = pd.concat(all_pages, ignore_index=True)
    df.shape</code></pre>
                            </div>
                            <p class="text-muted small mb-0">
                                Manage your tokens in <a asp-controller="Compte" asp-action="NotebookTokens">Notebook API tokens</a>.
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h2 class="h4 mb-3">Response format</h2>
                        <ul class="list-unstyled mb-4">
                            <li><strong>Content-Type</strong>: <code>application/x-parquet</code></li>
                            <li><strong>Headers</strong>:</li>
                        </ul>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Header</th>
                                        <th>Meaning</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><code>X-Row-Count</code></td>
                                        <td>Number of rows returned in the current page.</td>
                                    </tr>
                                    <tr>
                                        <td><code>X-Has-More</code></td>
                                        <td><code>true</code> if another page is available.</td>
                                    </tr>
                                    <tr>
                                        <td><code>X-Next-Cursor</code></td>
                                        <td>Cursor value to fetch the next page (empty if none).</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <p class="text-muted mb-0">A <strong>204 No Content</strong> response means the dataset has no rows.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="h4 mb-3">Pagination &amp; cursors</h2>
                        <p class="text-muted">
                            Every request must include <code>limit</code>. When you receive an <code>X-Next-Cursor</code>,
                            pass it back as <code>cursor</code> to retrieve the next page.
                        </p>
                        <pre class="code-block"><code>params = {"schema": "donnees", "table": "donnees_123", "limit": 1000}
response = requests.get(endpoint, params=params)

next_cursor = response.headers.get("X-Next-Cursor")
if next_cursor:
    params["cursor"] = next_cursor
    response = requests.get(endpoint, params=params)</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="h4 mb-3">Limits &amp; defaults</h2>
                        <ul class="list-unstyled">
                            <li><strong>Max rows per page:</strong> 100,000</li>
                            <li><strong>Max response size:</strong> 200 MB</li>
                            <li><strong>Default row group size:</strong> 10,000</li>
                            <li><strong>Command timeout:</strong> 60 seconds</li>
                            <li><strong>Public daily limit:</strong> 10 GB per day</li>
                            <li><strong>Private token limit:</strong> 1 GB per 60-minute window</li>
                        </ul>
                        <p class="text-muted small mb-0">Limits may vary by environment and are enforced per API call.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="h4 mb-3">Error responses</h2>
                        <p class="text-muted">Errors use the standard Problem Details JSON format.</p>
                        <ul class="list-unstyled mb-0">
                            <li><strong>400</strong> — Missing/invalid parameters or cursor.</li>
                            <li><strong>401</strong> — Missing/invalid token for private access.</li>
                            <li><strong>403</strong> — Dataset not permitted or API disabled.</li>
                            <li><strong>404</strong> — Dataset not found.</li>
                            <li><strong>413</strong> — Response exceeded size limit.</li>
                            <li><strong>429</strong> — Rate limit exceeded.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>