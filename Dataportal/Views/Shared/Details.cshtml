﻿@using System.Collections.Generic
@using System.Linq
@using Dataportal.Helpers
@model Dataportal.ViewModels.MetadonneeDetailsViewModel

@{
    ViewData["Title"] = "Dataset details";
    var currentStep = ViewData["CurrentStep"] as int?;
    var tabSections = new List<(string Id, string Title)>();
    if (Model.Donnees != null)
    {
        tabSections.Add(("data", "Data"));
    }
    if (Model.DonneesEventLogs != null)
    {
        tabSections.Add(("eventLogs", "Event logs"));
    }
    if (Model.DonneesContexteEnvironnemental != null)
    {
        tabSections.Add(("environmental", "Environmental context"));
    }
    var activeTabId = tabSections.Count > 0 ? tabSections[0].Id : string.Empty;
    var sanitizedDescription = RichTextSanitizer.Sanitize(Model.Metadonnee?.Description);
    var capabilityLinks = new List<(string Label, string Url)>();
    var licenceTooltip = string.IsNullOrWhiteSpace(Model.Licence?.Description)
        ? null
        : Model.Licence.Description;
    var visibilityTooltip = string.IsNullOrWhiteSpace(Model.Visibilite?.Description)
        ? null
        : Model.Visibilite.Description;

    var siteTooltipParts = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Site?.Emplacement))
    {
        siteTooltipParts.Add($"Location: {Model.Site.Emplacement}");
    }

    if (!string.IsNullOrWhiteSpace(Model.Site?.Description))
    {
        siteTooltipParts.Add($"Description: {Model.Site.Description}");
    }

    var siteTooltip = siteTooltipParts.Any() ? string.Join(" • ", siteTooltipParts) : null;
    var canManage = User.IsInRole("administrator") ||
                    (User.IsInRole("editor") && User.Identity.IsAuthenticated && User.FindFirst("UserId")?.Value == Model.Metadonnee.IdUtilisateur.ToString());
    Func<string, string> buildQualityBadgeClass = quality =>
    {
        if (string.IsNullOrWhiteSpace(quality))
        {
            return "quality-badge quality-badge-default";
        }

        var normalized = quality.Trim().ToLowerInvariant();
        if (normalized == "bronze")
        {
            return "quality-badge quality-badge-bronze";
        }

        if (normalized == "silver")
        {
            return "quality-badge quality-badge-silver";
        }

        if (normalized == "gold")
        {
            return "quality-badge quality-badge-gold";
        }

        return "quality-badge quality-badge-default";
    };

    if (Model.TypeEnergieRenouvelable?.Id > 0 && !string.IsNullOrWhiteSpace(Model.TypeEnergieRenouvelable.Libelle))
    {
        var renewableFilterUrl = Url.Action("RechercheDonnees", "AccesDonnees", new { idTypeEnergieRenouvelable = Model.TypeEnergieRenouvelable.Id });
        if (!string.IsNullOrWhiteSpace(renewableFilterUrl))
        {
            capabilityLinks.Add((Model.TypeEnergieRenouvelable.Libelle, renewableFilterUrl));
        }
    }

    if (Model.Metadonnee?.SeriesTemporelles == true)
    {
        var timeSeriesUrl = Url.Action("RechercheDonnees", "AccesDonnees", new { seriesTemporelles = true });
        if (!string.IsNullOrWhiteSpace(timeSeriesUrl))
        {
            capabilityLinks.Add(("Time series", timeSeriesUrl));
        }
    }

    if (Model.Metadonnee?.AutoriserApi == true)
    {
        var apiAllowedUrl = Url.Action("RechercheDonnees", "AccesDonnees", new { autoriserApi = true });
        if (!string.IsNullOrWhiteSpace(apiAllowedUrl))
        {
            capabilityLinks.Add(("API allowed", apiAllowedUrl));
        }
    }

    if (Model.Metadonnee?.Anonymiser == true)
    {
        var anonymizedUrl = Url.Action("RechercheDonnees", "AccesDonnees", new { anonymiser = true });
        if (!string.IsNullOrWhiteSpace(anonymizedUrl))
        {
            capabilityLinks.Add(("Anonymized", anonymizedUrl));
        }
    }

    if (Model.Metadonnee?.AutoriserLeTelechargement == true)
    {
        var downloadAllowedUrl = Url.Action("RechercheDonnees", "AccesDonnees", new { autoriserLeTelechargement = true });
        if (!string.IsNullOrWhiteSpace(downloadAllowedUrl))
        {
            capabilityLinks.Add(("Download allowed", downloadAllowedUrl));
        }
    }
}

<div class="container my-4 data-details-all">
    <div class="mb-4 d-flex flex-wrap align-items-center gap-3">
        <div class="flex-grow-1 min-width-0">
            <h1 class="mb-1">@Model.Metadonnee.Nom</h1>
            @if (Model.Utilisateur != null)
            {
                <button type="button"
                        class="btn btn-link p-0 text-muted text-decoration-none creator-trigger d-inline-flex align-items-center gap-1"
                        data-bs-toggle="modal"
                        data-bs-target="#creatorModal">
                    <small class="mb-0">Charbel Nasr</small>
                    <span class="material-symbols-outlined" style="font-size: 16px;">
                        open_in_new
                    </span>
                </button>
            }
            @if (capabilityLinks.Any())
            {
                <div class="dataset-flags d-flex flex-wrap mt-2">
                    @foreach (var link in capabilityLinks)
                    {
                        <a class="dataset-flag" href="@link.Url" target="_blank">@link.Label</a>
                    }
                </div>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            <a class="btn btn-link text-decoration-none text-muted ms-auto d-inline-flex align-items-center justify-content-center p-2 close-details-link"
               href="@Model.ReturnUrl"
               title="Close dataset details">
                <span class="material-symbols-outlined" aria-hidden="true">cancel</span>
                <span class="visually-hidden">Return to the previous page</span>
                </a>
            }
    </div>

    @if (currentStep.HasValue)
    {
        @await Html.PartialAsync("_CreationProgress")
    }
    
    <section class="metadata-section bg-white shadow-sm rounded p-4 mb-4">
        <div class="d-flex align-items-center justify-content-end flex-wrap gap-2 mb-4">
            <span class="badge bg-light text-dark">Last updated @(Model.Metadonnee.DernierMiseAJour?.ToString("d") ?? "—")</span>
        </div>
        <div class="metadata-description rich-text-content fs-5 mb-4">
            @if (!string.IsNullOrWhiteSpace(sanitizedDescription))
            {
                @Html.Raw(sanitizedDescription)
            }
            else
            {
                <p class="text-muted mb-0">No description has been provided for this dataset yet.</p>
            }
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="detail-field">
                    <span class="detail-label">License</span>
                    <p class="detail-value mb-0 d-flex align-items-center gap-2 flex-wrap">
                        <span>@Model.Licence?.Libelle</span>
                        @if (!string.IsNullOrWhiteSpace(licenceTooltip))
                        {
                            <span class="info-tooltip-icon" role="img" aria-label="License details" data-info-tooltip="@licenceTooltip" tabindex="0">
                                <span class="material-symbols-outlined" aria-hidden="true">info</span>
                            </span>
                        }
                    </p>
                </div>
                <div class="detail-field">
                    <span class="detail-label">Visibility</span>
                    <p class="detail-value mb-0 d-flex align-items-center gap-2 flex-wrap">
                        <span>@Model.Visibilite?.Libelle</span>
                        @if (!string.IsNullOrWhiteSpace(visibilityTooltip))
                        {
                            <span class="info-tooltip-icon" role="img" aria-label="Visibility details" data-info-tooltip="@visibilityTooltip" tabindex="0">
                                <span class="material-symbols-outlined" aria-hidden="true">info</span>
                            </span>
                        }
                    </p>
                </div>
                <div class="detail-field mb-0">
                    <span class="detail-label">Data size</span>
                    <p class="detail-value mb-0">@(Model.Metadonnee?.TailleDesDonnees ?? "—")</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="detail-field">
                    <span class="detail-label">Site</span>
                    <p class="detail-value mb-0 d-flex align-items-center gap-2 flex-wrap">
                        <span>@Model.Site?.Nom</span>
                        @if (!string.IsNullOrWhiteSpace(siteTooltip))
                        {
                            <span class="info-tooltip-icon" role="img" aria-label="Site details" data-info-tooltip="@siteTooltip" tabindex="0">
                                <span class="material-symbols-outlined" aria-hidden="true">info</span>
                            </span>
                        }
                    </p>
                </div>
                <div class="detail-field mb-0">
                    <span class="detail-label">Organisation/Team</span>
                    <p class="detail-value mb-0">@(Model.Utilisateur?.Entreprise?.Nom ?? "—")</p>
                </div>
            </div>
        </div>

        @if (Model.AppareilsLies != null && Model.AppareilsLies.Any())
        {
            <hr />
            <h5>Associated devices</h5>
            <ul>
                @foreach (var app in Model.AppareilsLies)
                {
                    var deviceTooltipParts = new List<string>();
                    if (!string.IsNullOrWhiteSpace(app.Appareil?.Description))
                    {
                        deviceTooltipParts.Add($"Description: {app.Appareil.Description}");
                    }

                    if (!string.IsNullOrWhiteSpace(app.Appareil?.Capacite))
                    {
                        deviceTooltipParts.Add($"Capacity: {app.Appareil.Capacite}");
                    }

                    if (!string.IsNullOrWhiteSpace(app.Appareil?.Model))
                    {
                        deviceTooltipParts.Add($"Model: {app.Appareil.Model}");
                    }

                    if (!string.IsNullOrWhiteSpace(app.Appareil?.Manufacturer))
                    {
                        deviceTooltipParts.Add($"Manufacturer: {app.Appareil.Manufacturer}");
                    }

                    var deviceTooltip = deviceTooltipParts.Any() ? string.Join(" • ", deviceTooltipParts) : null;
                    <li>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span>@app.Appareil?.Nom</span>
                            @if (!string.IsNullOrWhiteSpace(app.Commentaire))
                            {
                                <span class="text-muted">(@app.Commentaire)</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(deviceTooltip))
                            {
                                <span class="info-tooltip-icon" role="img" aria-label="Device details" data-info-tooltip="@deviceTooltip" tabindex="0">
                                    <span class="material-symbols-outlined" aria-hidden="true">info</span>
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(app.IdAppareilDansDonnees))
                        {
                            <div class="text-muted small">String IDs: @app.IdAppareilDansDonnees</div>
                        }
                    </li>
                }
            </ul>
        }
    </section>

    @if (tabSections.Any())
    {
        <ul class="nav nav-tabs" id="datasetDetailsTabs" role="tablist">
            @foreach (var tabSection in tabSections)
            {
                var isActive = tabSection.Id == activeTabId;
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(isActive ? "active" : string.Empty)" id="@tabSection.Id-tab" data-bs-toggle="tab" data-bs-target="#@tabSection.Id" type="button" role="tab" aria-controls="@tabSection.Id" aria-selected="@(isActive ? "true" : "false")">
                        @tabSection.Title
                    </button>
                </li>
            }
        </ul>
        <div class="tab-content border border-top-0 rounded-bottom bg-white shadow-sm p-4" id="datasetDetailsTabsContent">
            @if (Model.Donnees != null)
            {
                <div class="tab-pane fade @(activeTabId == "data" ? "show active" : string.Empty)" id="data" role="tabpanel" aria-labelledby="data-tab">
                    <div class="tab-pane-header">
                        <div class="tab-pane-primary">
                            <div class="detail-row detail-row-inline detail-row-columns">
                                <div class="detail-field">
                                    <span class="detail-label">Label</span>
                                    <p class="detail-value mb-0">@Model.Donnees.Libelle</p>
                                </div>
                                <div class="detail-field">
                                    <span class="detail-label">Code</span>
                                    <p class="detail-value mb-0">@Model.Donnees.Code</p>
                                </div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-field mb-0">
                                    <span class="detail-label">Table name</span>
                                    <p class="detail-value mb-0">@Model.Donnees.NomDeLaTable</p>
                                </div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-field mb-0">
                                    <span class="detail-label">Description</span>
                                    <p class="detail-value mb-0">@Model.Donnees.Description</p>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane-actions">
                            @if (!string.IsNullOrWhiteSpace(Model.Donnees.QualiteDonnees?.Libelle))
                            {
                                <span class="@buildQualityBadgeClass(Model.Donnees.QualiteDonnees.Libelle)" data-quality-description="@Model.Donnees.QualiteDonnees?.Description">@Model.Donnees.QualiteDonnees.Libelle</span>
                            }
                            @if (Model.Metadonnee?.AutoriserLeTelechargement == true && !string.IsNullOrWhiteSpace(Model.Donnees?.NomDeLaTable))
                            {
                                <button type="button"
                                        class="btn btn-outline-primary btn-sm download-table"
                                        data-table-name="@Model.Donnees.NomDeLaTable"
                                        data-download-parts='@System.Text.Json.JsonSerializer.Serialize(new[] { Model.Metadonnee.Nom, Model.Donnees?.Libelle, "data" })'
                                        data-max-rows-per-part="1000000"
                                        title="Download data as CSV (ZIP)"
                                        aria-label="Download the Data table as a ZIP archive">
                                    <span class="material-symbols-outlined align-middle" aria-hidden="true">download</span>
                                    <span class="align-middle">Download data</span>
                                </button>
                            }
                        </div>
                    </div>
                    <div class="detail-row detail-row-inline detail-row-columns">
                        <div class="detail-field">
                            <span class="detail-label">Number of sensors</span>
                            <p class="detail-value mb-0">@Model.Donnees.NombreDeCapteurs</p>
                        </div>
                        <div class="detail-field">
                            <span class="detail-label">Collection frequency</span>
                            <p class="detail-value mb-0">@Model.Donnees.FrequenceDeCollect</p>
                        </div>
                    </div>
                    <div class="detail-row mb-0">
                        <div class="detail-field mb-0">
                            <span class="detail-label">Dates</span>
                            <p class="detail-value mb-0">@Model.Donnees.StartTimestamp.ToShortDateString() - @Model.Donnees.EndTimestamp.ToShortDateString()</p>
                        </div>
                    </div>
                    @if (canManage)
                    {
                        <br />
                        <div class="detail-row mb-0">
                            <div class="detail-field mb-0">
                                <span class="detail-label">Indexing</span>
                                @if (Model.Donnees.IndexEnabled)
                                {
                                    <ul class="list-unstyled mb-0">
                                        <li><strong>Time column:</strong> @(Model.Donnees.IndexTimeColumn ?? "—")</li>
                                        <li><strong>ID column:</strong> @(Model.Donnees.IndexIdColumn ?? "—")</li>
                                        <li><strong>Include column:</strong> @(Model.Donnees.IndexIncludeColumn ?? "—")</li>
                                        <li><strong>Index type:</strong> @(Model.Donnees.IndexType ?? "—")</li>
                                        <li><strong>Index name:</strong> @(Model.Donnees.IndexName ?? "—")</li>
                                        <li><strong>Status:</strong> @(Model.Donnees.IndexStatus ?? "—")</li>
                                        @if (!string.IsNullOrWhiteSpace(Model.Donnees.IndexError))
                                        {
                                            <li><strong>Error:</strong> @Model.Donnees.IndexError</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="detail-value mb-0">Indexing not enabled.</p>
                                }
                            </div>
                        </div>
                    }

                    @if (Model.DonneesPreviewRows?.Any() == true)
                    {
                        <hr />
                        <h6 class="preview-heading text-center">Data preview</h6>
                        <div class="table-responsive">
                            <table class="table table-striped table-sm preview-table" data-table-name="@Model.Donnees.NomDeLaTable" data-fallback-schema="donnees">
                                <thead>
                                    <tr>
                                        @foreach (var col in Model.DonneesPreviewRows.First().Keys)
                                        {
                                            <th>@col</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="preview-summary-row is-loading" data-preview-summary>
                                        @foreach (var _ in Model.DonneesPreviewRows.First().Keys)
                                        {
                                            <td>
                                                <div class="summary-skeleton" aria-hidden="true">
                                                    <span></span>
                                                    <span></span>
                                                    <span></span>
                                                </div>
                                            </td>
                                        }
                                    </tr>
                                    @foreach (var row in Model.DonneesPreviewRows)
                                    {
                                        <tr>
                                            @foreach (var val in row.Values)
                                            {
                                                <td>@val</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
            @if (Model.DonneesEventLogs != null)
            {
                <div class="tab-pane fade @(activeTabId == "eventLogs" ? "show active" : string.Empty)" id="eventLogs" role="tabpanel" aria-labelledby="eventLogs-tab">
                    <div class="tab-pane-header">
                        <div class="tab-pane-primary">
                            <div class="detail-row detail-row-inline detail-row-columns">
                                <div class="detail-field">
                                    <span class="detail-label">Label</span>
                                    <p class="detail-value mb-0">@Model.DonneesEventLogs.Libelle</p>
                                </div>
                                <div class="detail-field">
                                    <span class="detail-label">Code</span>
                                    <p class="detail-value mb-0">@Model.DonneesEventLogs.Code</p>
                                </div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-field mb-0">
                                    <span class="detail-label">Table name</span>
                                    <p class="detail-value mb-0">@Model.DonneesEventLogs.NomDeLaTable</p>
                                </div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-field mb-0">
                                    <span class="detail-label">Description</span>
                                    <p class="detail-value mb-0">@Model.DonneesEventLogs.Description</p>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane-actions">
                            @if (!string.IsNullOrWhiteSpace(Model.DonneesEventLogs.QualiteDonnees?.Libelle))
                            {
                                <span class="@buildQualityBadgeClass(Model.DonneesEventLogs.QualiteDonnees.Libelle)" data-quality-description="@Model.DonneesEventLogs.QualiteDonnees?.Description">@Model.DonneesEventLogs.QualiteDonnees.Libelle</span>
                            }
                            @if (Model.Metadonnee?.AutoriserLeTelechargement == true && !string.IsNullOrWhiteSpace(Model.DonneesEventLogs?.NomDeLaTable))
                            {
                                <button type="button"
                                        class="btn btn-outline-primary btn-sm download-table"
                                        data-table-name="@Model.DonneesEventLogs.NomDeLaTable"
                                        data-download-parts='@System.Text.Json.JsonSerializer.Serialize(new[] { Model.Metadonnee.Nom, Model.DonneesEventLogs?.Libelle, "eventLogs" })'
                                        data-max-rows-per-part="1000000"
                                        title="Download event logs as CSV (ZIP)"
                                        aria-label="Download the Event logs table as a ZIP archive">
                                    <span class="material-symbols-outlined align-middle" aria-hidden="true">download</span>
                                    <span class="align-middle">Download event logs</span>
                                </button>
                            }
                        </div>
                    </div>
                    <div class="detail-row detail-row-inline detail-row-columns mb-0">
                        <div class="detail-field">
                            <span class="detail-label">Number of events</span>
                            <p class="detail-value mb-0">@Model.DonneesEventLogs.NombreDEvents</p>
                        </div>
                        <div class="detail-field">
                            <span class="detail-label">Dates</span>
                            <p class="detail-value mb-0">@Model.DonneesEventLogs.StartTimestamp.ToShortDateString() - @Model.DonneesEventLogs.EndTimestamp.ToShortDateString()</p>
                        </div>
                    </div>
                    @if (canManage)
                    {
                        <br />
                        <div class="detail-row mb-0">
                            <div class="detail-field mb-0">
                                <span class="detail-label">Indexing</span>
                                @if (Model.DonneesEventLogs.IndexEnabled)
                                {
                                    <ul class="list-unstyled mb-0">
                                        <li><strong>Time column:</strong> @(Model.DonneesEventLogs.IndexTimeColumn ?? "—")</li>
                                        <li><strong>ID column:</strong> @(Model.DonneesEventLogs.IndexIdColumn ?? "—")</li>
                                        <li><strong>Include column:</strong> @(Model.DonneesEventLogs.IndexIncludeColumn ?? "—")</li>
                                        <li><strong>Index type:</strong> @(Model.DonneesEventLogs.IndexType ?? "—")</li>
                                        <li><strong>Index name:</strong> @(Model.DonneesEventLogs.IndexName ?? "—")</li>
                                        <li><strong>Status:</strong> @(Model.DonneesEventLogs.IndexStatus ?? "—")</li>
                                        @if (!string.IsNullOrWhiteSpace(Model.DonneesEventLogs.IndexError))
                                        {
                                            <li><strong>Error:</strong> @Model.DonneesEventLogs.IndexError</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="detail-value mb-0">Indexing not enabled.</p>
                                }
                            </div>
                        </div>
                    }

                    @if (Model.EventLogsPreviewRows?.Any() == true)
                    {
                        <hr />
                        <h6 class="preview-heading text-center">Event log preview</h6>
                        <div class="table-responsive">
                            <table class="table table-striped table-sm preview-table" data-table-name="@Model.DonneesEventLogs.NomDeLaTable" data-fallback-schema="donnees_event_logs">
                                <thead>
                                    <tr>
                                        @foreach (var col in Model.EventLogsPreviewRows.First().Keys)
                                        {
                                            <th>@col</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="preview-summary-row is-loading" data-preview-summary>
                                        @foreach (var _ in Model.EventLogsPreviewRows.First().Keys)
                                        {
                                            <td>
                                                <div class="summary-skeleton" aria-hidden="true">
                                                    <span></span>
                                                    <span></span>
                                                    <span></span>
                                                </div>
                                            </td>
                                        }
                                    </tr>
                                    @foreach (var row in Model.EventLogsPreviewRows)
                                    {
                                        <tr>
                                            @foreach (var val in row.Values)
                                            {
                                                <td>@val</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }

            @if (Model.DonneesContexteEnvironnemental != null)
            {
                <div class="tab-pane fade @(activeTabId == "environmental" ? "show active" : string.Empty)" id="environmental" role="tabpanel" aria-labelledby="environmental-tab">
                    <div class="tab-pane-header">
                        <div class="tab-pane-primary">
                            <div class="detail-row detail-row-inline">
                                <div class="detail-field">
                                    <span class="detail-label">Label</span>
                                    <p class="detail-value mb-0">@Model.DonneesContexteEnvironnemental.Libelle</p>
                                </div>
                                <div class="detail-field">
                                    <span class="detail-label">Code</span>
                                    <p class="detail-value mb-0">@Model.DonneesContexteEnvironnemental.Code</p>
                                </div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-field mb-0">
                                    <span class="detail-label">Table name</span>
                                    <p class="detail-value mb-0">@Model.DonneesContexteEnvironnemental.NomDeLaTable</p>
                                </div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-field mb-0">
                                    <span class="detail-label">Description</span>
                                    <p class="detail-value mb-0">@Model.DonneesContexteEnvironnemental.Description</p>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane-actions">
                            @if (!string.IsNullOrWhiteSpace(Model.DonneesContexteEnvironnemental.QualiteDonnees?.Libelle))
                            {
                                <span class="@buildQualityBadgeClass(Model.DonneesContexteEnvironnemental.QualiteDonnees.Libelle)" data-quality-description="@Model.DonneesContexteEnvironnemental.QualiteDonnees?.Description">@Model.DonneesContexteEnvironnemental.QualiteDonnees.Libelle</span>
                            }
                            @if (Model.Metadonnee?.AutoriserLeTelechargement == true && !string.IsNullOrWhiteSpace(Model.DonneesContexteEnvironnemental?.NomDeLaTable))
                            {
                                <button type="button"
                                        class="btn btn-outline-primary btn-sm download-table"
                                        data-table-name="@Model.DonneesContexteEnvironnemental.NomDeLaTable"
                                        data-download-parts='@System.Text.Json.JsonSerializer.Serialize(new[] { Model.Metadonnee.Nom, Model.DonneesContexteEnvironnemental?.Libelle, "environment" })'
                                        data-max-rows-per-part="1000000"
                                        title="Download environmental context as CSV (ZIP)"
                                        aria-label="Download the Environmental context table as a ZIP archive">
                                    <span class="material-symbols-outlined align-middle" aria-hidden="true">download</span>
                                    <span class="align-middle">Download environmental context</span>
                                </button>
                            }
                        </div>
                    </div>
                    <div class="detail-row mb-0">
                        <div class="detail-field mb-0">
                            <span class="detail-label">Dates</span>
                            <p class="detail-value mb-0">@Model.DonneesContexteEnvironnemental.StartTimestamp.ToShortDateString() - @Model.DonneesContexteEnvironnemental.EndTimestamp.ToShortDateString()</p>
                        </div>
                    </div>
                    @if (canManage)
                    {
                        <br />
                        <div class="detail-row mb-0">
                            <div class="detail-field mb-0">
                                <span class="detail-label">Indexing</span>
                                @if (Model.DonneesContexteEnvironnemental.IndexEnabled)
                                {
                                    <ul class="list-unstyled mb-0">
                                        <li><strong>Time column:</strong> @(Model.DonneesContexteEnvironnemental.IndexTimeColumn ?? "—")</li>
                                        <li><strong>ID column:</strong> @(Model.DonneesContexteEnvironnemental.IndexIdColumn ?? "—")</li>
                                        <li><strong>Include column:</strong> @(Model.DonneesContexteEnvironnemental.IndexIncludeColumn ?? "—")</li>
                                        <li><strong>Index type:</strong> @(Model.DonneesContexteEnvironnemental.IndexType ?? "—")</li>
                                        <li><strong>Index name:</strong> @(Model.DonneesContexteEnvironnemental.IndexName ?? "—")</li>
                                        <li><strong>Status:</strong> @(Model.DonneesContexteEnvironnemental.IndexStatus ?? "—")</li>
                                        @if (!string.IsNullOrWhiteSpace(Model.DonneesContexteEnvironnemental.IndexError))
                                        {
                                            <li><strong>Error:</strong> @Model.DonneesContexteEnvironnemental.IndexError</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="detail-value mb-0">Indexing not enabled.</p>
                                }
                            </div>
                        </div>
                    }

                    @if (Model.ContextePreviewRows?.Any() == true)
                    {
                        <hr />
                        <h6 class="preview-heading text-center">Environmental context preview</h6>
                        <div class="table-responsive">
                            <table class="table table-striped table-sm preview-table" data-table-name="@Model.DonneesContexteEnvironnemental.NomDeLaTable" data-fallback-schema="donnees_contexte_environnemental">
                                <thead>
                                    <tr>
                                        @foreach (var col in Model.ContextePreviewRows.First().Keys)
                                        {
                                            <th>@col</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="preview-summary-row is-loading" data-preview-summary>
                                        @foreach (var _ in Model.ContextePreviewRows.First().Keys)
                                        {
                                            <td>
                                                <div class="summary-skeleton" aria-hidden="true">
                                                    <span></span>
                                                    <span></span>
                                                    <span></span>
                                                </div>
                                            </td>
                                        }
                                    </tr>
                                    @foreach (var row in Model.ContextePreviewRows)
                                    {
                                        <tr>
                                            @foreach (var val in row.Values)
                                            {
                                                <td>@val</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@if (Model.Utilisateur != null)
{
    <div class="modal fade" id="creatorModal" tabindex="-1" aria-labelledby="creatorModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="creatorModalLabel">Creator information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.Utilisateur.Prenom @Model.Utilisateur.Nom</dd>
                        <dt class="col-sm-4">Organisation</dt>
                        <dd class="col-sm-8">@(Model.Utilisateur.Entreprise?.Nom ?? "—")</dd>
                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">
                            <a href="mailto:@Model.Utilisateur.Email">@Model.Utilisateur.Email</a>
                        </dd>
                        @if (!string.IsNullOrWhiteSpace(Model.Utilisateur.LienLinkedIn))
                        {
                            <dt class="col-sm-4">LinkedIn</dt>
                            <dd class="col-sm-8">
                                <a href="@Model.Utilisateur.LienLinkedIn" target="_blank" rel="noopener">@Model.Utilisateur.LienLinkedIn</a>
                            </dd>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Utilisateur.DescriptionProfil))
                        {
                            <dt class="col-sm-4">Biography</dt>
                            <dd class="col-sm-8">@Model.Utilisateur.DescriptionProfil</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const downloadButtons = Array.from(document.querySelectorAll('.download-table'));
            const previewTables = Array.from(document.querySelectorAll('.preview-table'));

            const parseDownloadParts = (rawParts) => {
                if (!rawParts) {
                    return [];
                }

                try {
                    const parsed = JSON.parse(rawParts);
                    if (Array.isArray(parsed)) {
                        return parsed;
                    }
                } catch (_err) {
                    // Ignore and fallback below.
                }

                return rawParts.split('|');
            };

            const buildDownloadName = (rawParts) => {
                const parts = parseDownloadParts(rawParts);
                if (!parts || parts.length === 0) {
                    return 'dataset';
                }

                const seen = new Set();
                const normalized = [];

                parts.forEach((part) => {
                    const trimmed = (part ?? '').toString().trim();
                    if (!trimmed) {
                        return;
                    }

                    const key = trimmed.toLowerCase();
                    if (seen.has(key)) {
                        return;
                    }

                    seen.add(key);
                    normalized.push(trimmed);
                });

                return normalized.length > 0 ? normalized.join('_') : 'dataset';
            };

            const sanitizeFileName = (name) => {
                if (!name) {
                    return 'dataset';
                }

                const invalidChars = /[\\/:*?"<>|]+/g;
                const sanitized = name.replace(invalidChars, '_').trim();
                if (!sanitized) {
                    return 'dataset';
                }

                return sanitized.length > 120 ? sanitized.slice(0, 120) : sanitized;
            };

            downloadButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    const tableName = button.dataset.tableName;
                    if (!tableName) {
                        return;
                    }

                    const fileBase = sanitizeFileName(buildDownloadName(button.dataset.downloadParts || tableName));
                    const maxRows = button.dataset.maxRowsPerPart || '1000000';
                    const url = `/api/exports/table/${encodeURIComponent(tableName)}/zip?maxRowsPerPart=${encodeURIComponent(maxRows)}`;

                    button.disabled = true;
                    button.setAttribute('aria-busy', 'true');

                    const anchor = document.createElement('a');
                    anchor.href = url;
                    anchor.rel = 'noopener';
                    anchor.style.display = 'none';
                    anchor.download = `${fileBase}.zip`;
                    document.body.appendChild(anchor);
                    anchor.click();

                    window.setTimeout(() => {
                        anchor.remove();
                    }, 0);

                    window.setTimeout(() => {
                        button.disabled = false;
                        button.removeAttribute('aria-busy');
                    }, 1500);
                });
            });

            const formatNumber = (value) => {
                if (!Number.isFinite(value)) {
                    return '—';
                }

                return new Intl.NumberFormat(undefined, {
                    maximumFractionDigits: 2
                }).format(value);
            };

            const formatDate = (value) => {
                if (!value) {
                    return '—';
                }

                const parsed = new Date(value);
                if (Number.isNaN(parsed.getTime())) {
                    return '—';
                }

                return parsed.toLocaleDateString();
            };

            const parseNumber = (value) => {
                if (value === null || value === undefined) {
                    return null;
                }

                const parsed = Number(value);
                return Number.isFinite(parsed) ? parsed : null;
            };

            const buildSummaryLines = (summary) => {
                if (!summary) {
                    return [
                        { label: 'Type', value: '—' },
                        { label: 'Unique', value: '—' }
                    ];
                }

                const uniqueCount = summary.uniqueCount ?? '—';
                const nonNullCount = summary.nonNullCount ?? '—';
                const typeLabel = summary.dataType || '—';

                if (summary.category === 'Boolean') {
                    return [
                        { label: 'Type', value: typeLabel },
                        { label: 'Non-null', value: nonNullCount.toString() },
                        { label: 'Unique', value: uniqueCount.toString() }
                    ];
                }

                if (summary.category === 'Number') {
                    const minValue = formatNumber(parseNumber(summary.minValue));
                    const maxValue = formatNumber(parseNumber(summary.maxValue));
                    const avgValue = formatNumber(parseNumber(summary.avgValue));
                    const stdDevValue = formatNumber(parseNumber(summary.stdDevValue));

                    return [
                        { label: 'Type', value: typeLabel },
                        { label: 'Min / Max', value: `${minValue} / ${maxValue}` },
                        { label: 'Avg', value: avgValue },
                        { label: 'Std dev', value: stdDevValue },
                        { label: 'Non-null', value: nonNullCount.toString() },
                        { label: 'Unique', value: uniqueCount.toString() }
                    ];
                }

                if (summary.category === 'Date') {
                    return [
                        { label: 'Type', value: typeLabel },
                        { label: 'Min / Max', value: `${formatDate(summary.minValue)} / ${formatDate(summary.maxValue)}` },
                        { label: 'Non-null', value: nonNullCount.toString() },
                        { label: 'Unique', value: uniqueCount.toString() }
                    ];
                }

                if (summary.category === 'Text') {
                    const avgLength = formatNumber(parseNumber(summary.avgLength));
                    const maxLength = summary.maxLength ?? '—';
                    const minLength = summary.minLength ?? '—';

                    return [
                        { label: 'Type', value: typeLabel },
                        { label: 'Non-null', value: nonNullCount.toString() },
                        { label: 'Unique', value: uniqueCount.toString() },
                        { label: 'Min / Max', value: `${minLength} / ${maxLength}` },
                        { label: 'Avg length', value: avgLength }
                    ];
                }

                return [
                    { label: 'Type', value: typeLabel },
                    { label: 'Non-null', value: nonNullCount.toString() },
                    { label: 'Unique', value: uniqueCount.toString() }
                ];
            };

            const renderSummaryCell = (cell, lines) => {
                cell.textContent = '';
                const container = document.createElement('div');
                container.className = 'column-summary';
                lines.forEach((line) => {
                    const row = document.createElement('div');
                    row.className = 'column-summary-line';
                    const label = document.createElement('span');
                    label.className = 'column-summary-label';
                    label.textContent = line.label;
                    const value = document.createElement('span');
                    value.className = 'column-summary-value';
                    value.textContent = line.value;
                    row.appendChild(label);
                    row.appendChild(value);
                    container.appendChild(row);
                });
                cell.appendChild(container);
            };

            const buildTableSummaries = async (table) => {
                const summaryRow = table.querySelector('[data-preview-summary]');
                if (!summaryRow) {
                    return;
                }

                const tableName = table.dataset.tableName;
                const fallbackSchema = table.dataset.fallbackSchema || '';

                if (!tableName) {
                    summaryRow.classList.remove('is-loading');
                    return;
                }

                try {
                    const response = await fetch(`/api/table-summary?tableName=${encodeURIComponent(tableName)}&fallbackSchema=${encodeURIComponent(fallbackSchema)}`);
                    if (!response.ok) {
                        throw new Error('Failed to load summary');
                    }

                    const payload = await response.json();
                    const columns = Array.isArray(payload?.columns) ? payload.columns : [];
                    const columnLookup = new Map(columns.map((column) => [column.name, column]));
                    const headers = Array.from(table.querySelectorAll('thead th')).map((th) => th.textContent?.trim() ?? '');

                    headers.forEach((header, index) => {
                        const summary = columnLookup.get(header);
                        const lines = buildSummaryLines(summary);
                        renderSummaryCell(summaryRow.children[index], lines);
                    });
                } catch (_error) {
                    const headers = Array.from(table.querySelectorAll('thead th'));
                    headers.forEach((_, index) => {
                        renderSummaryCell(summaryRow.children[index], [
                            { label: 'Type', value: 'Unavailable' },
                            { label: 'Unique', value: '—' }
                        ]);
                    });
                } finally {
                    summaryRow.classList.remove('is-loading');
                }
            };

            const scheduleSummaries = () => {
                previewTables.forEach((table, index) => {
                    const delay = 120 + index * 80;
                    window.setTimeout(() => buildTableSummaries(table), delay);
                });
            };

            if (previewTables.length > 0) {
                if ('requestIdleCallback' in window) {
                    window.requestIdleCallback(scheduleSummaries);
                } else {
                    scheduleSummaries();
                }
            }
        });
    </script>
}
