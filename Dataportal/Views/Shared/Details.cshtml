@model Dataportal.ViewModels.MetadonneeDetailsViewModel

@{
    ViewData["Title"] = "Dataset details";
    var currentStep = ViewData["CurrentStep"] as int?;
}

<div class="container my-4">
    <h2 class="mb-4">@Model.Metadonnee.Nom</h2>
    @if (currentStep.HasValue)
    {
        @await Html.PartialAsync("_CreationProgress")
    }
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <span>Metadata</span>
            <button type="button" class="btn btn-sm btn-outline-light toggle-section" data-section-title="Metadata" data-expanded-symbol="−" data-collapsed-symbol="+" aria-expanded="true" aria-label="Collapse the Metadata section">−</button>
        </div>
        <div class="card-body">
            <p><strong>Description:</strong> @Model.Metadonnee.Description</p>
            <p><strong>License:</strong> @Model.Licence?.Libelle</p>
            <p><strong>Site:</strong> @Model.Site?.Nom</p>
            <p><strong>Visibility:</strong> @Model.Visibilite?.Libelle</p>
            <p><strong>Creator:</strong> @Model.Utilisateur?.Nom @Model.Utilisateur?.Prenom (@Model.Utilisateur?.Email)</p>
            <p><strong>Data size:</strong> @(Model.Metadonnee?.TailleDesDonnees ?? "—")</p>
            <p><strong>Time series:</strong> @(Model.Metadonnee.SeriesTemporelles ? "Yes" : "No")</p>
            <p><strong>API allowed:</strong> @(Model.Metadonnee.AutoriserApi ? "Yes" : "No")</p>
            <p><strong>Anonymization:</strong> @(Model.Metadonnee.Anonymiser ? "Yes" : "No")</p>
            <p><strong>Downloads allowed:</strong> @(Model.Metadonnee.AutoriserLeTelechargement ? "Yes" : "No")</p>
            <p><strong>Last updated:</strong> @Model.Metadonnee.DernierMiseAJour?.ToString("g")</p>

            @if (Model.AppareilsLies != null && Model.AppareilsLies.Any())
            {
                <hr />
                <h5>Associated devices</h5>
                <ul>
                    @foreach (var app in Model.AppareilsLies)
                    {
                        <li>
                            @app.Appareil?.Nom (@app.Commentaire)
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    @if (Model.Donnees != null)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <span>Data</span>
                <button type="button" class="btn btn-sm btn-outline-light toggle-section" data-section-title="Data" data-expanded-symbol="−" data-collapsed-symbol="+" aria-expanded="true" aria-label="Collapse the Data section">−</button>
            </div>
            <div class="card-body">
                <p><strong>Label:</strong> @Model.Donnees.Libelle</p>
                <p><strong>Code:</strong> @Model.Donnees.Code</p>
                <p><strong>Table name:</strong> @Model.Donnees.NomDeLaTable</p>
                <p><strong>Description:</strong> @Model.Donnees.Description</p>
                <p><strong>Data quality:</strong> @(Model.Donnees.QualiteDonnees?.Libelle ?? "—")</p>
                @if (!string.IsNullOrWhiteSpace(Model.Donnees.QualiteDonnees?.Description))
                {
                    <p class="text-muted">@Model.Donnees.QualiteDonnees.Description</p>
                }
                <p><strong>Number of sensors:</strong> @Model.Donnees.NombreDeCapteurs</p>
                <p><strong>Collection frequency:</strong> @Model.Donnees.FrequenceDeCollect</p>
                <p><strong>Dates:</strong> @Model.Donnees.StartTimestamp.ToShortDateString() - @Model.Donnees.EndTimestamp.ToShortDateString()</p>

                @if (Model.DonneesPreviewRows?.Any() == true)
                {
                    <hr />
                    <h6>Data preview</h6>
                    <div class="table-responsive">
                        <table class="table table-striped table-sm">
                            <thead>
                                <tr>
                                    @foreach (var col in Model.DonneesPreviewRows.First().Keys)
                                    {
                                        <th>@col</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.DonneesPreviewRows)
                                {
                                    <tr>
                                        @foreach (var val in row.Values)
                                        {
                                            <td>@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.DonneesEventLogs != null)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-warning text-white d-flex justify-content-between align-items-center">
                <span>Event logs</span>
                <button type="button" class="btn btn-sm btn-outline-light toggle-section" data-section-title="Event logs" data-expanded-symbol="−" data-collapsed-symbol="+" aria-expanded="true" aria-label="Collapse the event logs section">−</button>
            </div>
            <div class="card-body">
                <p><strong>Label:</strong> @Model.DonneesEventLogs.Libelle</p>
                <p><strong>Code:</strong> @Model.DonneesEventLogs.Code</p>
                <p><strong>Table name:</strong> @Model.DonneesEventLogs.NomDeLaTable</p>
                <p><strong>Description:</strong> @Model.DonneesEventLogs.Description</p>
                <p><strong>Data quality:</strong> @(Model.DonneesEventLogs.QualiteDonnees?.Libelle ?? "—")</p>
                @if (!string.IsNullOrWhiteSpace(Model.DonneesEventLogs.QualiteDonnees?.Description))
                {
                    <p class="text-muted">@Model.DonneesEventLogs.QualiteDonnees.Description</p>
                }
                <p><strong>Number of events:</strong> @Model.DonneesEventLogs.NombreDEvents</p>
                <p><strong>Dates:</strong> @Model.DonneesEventLogs.StartTimestamp.ToShortDateString() - @Model.DonneesEventLogs.EndTimestamp.ToShortDateString()</p>

                @if (Model.EventLogsPreviewRows?.Any() == true)
                {
                    <hr />
                    <h6>Event log preview</h6>
                    <div class="table-responsive">
                        <table class="table table-striped table-sm">
                            <thead>
                                <tr>
                                    @foreach (var col in Model.EventLogsPreviewRows.First().Keys)
                                    {
                                        <th>@col</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.EventLogsPreviewRows)
                                {
                                    <tr>
                                        @foreach (var val in row.Values)
                                        {
                                            <td>@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.DonneesContexteEnvironnemental != null)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <span>Environmental context</span>
                <button type="button" class="btn btn-sm btn-outline-light toggle-section" data-section-title="Environmental context" data-expanded-symbol="−" data-collapsed-symbol="+" aria-expanded="true" aria-label="Collapse the environmental context section">−</button>
            </div>
            <div class="card-body">
                <p><strong>Label:</strong> @Model.DonneesContexteEnvironnemental.Libelle</p>
                <p><strong>Code:</strong> @Model.DonneesContexteEnvironnemental.Code</p>
                <p><strong>Table name:</strong> @Model.DonneesContexteEnvironnemental.NomDeLaTable</p>
                <p><strong>Description:</strong> @Model.DonneesContexteEnvironnemental.Description</p>
                <p><strong>Data quality:</strong> @(Model.DonneesContexteEnvironnemental.QualiteDonnees?.Libelle ?? "—")</p>
                @if (!string.IsNullOrWhiteSpace(Model.DonneesContexteEnvironnemental.QualiteDonnees?.Description))
                {
                    <p class="text-muted">@Model.DonneesContexteEnvironnemental.QualiteDonnees.Description</p>
                }
                <p><strong>Dates:</strong> @Model.DonneesContexteEnvironnemental.StartTimestamp.ToShortDateString() - @Model.DonneesContexteEnvironnemental.EndTimestamp.ToShortDateString()</p>

                @if (Model.ContextePreviewRows?.Any() == true)
                {
                    <hr />
                    <h6>Environmental context preview</h6>
                    <div class="table-responsive">
                        <table class="table table-striped table-sm">
                            <thead>
                                <tr>
                                    @foreach (var col in Model.ContextePreviewRows.First().Keys)
                                    {
                                        <th>@col</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.ContextePreviewRows)
                                {
                                    <tr>
                                        @foreach (var val in row.Values)
                                        {
                                            <td>@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    <div class="text-center mt-4">
        <a href="@Url.Action("RechercheDonnees", "AccesDonnees")" class="btn btn-outline-primary">
            All data
        </a>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.card-header .toggle-section').forEach((button) => {
                const expandedSymbol = button.dataset.expandedSymbol || '−';
                button.textContent = expandedSymbol;

                button.addEventListener('click', () => {
                    const cardHeader = button.closest('.card-header');
                    if (!cardHeader) {
                        return;
                    }

                    const cardBody = cardHeader.nextElementSibling;
                    if (!cardBody) {
                        return;
                    }

                    const isCollapsed = cardBody.classList.toggle('d-none');
                    const collapsedSymbol = button.dataset.collapsedSymbol || '+';
                    const sectionTitle = button.dataset.sectionTitle || '';
                    const actionLabel = isCollapsed ? 'Expand' : 'Collapse';

                    button.textContent = isCollapsed ? collapsedSymbol : expandedSymbol;
                    button.setAttribute('aria-expanded', (!isCollapsed).toString());
                    button.setAttribute('aria-label', sectionTitle
                        ? `${actionLabel} the ${sectionTitle} section`
                        : `${actionLabel} the section`);
                });
            });
        });
    </script>
}