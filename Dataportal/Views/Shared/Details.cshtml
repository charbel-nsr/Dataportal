@model Dataportal.ViewModels.MetadonneeDetailsViewModel

@{
    ViewData["Title"] = "Dataset details";
    var currentStep = ViewData["CurrentStep"] as int?;
}

<div class="container my-4 data-details-all">
    <div class="d-flex justify-content-between align-items-center mb-4 gap-2 flex-wrap">
        <h2 class="mb-0">@Model.Metadonnee.Nom</h2>
        <button type="button" class="btn btn-link p-0 toggle-all-sections" data-expanded-text="Retract all" data-collapsed-text="Expand all" aria-expanded="true" style="box-shadow: none;">
            Retract all
        </button>
    </div>
    @if (currentStep.HasValue)
    {
        @await Html.PartialAsync("_CreationProgress")
    }
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <span>Metadata</span>
            <button type="button" class="btn btn-sm btn-outline-light toggle-section" data-section-title="Metadata" data-expanded-symbol="−" data-collapsed-symbol="+" aria-expanded="true" aria-label="Collapse the Metadata section">−</button>
        </div>
        <div class="card-body">
            <p><strong>Description:</strong> @Model.Metadonnee.Description</p>
            <p><strong>License:</strong> @Model.Licence?.Libelle</p>
            <p><strong>Site:</strong> @Model.Site?.Nom</p>
            <p><strong>Visibility:</strong> @Model.Visibilite?.Libelle</p>
            <p><strong>Renewable energy type:</strong> @(Model.TypeEnergieRenouvelable?.Libelle ?? "—")</p>
            <p><strong>Creator:</strong> @Model.Utilisateur?.Nom @Model.Utilisateur?.Prenom (@Model.Utilisateur?.Email)</p>
            <p><strong>Data size:</strong> @(Model.Metadonnee?.TailleDesDonnees ?? "—")</p>
            <p><strong>Time series:</strong> @(Model.Metadonnee.SeriesTemporelles ? "Yes" : "No")</p>
            <p><strong>API allowed:</strong> @(Model.Metadonnee.AutoriserApi ? "Yes" : "No")</p>
            <p><strong>Anonymization:</strong> @(Model.Metadonnee.Anonymiser ? "Yes" : "No")</p>
            <p><strong>Downloads allowed:</strong> @(Model.Metadonnee.AutoriserLeTelechargement ? "Yes" : "No")</p>
            <p><strong>Last updated:</strong> @Model.Metadonnee.DernierMiseAJour?.ToString("g")</p>

            @if (Model.AppareilsLies != null && Model.AppareilsLies.Any())
            {
                <hr />
                <h5>Associated devices</h5>
                <ul>
                    @foreach (var app in Model.AppareilsLies)
                    {
                        <li>
                            @app.Appareil?.Nom (@app.Commentaire)
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    @if (Model.Donnees != null)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <span>Data</span>
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="btn btn-sm btn-outline-light toggle-section" data-section-title="Data" data-expanded-symbol="−" data-collapsed-symbol="+" aria-expanded="true" aria-label="Collapse the Data section">−</button>
                    @if (Model.Metadonnee?.AutoriserLeTelechargement == true && !string.IsNullOrWhiteSpace(Model.Donnees?.NomDeLaTable))
                    {
                        <button type="button"
                                class="btn btn-sm btn-outline-light download-table"
                                data-table-name="@Model.Donnees.NomDeLaTable"
                                data-download-parts='@System.Text.Json.JsonSerializer.Serialize(new[] { Model.Metadonnee.Nom, Model.Donnees?.Libelle, "data" })'
                                data-max-rows-per-part="1000000"
                                title="Download data as CSV (ZIP)"
                                aria-label="Download the Data table as a ZIP archive">
                            <span class="material-symbols-outlined" aria-hidden="true">download</span>
                            <span class="visually-hidden">Download data as ZIP</span>
                        </button>
                    }
                </div>
            </div>
            <div class="card-body">
                <p><strong>Label:</strong> @Model.Donnees.Libelle</p>
                <p><strong>Code:</strong> @Model.Donnees.Code</p>
                <p><strong>Table name:</strong> @Model.Donnees.NomDeLaTable</p>
                <p><strong>Description:</strong> @Model.Donnees.Description</p>
                <p><strong>Data quality:</strong> @(Model.Donnees.QualiteDonnees?.Libelle ?? "—")</p>
                @if (!string.IsNullOrWhiteSpace(Model.Donnees.QualiteDonnees?.Description))
                {
                    <p class="text-muted">@Model.Donnees.QualiteDonnees.Description</p>
                }
                <p><strong>Number of sensors:</strong> @Model.Donnees.NombreDeCapteurs</p>
                <p><strong>Collection frequency:</strong> @Model.Donnees.FrequenceDeCollect</p>
                <p><strong>Dates:</strong> @Model.Donnees.StartTimestamp.ToShortDateString() - @Model.Donnees.EndTimestamp.ToShortDateString()</p>

                @if (Model.DonneesPreviewRows?.Any() == true)
                {
                    <hr />
                    <h6>Data preview</h6>
                    <div class="table-responsive">
                        <table class="table table-striped table-sm">
                            <thead>
                                <tr>
                                    @foreach (var col in Model.DonneesPreviewRows.First().Keys)
                                    {
                                        <th>@col</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.DonneesPreviewRows)
                                {
                                    <tr>
                                        @foreach (var val in row.Values)
                                        {
                                            <td>@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.DonneesEventLogs != null)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-warning text-white d-flex justify-content-between align-items-center">
                <span>Event logs</span>
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="btn btn-sm btn-outline-light toggle-section" data-section-title="Event logs" data-expanded-symbol="−" data-collapsed-symbol="+" aria-expanded="true" aria-label="Collapse the event logs section">−</button>
                    @if (Model.Metadonnee?.AutoriserLeTelechargement == true && !string.IsNullOrWhiteSpace(Model.DonneesEventLogs?.NomDeLaTable))
                    {
                        <button type="button"
                                class="btn btn-sm btn-outline-light download-table"
                                data-table-name="@Model.DonneesEventLogs.NomDeLaTable"
                                data-download-parts='@System.Text.Json.JsonSerializer.Serialize(new[] { Model.Metadonnee.Nom, Model.DonneesEventLogs?.Libelle, "eventLogs" })'
                                data-max-rows-per-part="1000000"
                                title="Download event logs as CSV (ZIP)"
                                aria-label="Download the Event logs table as a ZIP archive">
                            <span class="material-symbols-outlined" aria-hidden="true">download</span>
                            <span class="visually-hidden">Download event logs as ZIP</span>
                        </button>
                    }
                </div>
            </div>
            <div class="card-body">
                <p><strong>Label:</strong> @Model.DonneesEventLogs.Libelle</p>
                <p><strong>Code:</strong> @Model.DonneesEventLogs.Code</p>
                <p><strong>Table name:</strong> @Model.DonneesEventLogs.NomDeLaTable</p>
                <p><strong>Description:</strong> @Model.DonneesEventLogs.Description</p>
                <p><strong>Data quality:</strong> @(Model.DonneesEventLogs.QualiteDonnees?.Libelle ?? "—")</p>
                @if (!string.IsNullOrWhiteSpace(Model.DonneesEventLogs.QualiteDonnees?.Description))
                {
                    <p class="text-muted">@Model.DonneesEventLogs.QualiteDonnees.Description</p>
                }
                <p><strong>Number of events:</strong> @Model.DonneesEventLogs.NombreDEvents</p>
                <p><strong>Dates:</strong> @Model.DonneesEventLogs.StartTimestamp.ToShortDateString() - @Model.DonneesEventLogs.EndTimestamp.ToShortDateString()</p>

                @if (Model.EventLogsPreviewRows?.Any() == true)
                {
                    <hr />
                    <h6>Event log preview</h6>
                    <div class="table-responsive">
                        <table class="table table-striped table-sm">
                            <thead>
                                <tr>
                                    @foreach (var col in Model.EventLogsPreviewRows.First().Keys)
                                    {
                                        <th>@col</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.EventLogsPreviewRows)
                                {
                                    <tr>
                                        @foreach (var val in row.Values)
                                        {
                                            <td>@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.DonneesContexteEnvironnemental != null)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <span>Environmental context</span>
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="btn btn-sm btn-outline-light toggle-section" data-section-title="Environmental context" data-expanded-symbol="−" data-collapsed-symbol="+" aria-expanded="true" aria-label="Collapse the environmental context section">−</button>
                    @if (Model.Metadonnee?.AutoriserLeTelechargement == true && !string.IsNullOrWhiteSpace(Model.DonneesContexteEnvironnemental?.NomDeLaTable))
                    {
                        <button type="button"
                                class="btn btn-sm btn-outline-light download-table"
                                data-table-name="@Model.DonneesContexteEnvironnemental.NomDeLaTable"
                                data-download-parts='@System.Text.Json.JsonSerializer.Serialize(new[] { Model.Metadonnee.Nom, Model.DonneesContexteEnvironnemental?.Libelle, "environment" })'
                                data-max-rows-per-part="1000000"
                                title="Download environmental context as CSV (ZIP)"
                                aria-label="Download the Environmental context table as a ZIP archive">
                            <span class="material-symbols-outlined" aria-hidden="true">download</span>
                            <span class="visually-hidden">Download environmental context as ZIP</span>
                        </button>
                    }
                </div>
            </div>
            <div class="card-body">
                <p><strong>Label:</strong> @Model.DonneesContexteEnvironnemental.Libelle</p>
                <p><strong>Code:</strong> @Model.DonneesContexteEnvironnemental.Code</p>
                <p><strong>Table name:</strong> @Model.DonneesContexteEnvironnemental.NomDeLaTable</p>
                <p><strong>Description:</strong> @Model.DonneesContexteEnvironnemental.Description</p>
                <p><strong>Data quality:</strong> @(Model.DonneesContexteEnvironnemental.QualiteDonnees?.Libelle ?? "—")</p>
                @if (!string.IsNullOrWhiteSpace(Model.DonneesContexteEnvironnemental.QualiteDonnees?.Description))
                {
                    <p class="text-muted">@Model.DonneesContexteEnvironnemental.QualiteDonnees.Description</p>
                }
                <p><strong>Dates:</strong> @Model.DonneesContexteEnvironnemental.StartTimestamp.ToShortDateString() - @Model.DonneesContexteEnvironnemental.EndTimestamp.ToShortDateString()</p>

                @if (Model.ContextePreviewRows?.Any() == true)
                {
                    <hr />
                    <h6>Environmental context preview</h6>
                    <div class="table-responsive">
                        <table class="table table-striped table-sm">
                            <thead>
                                <tr>
                                    @foreach (var col in Model.ContextePreviewRows.First().Keys)
                                    {
                                        <th>@col</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.ContextePreviewRows)
                                {
                                    <tr>
                                        @foreach (var val in row.Values)
                                        {
                                            <td>@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    <div class="text-center mt-4">
        <a href="@Url.Action("RechercheDonnees", "AccesDonnees")" class="btn btn-outline-primary">
            All data
        </a>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const sectionButtons = Array.from(document.querySelectorAll('.card-header .toggle-section'));
            const toggleAllButton = document.querySelector('.toggle-all-sections');

            const getCardBody = (button) => {
                const cardHeader = button.closest('.card-header');
                return cardHeader ? cardHeader.nextElementSibling : null;
            };

            const isSectionCollapsed = (button) => {
                const cardBody = getCardBody(button);
                return cardBody ? cardBody.classList.contains('d-none') : false;
            };

            const setSectionState = (button, collapsed) => {
                const cardBody = getCardBody(button);
                if (!cardBody) {
                    return;
                }

                cardBody.classList.toggle('d-none', collapsed);

                const expandedSymbol = button.dataset.expandedSymbol || '−';
                const collapsedSymbol = button.dataset.collapsedSymbol || '+';
                const sectionTitle = button.dataset.sectionTitle || '';
                const actionLabel = collapsed ? 'Expand' : 'Collapse';

                button.textContent = collapsed ? collapsedSymbol : expandedSymbol;
                button.setAttribute('aria-expanded', (!collapsed).toString());
                button.setAttribute('aria-label', sectionTitle
                    ? `${actionLabel} the ${sectionTitle} section`
                    : `${actionLabel} the section`);
            };

            const updateToggleAllState = () => {
                if (!toggleAllButton) {
                    return;
                }

                if (sectionButtons.length === 0) {
                    toggleAllButton.classList.add('d-none');
                    return;
                }

                const collapsedText = toggleAllButton.dataset.collapsedText || 'Expand all';
                const expandedText = toggleAllButton.dataset.expandedText || 'Retract all';
                const anyExpanded = sectionButtons.some((button) => !isSectionCollapsed(button));

                toggleAllButton.textContent = anyExpanded ? expandedText : collapsedText;
                toggleAllButton.setAttribute('aria-expanded', anyExpanded.toString());
            };

            sectionButtons.forEach((button) => {
                setSectionState(button, isSectionCollapsed(button));

                button.addEventListener('click', () => {
                    const currentlyCollapsed = isSectionCollapsed(button);
                    setSectionState(button, !currentlyCollapsed);
                    updateToggleAllState();
                });
            });

            if (toggleAllButton && sectionButtons.length > 0) {
                updateToggleAllState();

                toggleAllButton.addEventListener('click', () => {
                    const collapseAll = toggleAllButton.getAttribute('aria-expanded') === 'true';
                    sectionButtons.forEach((button) => setSectionState(button, collapseAll));
                    updateToggleAllState();
                });
            } else if (toggleAllButton) {
                toggleAllButton.classList.add('d-none');
            }

            const downloadButtons = Array.from(document.querySelectorAll('.download-table'));

            const parseDownloadParts = (rawParts) => {
                if (!rawParts) {
                    return [];
                }

                try {
                    const parsed = JSON.parse(rawParts);
                    if (Array.isArray(parsed)) {
                        return parsed;
                    }
                } catch (_err) {
                    // Fallback to delimiter-based parsing for legacy data attributes.
                }

                return rawParts.split('|');
            };

            const buildDownloadName = (rawParts) => {
                const parts = parseDownloadParts(rawParts);
                if (!parts || parts.length === 0) {
                    return 'dataset';
                }

                const seen = new Set();
                const normalized = [];

                parts.forEach((part) => {
                    const trimmed = (part ?? '').toString().trim();
                    if (!trimmed) {
                        return;
                    }

                    const key = trimmed.toLowerCase();
                    if (seen.has(key)) {
                        return;
                    }

                    seen.add(key);
                    normalized.push(trimmed);
                });

                return normalized.length > 0 ? normalized.join('_') : 'dataset';
            };

            const sanitizeFileName = (name) => {
                if (!name) {
                    return 'dataset';
                }

                const invalidChars = /[\\/:*?"<>|]+/g;
                const sanitized = name.replace(invalidChars, '_').trim();
                if (!sanitized) {
                    return 'dataset';
                }

                return sanitized.length > 120 ? sanitized.slice(0, 120) : sanitized;
            };

            downloadButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    const tableName = button.dataset.tableName;
                    if (!tableName) {
                        return;
                    }

                    const fileBase = sanitizeFileName(buildDownloadName(button.dataset.downloadParts || tableName));
                    const maxRows = button.dataset.maxRowsPerPart || '1000000';
                    const url = `/api/exports/table/${encodeURIComponent(tableName)}/zip?maxRowsPerPart=${encodeURIComponent(maxRows)}`;

                    button.disabled = true;
                    button.setAttribute('aria-busy', 'true');

                    const anchor = document.createElement('a');
                    anchor.href = url;
                    anchor.rel = 'noopener';
                    anchor.style.display = 'none';
                    anchor.download = `${fileBase}.zip`;
                    document.body.appendChild(anchor);
                    anchor.click();

                    window.setTimeout(() => {
                        anchor.remove();
                    }, 0);

                    window.setTimeout(() => {
                        button.disabled = false;
                        button.removeAttribute('aria-busy');
                    }, 1500);
                });
            });
        });
    </script>
}
