<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Data Portal</title>
    <link rel="icon" type="image/x-icon" href="~/logo/ets-header-logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/customBootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Dataportal.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css">
</head>
<body class="@(ViewData["DisableScroll"] != null && (bool)ViewData["DisableScroll"] ? "no-scroll mb-0" : "")">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light sticky-top">
            <div class="container ml-3">
                <a class="navbar-brand" asp-area="" asp-controller="Accueil" asp-action="Index">
                    <img src="~/logo/ets-header-logo.png" alt="Data Portal" style="height: 50px;" />
                    <span style="color: #e72b37; font-weight: bold; margin-left: 10px;">Data Portal</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Accueil" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="AccesDonnees" asp-action="RechercheDonnees">Data</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Files" asp-action="Index">Files</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Accueil" asp-action="NotebookApi">Notebook API</a>
                        </li>
                        @if (User.Identity.IsAuthenticated && (User.IsInRole("administrator") || User.IsInRole("editor")))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/jupyter/launch" target="_blank" rel="noopener">JupyterHub</a>
                            </li>
                        }
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("administrator") || User.IsInRole("editor"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="controleDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Control</a>
                                    <ul class="dropdown-menu" aria-labelledby="controleDropdown">
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Controle" asp-action="Sites">
                                                Sites
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Controle" asp-action="Appareils">
                                                Devices
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Controle" asp-action="Licences">
                                                Licenses
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole("administrator") || User.IsInRole("editor"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="gestionDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Management</a>
                                    <ul class="dropdown-menu" aria-labelledby="gestionDropdown">
                                        @if (User.IsInRole("administrator"))
                                        {
                                            <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Gestion" asp-action="DemandeDeCompte">
                                                Account Requests
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" asp-area="" asp-controller="Gestion" asp-action="MessageAccueil">
                                                    Home message
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" asp-area="" asp-controller="Gestion" asp-action="NotebookApiAccessLogs">
                                                    API access logs
                                                </a>
                                            </li>
                                        }
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Gestion" asp-action="Utilisateurs">
                                                Users
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Gestion" asp-action="Entreprises">
                                                Organizations
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Gestion" asp-action="Indexation">
                                                Indexation
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person me-1"></i>Profile
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="profileDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Compte" asp-action="Profil">
                                            Settings
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Compte" asp-action="ChangerMotDePasse">
                                            Change password
                                        </a>
                                    </li>
                                    <li>
                                        <form asp-area="" asp-controller="Compte" asp-action="SeDeconnecter" method="post" id="logoutForm">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">Sign out</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Compte" asp-action="SeConnecter">Sign in</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div>
        <main role="main" class="@(ViewData["DisableScroll"] != null && (bool)ViewData["DisableScroll"] ? "" : "pb-3")">
            @RenderBody()
        </main>
    </div>
    @if (ViewData["HideFooter"] == null || !(bool)ViewData["HideFooter"])
    {
        <footer class="footer border-top" role="contentinfo">
            <div class="container py-4">
                <div class="row text-center text-md-start">
                    <div class="col-md-3 mb-3 text-center">
                        <div class="mb-3">
                            <a href="https://www.etsmtl.ca/" target="_blank">
                                <img src="~/logo/ets-logo.png" alt="ETS Logo" class="img-fluid footer-logo">
                            </a>
                        </div>
                    </div>
                    <div class="col-md-1 mb-3">
                    </div>
                    <div class="col-md-4 mb-3 text-center">
                        <div class="mb-3">
                            <a href="https://www.hydroquebec.com/" target="_blank">
                                <img src="~/logo/hq-footer-logo.png" alt="HQ Footer Logo" class="img-fluid footer-logo ms-1">
                            </a>
                        </div>
                        <div class="mb-3">
                            <a href="https://www.powerfactors.com/" target="_blank">
                                <img src="~/logo/pf-footer-logo.png" alt="PF Footer Logo" class="img-fluid footer-logo ms-1">
                            </a>
                        </div>
                        <div class="mb-3">
                            <a href="https://www.mitacs.ca/" target="_blank">
                                <img src="~/logo/Mitacs_logo.png" alt="Mitacs Footer Logo" class="img-fluid footer-logo ms-1" />
                            </a>
                        </div>
                    </div>
                    <div class="col-md-1 mb-3">
                    </div>
                    <div class="col-md-2 mb-3">
                        <nav aria-label="Main navigation">
                            <ul class="list-unstyled">
                                <li><a class="footer-links" asp-area="" asp-controller="Accueil" asp-action="Index">Home</a></li>
                                <li><a class="footer-links" asp-area="" asp-controller="AccesDonnees" asp-action="RechercheDonnees">Data</a></li>
                                <li><a class="footer-links" asp-area="" asp-controller="Documentation" asp-action="Index">Documentation</a></li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
            <div class="container-fluid bg-light">
                <div class="row">
                    <div class="col text-end py-2 text-muted">
                        &copy; 2025 - All rights reserved.
                    </div>
                </div>
            </div>
        </footer>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
