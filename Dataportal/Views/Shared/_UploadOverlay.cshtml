<div id="upload-overlay" class="upload-overlay d-none" aria-hidden="true">
    <div class="upload-overlay__backdrop"></div>
    <div class="upload-overlay__content" role="alert" aria-live="assertive">
        <div class="upload-overlay__animation" data-upload-overlay-animation aria-hidden="true"></div>
        <h3 class="upload-overlay__title">Upload in progress</h3>
        <p class="upload-overlay__message">Please do not interrupt your connection; the upload is in progress.</p>
        <p class="upload-overlay__status" data-upload-overlay-status>Preparing upload…</p>
    </div>
</div>

<div id="upload-confirmation" class="upload-confirmation d-none" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="upload-confirmation-title">
    <div class="upload-confirmation__backdrop"></div>
    <div class="upload-confirmation__content">
        <h3 id="upload-confirmation-title" class="upload-confirmation__title">Confirm upload</h3>
        <p class="upload-confirmation__message" data-upload-confirmation-message>Once this step is confirmed, the data will be created. Do you want to continue?</p>
        <div class="upload-confirmation__actions">
            <button type="button" class="btn btn-outline-secondary" data-upload-confirmation-cancel>Cancel</button>
            <button type="button" class="btn btn-primary" data-upload-confirmation-confirm>Continue</button>
        </div>
    </div>
</div>
