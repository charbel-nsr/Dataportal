<div id="upload-overlay" class="upload-overlay d-none" aria-hidden="true">
    <div class="upload-overlay__backdrop"></div>
    <div class="upload-overlay__content" role="alert" aria-live="assertive">
        <div class="upload-overlay__animation" data-upload-overlay-animation aria-hidden="true"></div>
        <h3 class="upload-overlay__title">Téléversement en cours</h3>
        <p class="upload-overlay__message">Veuillez ne pas interrompre la connexion&nbsp;; le téléversement est en cours.</p>
        <p class="upload-overlay__status" data-upload-overlay-status>Préparation du téléversement…</p>
    </div>
</div>

<div id="upload-confirmation" class="upload-confirmation d-none" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="upload-confirmation-title">
    <div class="upload-confirmation__backdrop"></div>
    <div class="upload-confirmation__content">
        <h3 id="upload-confirmation-title" class="upload-confirmation__title">Confirmer l'importation</h3>
        <p class="upload-confirmation__message" data-upload-confirmation-message>Une fois cette étape validée, les données seront créées temporairement. Souhaitez-vous continuer&nbsp;?</p>
        <div class="upload-confirmation__actions">
            <button type="button" class="btn btn-outline-secondary" data-upload-confirmation-cancel>Annuler</button>
            <button type="button" class="btn btn-primary" data-upload-confirmation-confirm>Continuer</button>
        </div>
    </div>
</div>
