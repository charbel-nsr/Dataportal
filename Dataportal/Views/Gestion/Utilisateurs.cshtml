@model Dataportal.ViewModels.UtilisateursAdminViewModel
@{
    ViewData["Title"] = "User management";
}

<div class="container">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="row bg-light rounded shadow p-4 mb-4">
        <form method="get" class="row g-3">
            <div class="col-md-8 mt-2">
                <div class="form-floating">
                    <input type="text" class="form-control" name="search" id="search" placeholder="Search" value="@Model.Search">
                    <label for="search">Name, first name, or email</label>
                </div>
            </div>
            <div class="col-md-4 mt-2">
                <div class="form-floating">
                    <select class="form-select" name="selectedEntrepriseId" id="selectedEntrepriseId">
                        <option value="">All organizations</option>
                        @foreach (var e in Model.Entreprises)
                        {
                            <option value="@e.Id" selected="@(e.Id == Model.SelectedEntrepriseId ? "selected" : null)">@e.Nom</option>
                        }
                    </select>
                    <label for="selectedEntrepriseId">Organization</label>
                </div>
            </div>
            <div class="col-md-4 mt-2">
                <div class="form-floating">
                    <select class="form-select" name="selectedRoleId" id="selectedRoleId">
                        <option value="">All roles</option>
                        @foreach (var r in Model.Roles)
                        {
                            <option value="@r.Id" selected="@(r.Id == Model.SelectedRoleId ? "selected" : null)">@r.Libelle</option>
                        }
                    </select>
                    <label for="selectedRoleId">Role</label>
                </div>
            </div>
            <div class="col-md-4 mt-2">
                <div class="form-floating">
                    <select class="form-select" name="compteActif" id="compteActif">
                        <option value="">All</option>
                        <option value="true" selected="@(Model.CompteActif == true ? "selected" : null)">Active</option>
                        <option value="false" selected="@(Model.CompteActif == false ? "selected" : null)">Inactive</option>
                    </select>
                    <label for="compteActif">Account status</label>
                </div>
            </div>
            <div class="col-md-4 mt-2">
                <div class="row g-2">
                    <div class="col-6">
                        <button type="submit" class="btn btn-primary w-100">Filter</button>
                    </div>
                    <div class="col-6">
                        <a href="@Url.Action("Utilisateurs", "Gestion")" class="btn btn-outline-primary w-100">Reset</a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    @if (Model.Utilisateurs != null && Model.Utilisateurs.Any()){
        <div class="container">
            <div class="paginated-table-wrapper" data-page-size="20">
                <div class="table-responsive">
                    <table class="table table-hover shadow-sm paginated-table">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Name
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        First name
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Email
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="boolean">
                                    <button type="button" class="table-sort-button">
                                        Status
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Organization
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Role
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var u in Model.Utilisateurs)
                        {
                            var organizationDisplay = string.IsNullOrWhiteSpace(u.Entreprise?.Nom) ? "—" : u.Entreprise.Nom;
                            var roleDisplay = string.IsNullOrWhiteSpace(u.Role?.Libelle) ? "—" : u.Role.Libelle;
                            <tr>
                                <td data-sort-value="@u.Nom">@u.Nom</td>
                                <td data-sort-value="@u.Prenom">@u.Prenom</td>
                                <td data-sort-value="@u.Email">@u.Email</td>
                                <td data-sort-value="@(u.CompteActif ? 1 : 0)">
                                    @if (u.CompteActif)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td data-sort-value="@organizationDisplay">@organizationDisplay</td>
                                <td data-sort-value="@roleDisplay">@roleDisplay</td>
                                <td>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#userDetailsModal"
                                            data-id="@u.Id"
                                            data-nom="@u.Nom"
                                            data-prenom="@u.Prenom"
                                            data-email="@u.Email"
                                            data-actif="@u.CompteActif"
                                            data-entreprise="@u.Entreprise?.Nom"
                                            data-role="@u.Role?.Libelle"
                                            data-login="@u.DernierLogin?.ToString("g")"
                                            data-description="@u.DescriptionProfil"
                                            data-linkedin="@u.LienLinkedIn">
                                        <i class="bi bi-exclamation-circle"></i>
                                    </button>
                                    @if (User.IsInRole("administrator"))
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editRoleModal"
                                                data-id="@u.Id"
                                                data-roleid="@u.IdRole"
                                                data-nom="@u.Nom"
                                                data-prenom="@u.Prenom">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <div class="table-pagination-controls d-flex justify-content-end align-items-center gap-2 mt-3 d-none">
                    <button type="button" class="table-pagination-button table-pagination-prev" aria-label="Previous page" disabled>
                        <span class="material-symbols-outlined">
                            arrow_circle_left
                        </span>
                    </button>
                    <div class="d-flex align-items-center gap-1">
                        <input type="number" class="form-control table-pagination-input" value="1" min="1" />
                        <span>/</span>
                        <span class="table-pagination-total">1</span>
                    </div>
                    <button type="button" class="table-pagination-button table-pagination-next" aria-label="Next page" disabled>
                        <span class="material-symbols-outlined">
                            arrow_circle_right
                        </span>
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center">
            <img src="/illustration/empty-search.svg" alt="No data found" class="img-fluid" style="max-height:200px;" />
            <p class="text-muted mt-2">No data found.</p>
        </div>
    }
</div>

<div class="modal fade" id="userDetailsModal" tabindex="-1" aria-labelledby="userDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userDetailsModalLabel">User details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong>Name:</strong> <span id="detailNom"></span></p>
                <p><strong>First name:</strong> <span id="detailPrenom"></span></p>
                <p><strong>Email:</strong> <span id="detailEmail"></span></p>
                <p><strong>Status:</strong> <span id="detailActif"></span></p>
                <p><strong>Organization:</strong> <span id="detailEntreprise"></span></p>
                <p><strong>Role:</strong> <span id="detailRole"></span></p>
                <p><strong>Last login:</strong> <span id="detailLogin"></span></p>
                <p><strong>Description:</strong> <span id="detailDescription"></span></p>
                <p><strong>LinkedIn:</strong> <a id="detailLinkedIn" href="#" target="_blank"></a></p>
                @if (User.IsInRole("administrator"))
                {
                    <div id="confirmWarning" class="alert alert-danger d-none mt-3"></div>
                }
            </div>
            <div class="modal-footer">
                @if (User.IsInRole("administrator"))
                {
                    <form id="toggleActifForm" method="post" asp-action="ToggleUtilisateurActif" class="d-flex gap-2 align-items-center m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="toggleUserId" value="" />
                        <button type="button" id="toggleActifButton" class="btn btn-primary">
                            <span id="toggleActifButtonText"></span>
                        </button>
                    </form>
                }
                <button type="button" class="btn btn-outline-primary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@if (User.IsInRole("administrator"))
{
    <div class="modal fade" id="editRoleModal" tabindex="-1" aria-labelledby="editRoleModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="EditUserRole">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editRoleUserId" name="id" value="" />
                    <div class="modal-header">
                        <h5 class="modal-title" id="editRoleModalLabel">Edit role</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p><strong>User:</strong> <span id="editRoleUserName"></span></p>
                        <div class="form-floating">
                            <select class="form-select" id="editRoleSelect" name="newRoleId" required>
                                <option value="">Select a role</option>
                                @foreach (var role in Model.Roles)
                                {
                                    <option value="@role.Id">@role.Libelle</option>
                                }
                            </select>
                            <label for="editRoleSelect">New role</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<script>
    document.addEventListener('DOMContentLoaded', () => {
        let confirming = false;
        let currentIsActive = true;

        const userDetailsModal = document.getElementById('userDetailsModal');
        const toggleActifForm = document.getElementById('toggleActifForm');
        const toggleUserIdInput = document.getElementById('toggleUserId');
        const toggleActifButton = document.getElementById('toggleActifButton');
        const toggleActifButtonText = document.getElementById('toggleActifButtonText');
        const confirmWarning = document.getElementById('confirmWarning');

        userDetailsModal.addEventListener('show.bs.modal', event => {
            confirming = false;
            if (confirmWarning) {
                confirmWarning.classList.add('d-none');
                confirmWarning.textContent = '';
            }

            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            const nom = button.getAttribute('data-nom');
            const prenom = button.getAttribute('data-prenom');
            const email = button.getAttribute('data-email');
            const actif = button.getAttribute('data-actif') === 'True';
            currentIsActive = actif;
            const entreprise = button.getAttribute('data-entreprise');
            const role = button.getAttribute('data-role');
            const login = button.getAttribute('data-login') || 'Never';
            const description = button.getAttribute('data-description') || '—';
            const linkedin = button.getAttribute('data-linkedin');

            document.getElementById('detailNom').textContent = nom;
            document.getElementById('detailPrenom').textContent = prenom;
            document.getElementById('detailEmail').textContent = email;
            document.getElementById('detailActif').textContent = actif ? 'Active' : 'Inactive';
            document.getElementById('detailEntreprise').textContent = entreprise;
            document.getElementById('detailRole').textContent = role;
            document.getElementById('detailLogin').textContent = login;
            document.getElementById('detailDescription').textContent = description;
            const linkedinLink = document.getElementById('detailLinkedIn');
            if (linkedin) {
                linkedinLink.href = linkedin;
                linkedinLink.textContent = linkedin;
            } else {
                linkedinLink.href = '#';
                linkedinLink.textContent = '—';
            }

            if (toggleUserIdInput) {
                toggleUserIdInput.value = id;
            }

            if (toggleActifForm && toggleActifButton && toggleActifButtonText) {
                if (role && role.toLowerCase() === 'administrator') {
                    // Hide activation controls for administrators
                    toggleActifForm.classList.add('d-none');
                } else {
                    toggleActifForm.classList.remove('d-none');
                    // Setup initial button text
                    if (actif) {
                        toggleActifButtonText.textContent = 'Deactivate this profile';
                        toggleActifButton.classList.remove('btn-success');
                        toggleActifButton.classList.add('btn-warning');
                    } else {
                        toggleActifButtonText.textContent = 'Activate this profile';
                        toggleActifButton.classList.remove('btn-warning');
                        toggleActifButton.classList.add('btn-success');
                    }
                }
            }
        });

        if (toggleActifButton) {
            toggleActifButton.addEventListener('click', () => {
                if (!confirming) {
                    // First click: show confirmation
                    confirming = true;
                    if (confirmWarning) {
                        confirmWarning.classList.remove('d-none');
                        if (currentIsActive) {
                            confirmWarning.innerHTML = "Are you sure you want to <strong>deactivate</strong> this profile? The user will be <strong>signed out immediately</strong> and notified by email.";
                            toggleActifButtonText.textContent = 'Confirm deactivation';
                            toggleActifButton.classList.remove('btn-warning');
                            toggleActifButton.classList.add('btn-danger');
                        } else {
                            confirmWarning.textContent = "Are you sure you want to activate this profile?";
                            toggleActifButtonText.textContent = 'Confirm activation';
                            toggleActifButton.classList.remove('btn-success');
                            toggleActifButton.classList.add('btn-primary');
                        }
                    }
                } else {
                    // Second click: submit form
                    if (toggleActifForm) toggleActifForm.submit();
                }
            });
        }
    });

    const editRoleModal = document.getElementById('editRoleModal');
    if (editRoleModal) {
        editRoleModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const userId = button.getAttribute('data-id');
            const userNom = button.getAttribute('data-nom');
            const userPrenom = button.getAttribute('data-prenom');
            const currentRoleId = button.getAttribute('data-roleid');

            document.getElementById('editRoleUserId').value = userId;
            document.getElementById('editRoleUserName').textContent = userPrenom + ' ' + userNom;
            document.getElementById('editRoleSelect').value = currentRoleId;
        });
    }

</script>

