@model Dataportal.ViewModels.EntrepriseViewModel
@{
    ViewData["Title"] = "Gestion des entreprises";
}

<div class="container">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row bg-light rounded shadow p-4 mb-4">
        <form method="get" class="row gx-3 gy-2 align-items-center">
            <div class="col-md-6">
                <div class="form-floating">
                    <input type="text" class="form-control" id="search" name="search" placeholder="Nom" value="@Model.Search">
                    <label for="search">Nom</label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating">
                    <select class="form-select" name="actif" id="actif">
                        <option value="">Tous</option>
                        <option value="true" selected="@(Model.Actif == true ? "selected" : null)">Actifs</option>
                        <option value="false" selected="@(Model.Actif == false ? "selected" : null)">Inactifs</option>
                    </select>
                    <label for="actif">Statut actif</label>
                </div>
            </div>
            <div class="col-md-6 offset-md-6 mt-2 d-flex flex-column flex-md-row">
                <button type="submit" class="btn btn-primary flex-grow-1 w-100 mb-2 mb-md-0 me-md-2">
                    Filtrer
                </button>
                <a href="@Url.Action("Entreprises", "Gestion")" class="btn btn-outline-primary flex-grow-1 w-100">
                    Réinitialiser
                </a>
            </div>
        </form>
    </div>
    <div class="col-12 col-md-auto mb-3">
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="bi bi-plus-circle"></i> Créer une entreprise
        </button>
    </div>

    <div class="row">
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm">
                <thead class="table-light">
                    <tr>
                        <th>Nom</th>
                        <th>Actif</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entreprise in Model.Entreprises)
                    {
                        <tr>
                            <td>@entreprise.Nom</td>
                            <td>
                                @if (entreprise.Actif)
                                {
                                    <span class="badge bg-success">Actif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactif</span>
                                }
                            </td>
                            <td>
                                @if (!entreprise.Actif)
                                {
                                    <button class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#activateModal" data-id="@entreprise.Id" data-nom="@entreprise.Nom" title="Activer">
                                        <i class="bi bi-check-circle"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#deactivateModal" data-id="@entreprise.Id" data-nom="@entreprise.Nom" title="Désactiver">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal"
                                        data-id="@entreprise.Id"
                                        data-nom="@entreprise.Nom"
                                        title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#domainesModal"
                                        data-id="@entreprise.Id"
                                        data-nom="@entreprise.Nom"
                                        title="Gérer les domaines">
                                    <i class="bi bi-envelope"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-primary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editEntrepriseModal"
                                        data-id="@entreprise.Id"
                                        data-nom="@entreprise.Nom"
                                        data-actif="@entreprise.Actif"
                                        title="Éditer">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Domaines Modal Placeholder -->
<div class="modal fade" id="domainesModal" tabindex="-1" aria-labelledby="domainesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="domainesModalContent">
            <!-- Loaded via AJAX -->
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="CreateEntreprise">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createModalLabel">Créer une entreprise</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="Nom" name="Nom" placeholder="Nom" required>
                        <label for="Nom">Nom de l'entreprise</label>
                    </div>
                    <div class="form-floating mb-3">
                        <select class="form-select" id="Actif" name="Actif" required>
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                        <label for="Actif">Statut de l'entreprise</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-success">Créer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Activate Modal -->
<div class="modal fade" id="activateModal" tabindex="-1" aria-labelledby="activateModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="ActivateEntreprise">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="activateModalLabel">Confirmer l'activation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="activate-id" name="id" />
                    <p>Êtes-vous sûr de vouloir activer l'entreprise <strong id="activate-nom"></strong> ?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-success">Activer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Deactivate Modal -->
<div class="modal fade" id="deactivateModal" tabindex="-1" aria-labelledby="deactivateModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="DeactivateEntreprise">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="deactivateModalLabel">Confirmer la désactivation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="deactivate-id" name="id" />
                    <p>Êtes-vous sûr de vouloir désactiver l'entreprise <strong id="deactivate-nom"></strong> ?<br/>
                    Cela empêchera la création de nouveaux utilisateurs dans cette entreprise.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-warning">Désactiver</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="DeleteEntreprise">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Confirmer la suppression</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="delete-id" name="id" />
                    <p>Êtes-vous sûr de vouloir supprimer l'entreprise <strong id="delete-nom"></strong> ?</p>
                    <p class="text-danger">Cette action est définitive et ne peut se faire que si aucune demande ou utilisateur n'y est associé.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-danger">Supprimer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editEntrepriseModal" tabindex="-1" aria-labelledby="editEntrepriseModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="EditEntreprise">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editEntrepriseId" name="id" />
                <div class="modal-header">
                    <h5 class="modal-title" id="editEntrepriseModalLabel">Modifier l'entreprise</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="editEntrepriseNom" name="Nom" placeholder="Nom" required>
                        <label for="editEntrepriseNom">Nom de l'entreprise</label>
                    </div>
                    <div class="form-floating mb-3">
                        <select class="form-select" id="editEntrepriseActif" name="Actif" required>
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                        <label for="editEntrepriseActif">Statut de l'entreprise</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-success">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const activateModal = document.getElementById('activateModal');
        activateModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            const nom = button.getAttribute('data-nom');
            document.getElementById('activate-id').value = id;
            document.getElementById('activate-nom').textContent = nom;
        });

        const deactivateModal = document.getElementById('deactivateModal');
        deactivateModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            const nom = button.getAttribute('data-nom');
            document.getElementById('deactivate-id').value = id;
            document.getElementById('deactivate-nom').textContent = nom;
        });

        const deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            const nom = button.getAttribute('data-nom');
            document.getElementById('delete-id').value = id;
            document.getElementById('delete-nom').textContent = nom;
        });

        document.addEventListener('DOMContentLoaded', () => {
            const domainesModal = document.getElementById('domainesModal');
            domainesModal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                const entrepriseId = button.getAttribute('data-id');
                fetch(`/Gestion/GetDomaines?id=${entrepriseId}`)
                    .then(response => response.text())
                    .then(html => {
                        document.getElementById('domainesModalContent').innerHTML = html;
                    });
            });
        });

        const editEntrepriseModal = document.getElementById('editEntrepriseModal');
        editEntrepriseModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            const nom = button.getAttribute('data-nom');
            const actif = button.getAttribute('data-actif') === 'True';

            document.getElementById('editEntrepriseId').value = id;
            document.getElementById('editEntrepriseNom').value = nom;
            document.getElementById('editEntrepriseActif').value = actif ? 'true' : 'false';
        });

    </script>
}
