@model Dataportal.ViewModels.EntrepriseViewModel
@{
    ViewData["Title"] = "Company management";
}

<div class="container">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row bg-light rounded shadow p-4 mb-4">
        <form method="get" class="row gx-3 gy-2 align-items-center">
            <div class="col-md-6">
                <div class="form-floating">
                    <input type="text" class="form-control" id="search" name="search" placeholder="Name" value="@Model.Search">
                    <label for="search">Name</label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating">
                    <select class="form-select" name="actif" id="actif">
                        <option value="">All</option>
                        <option value="true" selected="@(Model.Actif == true ? "selected" : null)">Active</option>
                        <option value="false" selected="@(Model.Actif == false ? "selected" : null)">Inactive</option>
                    </select>
                    <label for="actif">Active status</label>
                </div>
            </div>
            <div class="col-md-6 offset-md-6 mt-2 d-flex flex-column flex-md-row">
                <button type="submit" class="btn btn-primary flex-grow-1 w-100 mb-2 mb-md-0 me-md-2">
                    Filter
                </button>
                <a href="@Url.Action("Entreprises", "Gestion")" class="btn btn-outline-primary flex-grow-1 w-100">
                    Reset
                </a>
            </div>
        </form>
    </div>
    @if (User.IsInRole("administrator"))
    {
        <div class="col-12 col-md-auto mb-3">
            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createModal">
                <i class="bi bi-plus-circle"></i> Create a company
            </button>
        </div>
    }

    @if (Model.Entreprises != null && Model.Entreprises.Any()){
        <div class="row">
            <div class="paginated-table-wrapper" data-page-size="20">
                <div class="table-responsive">
                    <table class="table table-hover align-middle shadow-sm paginated-table">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Name
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="boolean">
                                    <button type="button" class="table-sort-button">
                                        Active
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var entreprise in Model.Entreprises)
                        {
                            <tr>
                                <td data-sort-value="@entreprise.Nom">@entreprise.Nom</td>
                                <td data-sort-value="@(entreprise.Actif ? 1 : 0)">
                                    @if (entreprise.Actif)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (User.IsInRole("administrator"))
                                    {
                                        if (!entreprise.Actif)
                                        {
                                            <button class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#activateModal" data-id="@entreprise.Id" data-nom="@entreprise.Nom" title="Activate">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#deactivateModal" data-id="@entreprise.Id" data-nom="@entreprise.Nom" title="Deactivate">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@entreprise.Id"
                                                data-nom="@entreprise.Nom"
                                                title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#domainesModal"
                                            data-id="@entreprise.Id"
                                            data-nom="@entreprise.Nom"
                                            title="Manage domains">
                                        <i class="bi bi-envelope"></i>
                                    </button>
                                    @if (User.IsInRole("administrator"))
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editEntrepriseModal"
                                                data-id="@entreprise.Id"
                                                data-nom="@entreprise.Nom"
                                                data-actif="@entreprise.Actif"
                                                title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <div class="table-pagination-controls d-flex justify-content-end align-items-center gap-2 mt-3 d-none">
                    <button type="button" class="table-pagination-button table-pagination-prev" aria-label="Previous page" disabled>
                        <span class="material-symbols-outlined">
                            arrow_circle_left
                        </span>
                    </button>
                    <div class="d-flex align-items-center gap-1">
                        <input type="number" class="form-control table-pagination-input" value="1" min="1" />
                        <span>/</span>
                        <span class="table-pagination-total">1</span>
                    </div>
                    <button type="button" class="table-pagination-button table-pagination-next" aria-label="Next page" disabled>
                        <span class="material-symbols-outlined">
                            arrow_circle_right
                        </span>
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center">
            <img src="/illustration/empty-search.svg" alt="No data found" class="img-fluid" style="max-height:200px;" />
            <p class="text-muted mt-2">No data found.</p>
        </div>
    }
</div>

<!-- Domaines Modal Placeholder -->
<div class="modal fade" id="domainesModal" tabindex="-1" aria-labelledby="domainesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="domainesModalContent">
            <!-- Loaded via AJAX -->
        </div>
    </div>
</div>

@if (User.IsInRole("administrator"))
{
    <!-- Create Modal -->
    <div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="CreateEntreprise">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title" id="createModalLabel">Create a company</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" id="Nom" name="Nom" placeholder="Name" required>
                            <label for="Nom">Company name</label>
                        </div>
                        <div class="form-floating mb-3">
                            <select class="form-select" id="Actif" name="Actif" required>
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                            <label for="Actif">Company status</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Activate Modal -->
    <div class="modal fade" id="activateModal" tabindex="-1" aria-labelledby="activateModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="ActivateEntreprise">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title" id="activateModalLabel">Confirm activation</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="activate-id" name="id" />
                        <p>Are you sure you want to activate the company <strong id="activate-nom"></strong>?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Activate</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Deactivate Modal -->
    <div class="modal fade" id="deactivateModal" tabindex="-1" aria-labelledby="deactivateModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="DeactivateEntreprise">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title" id="deactivateModalLabel">Confirm deactivation</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="deactivate-id" name="id" />
                        <p>Are you sure you want to deactivate the company <strong id="deactivate-nom"></strong>?<br/>
                        This will prevent creating new users in this company.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning">Deactivate</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="DeleteEntreprise">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title" id="deleteModalLabel">Confirm deletion</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="delete-id" name="id" />
                        <p>Are you sure you want to delete the company <strong id="delete-nom"></strong>?</p>
                        <p class="text-danger">This action is permanent and only possible if no request or user is associated with it.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editEntrepriseModal" tabindex="-1" aria-labelledby="editEntrepriseModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="EditEntreprise">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editEntrepriseId" name="id" />
                    <div class="modal-header">
                        <h5 class="modal-title" id="editEntrepriseModalLabel">Edit company</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" id="editEntrepriseNom" name="Nom" placeholder="Name" required>
                            <label for="editEntrepriseNom">Company name</label>
                        </div>
                        <div class="form-floating mb-3">
                            <select class="form-select" id="editEntrepriseActif" name="Actif" required>
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                            <label for="editEntrepriseActif">Company status</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        const activateModal = document.getElementById('activateModal');
        if (activateModal) {
            activateModal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const nom = button.getAttribute('data-nom');
                document.getElementById('activate-id').value = id;
                document.getElementById('activate-nom').textContent = nom;
            });
        }

        const deactivateModal = document.getElementById('deactivateModal');
        if (deactivateModal) {
            deactivateModal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const nom = button.getAttribute('data-nom');
                document.getElementById('deactivate-id').value = id;
                document.getElementById('deactivate-nom').textContent = nom;
            });
        }

        const deleteModal = document.getElementById('deleteModal');
        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const nom = button.getAttribute('data-nom');
                document.getElementById('delete-id').value = id;
                document.getElementById('delete-nom').textContent = nom;
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            const domainesModal = document.getElementById('domainesModal');
            const modalContent = document.getElementById('domainesModalContent');
            let currentEntrepriseId = null;

            if (!domainesModal || !modalContent) {
                return;
            }

            const renderError = (message) => {
                modalContent.innerHTML = `
                    <div class="modal-header">
                        <h5 class="modal-title text-danger">Unable to load domains</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-danger mb-0">${message}</div>
                    </div>`;
            };

            const renderSpinner = () => {
                modalContent.innerHTML = `
                    <div class="modal-body py-5 text-center">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>`;
            };

            domainesModal.addEventListener('show.bs.modal', event => {
                const trigger = event.relatedTarget;

                if (trigger && domainesModal.contains(trigger)) {
                    // Opening a nested modal (e.g., "Add a new domain") should not reload the parent content
                    return;
                }

                if (!trigger) {
                    renderError('No organization was selected.');
                    currentEntrepriseId = null;
                    return;
                }

                const entrepriseId = trigger.getAttribute('data-id');

                if (!entrepriseId) {
                    renderError('No organization identifier was provided.');
                    currentEntrepriseId = null;
                    return;
                }

                currentEntrepriseId = entrepriseId;
                renderSpinner();

                fetch(`/Gestion/GetDomaines?id=${encodeURIComponent(entrepriseId)}`, { credentials: 'same-origin' })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Request failed');
                        }

                        return response.text();
                    })
                    .then(html => {
                        modalContent.innerHTML = html;
                    })
                    .catch(() => {
                        renderError('An error occurred while retrieving the domains. Please refresh the page and try again.');
                        currentEntrepriseId = null;
                    });
            });
        });

        const editEntrepriseModal = document.getElementById('editEntrepriseModal');
        if (editEntrepriseModal) {
            editEntrepriseModal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const nom = button.getAttribute('data-nom');
                const actif = button.getAttribute('data-actif') === 'True';

                document.getElementById('editEntrepriseId').value = id;
                document.getElementById('editEntrepriseNom').value = nom;
                document.getElementById('editEntrepriseActif').value = actif ? 'true' : 'false';
            });
        }

    </script>
}
