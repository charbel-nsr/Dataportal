@model Dataportal.ViewModels.NotebookApiAccessLogsViewModel
@{
    ViewData["Title"] = "Notebook API access logs";
}

<div class="container">
    <div class="row bg-light rounded shadow p-4 mb-4">
        <form method="get" class="row g-3">
            <div class="col-md-3 mt-2">
                <div class="form-floating">
                    <input type="number" class="form-control" name="datasetId" id="datasetId" placeholder="Dataset id" value="@Model.DatasetId">
                    <label for="datasetId">Dataset id</label>
                </div>
            </div>
            <div class="col-md-3 mt-2">
                <div class="form-floating">
                    <input type="number" class="form-control" name="userId" id="userId" placeholder="User id" value="@Model.UserId">
                    <label for="userId">User id</label>
                </div>
            </div>
            <div class="col-md-3 mt-2">
                <div class="form-floating">
                    <input type="number" class="form-control" name="tokenId" id="tokenId" placeholder="Token id" value="@Model.TokenId">
                    <label for="tokenId">Token id</label>
                </div>
            </div>
            <div class="col-md-3 mt-2">
                <div class="form-floating">
                    <input type="datetime-local" class="form-control" name="dateFromUtc" id="dateFromUtc" value="@(Model.DateFromUtc?.ToString("yyyy-MM-ddTHH:mm"))">
                    <label for="dateFromUtc">From (UTC)</label>
                </div>
            </div>
            <div class="col-md-3 mt-2">
                <div class="form-floating">
                    <input type="datetime-local" class="form-control" name="dateToUtc" id="dateToUtc" value="@(Model.DateToUtc?.ToString("yyyy-MM-ddTHH:mm"))">
                    <label for="dateToUtc">To (UTC)</label>
                </div>
            </div>
            <div class="col-md-3 mt-2">
                <div class="row g-2">
                    <div class="col-6">
                        <button type="submit" class="btn btn-primary w-100">Filter</button>
                    </div>
                    <div class="col-6">
                        <a href="@Url.Action("NotebookApiAccessLogs", "Gestion")" class="btn btn-outline-primary w-100">Reset</a>
                    </div>
                </div>
            </div>
            <div class="col-12 mt-2">
                <small class="text-muted">Showing the 500 most recent matches.</small>
            </div>
        </form>
    </div>

    @if (Model.Logs != null && Model.Logs.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover shadow-sm">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Accessed (UTC)</th>
                        <th scope="col">Dataset</th>
                        <th scope="col">Dataset id</th>
                        <th scope="col">User</th>
                        <th scope="col">User id</th>
                        <th scope="col">Token</th>
                        <th scope="col">Token id</th>
                        <th scope="col">Bytes returned</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.Logs)
                    {
                        <tr>
                            <td>@log.AccessedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@log.DatasetName</td>
                            <td>@log.DatasetId</td>
                            <td>@(log.UserDisplayName ?? "-")</td>
                            <td>@(log.UserId?.ToString() ?? "-")</td>
                            <td>@(log.TokenLabel ?? "-")</td>
                            <td>@(log.TokenId?.ToString() ?? "-")</td>
                            <td>@log.BytesReturned</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No access logs match the selected filters.</div>
    }
</div>