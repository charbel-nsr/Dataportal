@model Dataportal.ViewModels.DemandeDeCompteViewModel
@using Dataportal.Models
@{
    ViewData["Title"] = "Account requests";
}

<div class="container">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="row bg-light rounded shadow p-4">
        <form asp-action="DemandeDeCompte" method="get" class="row gx-3 gy-2 align-items-center w-100">
            @Html.AntiForgeryToken()
            <div class="col-md-4">
                <div class="form-floating">
                    @{
                        var search = Context.Request.Query["search"];
                    }
                    <input type="text" class="form-control" id="search" name="search" placeholder="Search" value="@(string.IsNullOrEmpty(search)? "" : search)">
                    <label for="searchInput">Last name, First name, Email, Comment</label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-floating">
                    <select class="form-select" name="selectedEntrepriseId" id="entrepriseSelect">
                        <option selected value="">All companies</option>
                        @foreach (var entreprise in Model.Entreprises)
                        {
                            var isSelected = entreprise.Id.ToString() == Context.Request.Query["selectedEntrepriseId"];
                            <option value="@entreprise.Id" selected="@(isSelected? "selected" :null)">@entreprise.Nom</option>
                        }
                    </select>
                    <label for="entrepriseSelect">Company</label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-floating">
                    <select class="form-select" name="selectedStatutId" id="statutSelect">
                        <option selected value="">All statuses</option>
                        @foreach (var statut in Model.Statuts)
                        {
                            var isSelected = statut.Id.ToString() == Context.Request.Query["selectedStatutId"];
                            <option value="@statut.Id" selected="@(isSelected ? "selected" : null)">@statut.Libelle</option>
                        }
                    </select>
                    <label for="statutSelect">Status</label>
                </div>
            </div>
            <div class="col-md-4 mt-2">
                <div class="form-floating">
                    @{
                        var rawDateMin = Context.Request.Query["dateMin"];
                        string dateMinValue;
                        if (!string.IsNullOrEmpty(rawDateMin) && DateTime.TryParse(rawDateMin, out var parsedDateMin))
                        {
                            dateMinValue = parsedDateMin.ToString("yyyy-MM-dd");
                            <input type="date" class="form-control" name="dateMin" id="dateMin" value="@dateMinValue">
                        }
                        else
                        {
                            <input type="date" class="form-control" name="dateMin" id="dateMin">
                        }
                    }
                    <label for="dateMin">Start date</label>
                </div>
            </div>
            <div class="col-md-4 mt-2">
                <div class="form-floating">
                    @{
                        var rawDateMax = Context.Request.Query["dateMax"];
                        string dateMaxValue;
                        if (!string.IsNullOrEmpty(rawDateMax) && DateTime.TryParse(rawDateMax, out var parsedDateMax))
                        {
                            dateMaxValue = parsedDateMax.ToString("yyyy-MM-dd");
                            <input type="date" class="form-control" name="dateMax" id="dateMax" value="@dateMaxValue">
                        }
                        else
                        {
                            <input type="date" class="form-control" name="dateMax" id="dateMax">
                        }
                    }
                    <label for="dateMax">End date</label>
                </div>
            </div>
            <div class="col-md-4 mt-2">
                <div class="row g-2">
                    <div class="col-6">
                        <button type="submit" class="btn btn-primary w-100">Filter</button>
                    </div>
                    <div class="col-6">
                        <a href="@Url.Action("DemandeDeCompte", "Gestion")" class="btn btn-outline-primary w-100">Reset</a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    @if (Model.Demandes != null && Model.Demandes.Any()){
        <div class="row mt-4">
            <div class="paginated-table-wrapper" data-page-size="20">
                <div class="table-responsive">
                    <table class="table table-hover align-middle shadow-sm paginated-table">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Last name
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        First name
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Email
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Company
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col" data-sortable="true" data-sort-type="string">
                                    <button type="button" class="table-sort-button">
                                        Status
                                        <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th scope="col">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var demande in Model.Demandes)
                            {
                                var companyDisplay = string.IsNullOrWhiteSpace(demande.Entreprise?.Nom) ? "—" : demande.Entreprise.Nom;
                                var statusLabel = "Unknown";
                                var statusIconClass = "bi bi-question-circle text-secondary";
                                var statusKey = "Unknown";

                                if (!string.IsNullOrWhiteSpace(demande.StatutDeLaDemande?.Libelle))
                                {
                                    switch (demande.StatutDeLaDemande.Libelle.ToLower())
                                    {
                                        case "pending":
                                            statusLabel = "Pending";
                                            statusIconClass = "bi bi-hourglass-split text-warning";
                                            statusKey = "Pending";
                                            break;
                                        case "approved":
                                            statusLabel = "Approved";
                                            statusIconClass = "bi bi-check-circle-fill text-success";
                                            statusKey = "Approved";
                                            break;
                                        case "rejected":
                                            statusLabel = "Rejected";
                                            statusIconClass = "bi bi-x-circle-fill text-danger";
                                            statusKey = "Rejected";
                                            break;
                                        default:
                                            statusKey = demande.StatutDeLaDemande.Libelle;
                                            break;
                                    }
                                }

                                <tr>
                                    <td data-sort-value="@demande.Nom">@demande.Nom</td>
                                    <td data-sort-value="@demande.Prenom">@demande.Prenom</td>
                                    <td data-sort-value="@demande.Email">@demande.Email</td>
                                    <td data-sort-value="@companyDisplay">@companyDisplay</td>
                                    <td data-sort-value="@statusKey">
                                        <i class="@statusIconClass" title="@statusLabel">@statusLabel</i>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal" data-id="@demande.Id">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        @if (demande.StatutDeLaDemande?.Libelle?.ToLower() == "rejected")
                                        {
                                            <form method="post" asp-action="DeleteDemande" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@demande.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-pagination-controls d-flex justify-content-end align-items-center gap-2 mt-3 d-none">
                    <button type="button" class="table-pagination-button table-pagination-prev" aria-label="Previous page" disabled>
                        <span class="material-symbols-outlined">
                            arrow_circle_left
                        </span>
                    </button>
                    <div class="d-flex align-items-center gap-1">
                        <input type="number" class="form-control table-pagination-input" value="1" min="1" />
                        <span>/</span>
                        <span class="table-pagination-total">1</span>
                    </div>
                    <button type="button" class="table-pagination-button table-pagination-next" aria-label="Next page" disabled>
                        <span class="material-symbols-outlined">
                            arrow_circle_right
                        </span>
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center">
            <img src="/illustration/empty-search.svg" alt="No data found" class="img-fluid" style="max-height:200px;" />
            <p class="text-muted mt-2">No data found.</p>
        </div>
    }
</div>

<!-- Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-action="ApprouverDemande" id="modal-action-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="modal-action-id" />
                <input type="hidden" name="idEntreprise" id="modal-action-idEntreprise" />
                <input type="hidden" name="emailVerifie" id="modal-action-emailVerifie" />
                <input type="hidden" name="commentaire" id="modal-action-commentaire" />

                <div class="modal-header">
                    <h5 class="modal-title" id="editModalLabel">Request details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="modal-demandeId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="modal-Nom" placeholder="Last name" readonly>
                                <label for="modal-Nom">Last name</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="modal-Prenom" placeholder="First name" readonly>
                                <label for="modal-Prenom">First name</label>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-floating">
                                <input type="email" class="form-control" id="modal-Email" placeholder="Email" readonly>
                                <label for="modal-Email">Email</label>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-floating">
                                <textarea class="form-control" id="modal-Commentaire" style="height: 100px" placeholder="Comment" readonly></textarea>
                                <label for="modal-Commentaire">Comment</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select class="form-select" id="modal-Entreprise" disabled>
                                    @foreach (var entreprise in Model.Entreprises)
                                    {
                                        <option value="@entreprise.Id">@entreprise.Nom</option>
                                    }
                                </select>
                                <label for="modal-Entreprise">Company</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="modal-DateCreation" placeholder="Created on" readonly>
                                <label for="modal-DateCreation">Created on</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" id="modal-EmailVerifie" disabled>
                                <label class="form-check-label" for="modal-EmailVerifie">
                                    Email verified
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select class="form-select" id="modal-action-roleId" name="idRole">
                                    <option value="">Select a role</option>
                                    @foreach (var role in Model.Roles.OrderBy(r => r.Id))
                                    {
                                        <option value="@role.Id">@role.Libelle</option>
                                    }
                                </select>
                                <label for="modal-action-roleId">Role to assign (required only when approving)</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="row g-2 w-100">
                        <div class="col-12 col-md">
                            <button type="submit" name="idStatut" value="2" class="btn btn-success w-100" id="btn-valider">
                                Approve request
                            </button>
                        </div>
                        <div class="col-12 col-md">
                            <button type="submit" name="idStatut" value="3" class="btn btn-danger w-100" id="btn-refuser">
                                Reject request
                            </button>
                        </div>
                        <div class="col-12 col-md">
                            <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">
                                Close
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const modal = document.getElementById('editModal');
        const roleSelect = document.getElementById('modal-action-roleId');
        const btnValider = document.getElementById('btn-valider');
        const btnRefuser = document.getElementById('btn-refuser');

        btnValider.addEventListener('click', () => {
            roleSelect.required = true;
        });

        btnRefuser.addEventListener('click', () => {
            roleSelect.required = false;
        });

        modal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const demandeId = button.getAttribute('data-id');

            roleSelect.value = '';
            roleSelect.required = false;
            roleSelect.disabled = true;

            fetch(`/Gestion/DemandeDeCompteDetails/${demandeId}`)
                .then(response => response.json())
                .then(data => {
                    document.getElementById('modal-demandeId').value = data.id;
                    document.getElementById('modal-Nom').value = data.nom;
                    document.getElementById('modal-Prenom').value = data.prenom;
                    document.getElementById('modal-Email').value = data.email;
                    document.getElementById('modal-Commentaire').value = data.commentaire ?? '';
                    document.getElementById('modal-Entreprise').value = data.idEntreprise;
                    document.getElementById('modal-DateCreation').value = data.dateCreation;
                    document.getElementById('modal-EmailVerifie').checked = data.emailVerifie;

                    document.getElementById('modal-action-id').value = data.id;
                    document.getElementById('modal-action-idEntreprise').value = data.idEntreprise;
                    document.getElementById('modal-action-emailVerifie').value = data.emailVerifie;
                    document.getElementById('modal-action-commentaire').value = data.commentaire ?? '';

                    const canValidate = data.idStatutDeLaDemande === 1 || data.idStatutDeLaDemande === 3;
                    btnValider.style.display = canValidate ? 'inline-block' : 'none';
                    btnRefuser.style.display = (data.idStatutDeLaDemande === 1) ? 'inline-block' : 'none';
                    roleSelect.disabled = !canValidate;

                    if (!canValidate) {
                        roleSelect.value = '';
                        roleSelect.required = false;
                    }
                });
        });
    </script>
}