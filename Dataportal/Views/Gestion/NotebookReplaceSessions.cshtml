@model Dataportal.ViewModels.NotebookReplaceSessionsViewModel

@{
    ViewData["Title"] = "Notebook replace sessions";
}

<div class="container">
    <div class="row bg-light rounded shadow p-4 mb-4">
        <form method="get" class="row gx-3 gy-2 align-items-center w-100">
            <div class="col-md-3 mt-2">
                <div class="form-floating">
                    <input type="number" class="form-control" name="datasetId" id="datasetId" placeholder="Dataset id" value="@Model.DatasetId">
                    <label for="datasetId">Dataset id</label>
                </div>
            </div>
            @if (Model.IsAdminView)
            {
                <div class="col-md-3 mt-2">
                    <div class="form-floating">
                        <input type="number" class="form-control" name="userId" id="userId" placeholder="User id" value="@Model.UserId">
                        <label for="userId">User id</label>
                    </div>
                </div>
            }
            <div class="col-md-3 mt-2">
                <div class="form-floating">
                    <select class="form-select" name="status" id="status">
                        <option value="">All statuses</option>
                        @foreach (var option in Model.StatusOptions)
                        {
                            <option value="@option.Value" selected="@option.Selected">@option.Text</option>
                        }
                    </select>
                    <label for="status">Status</label>
                </div>
            </div>
            <div class="col-md-3 mt-2">
                <div class="form-floating">
                    <input type="datetime-local" class="form-control" name="createdFromUtc" id="createdFromUtc" value="@(Model.CreatedFromUtc?.ToString("yyyy-MM-ddTHH:mm"))">
                    <label for="createdFromUtc">From (UTC)</label>
                </div>
            </div>
            <div class="col-md-3 mt-2">
                <div class="form-floating">
                    <input type="datetime-local" class="form-control" name="createdToUtc" id="createdToUtc" value="@(Model.CreatedToUtc?.ToString("yyyy-MM-ddTHH:mm"))">
                    <label for="createdToUtc">To (UTC)</label>
                </div>
            </div>
            <div class="col-md-9 mt-2">
                <div class="row g-2">
                    <div class="col-6">
                        <button type="submit" class="btn btn-primary w-100">Filter</button>
                    </div>
                    <div class="col-6">
                        <a href="@Url.Action("NotebookReplaceSessions", "Gestion")" class="btn btn-outline-primary w-100">Reset</a>
                    </div>
                </div>
            </div>
            <div class="col-12 mt-2">
                <small class="text-muted">Showing the 500 most recent matches. Sessions older than one hour are auto-aborted.</small>
            </div>
        </form>
    </div>

    @if (Model.Sessions != null && Model.Sessions.Any())
    {
        <div class="paginated-table-wrapper" data-page-size="20">
            <div class="table-responsive">
                <table class="table table-hover shadow-sm paginated-table">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Created (UTC)</th>
                            <th scope="col">Status</th>
                            <th scope="col">Dataset</th>
                            <th scope="col">Dataset id</th>
                            <th scope="col">Schema</th>
                            <th scope="col">Table</th>
                            <th scope="col">Staging table</th>
                            <th scope="col">Old table</th>
                            <th scope="col">User</th>
                            <th scope="col">User id</th>
                            <th scope="col">Updated (UTC)</th>
                            <th scope="col">Completed (UTC)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model.Sessions)
                        {
                            <tr>
                                <td>@session.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@session.Status</td>
                                <td>@session.DatasetName</td>
                                <td>@session.DatasetId</td>
                                <td>@session.Schema</td>
                                <td>@session.TableName</td>
                                <td>@session.StagingTableName</td>
                                <td>@(session.OldTableName ?? "-")</td>
                                <td>@(session.UserDisplayName ?? "-")</td>
                                <td>@(session.UserId?.ToString() ?? "-")</td>
                                <td>@(session.UpdatedAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                                <td>@(session.CompletedAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-pagination-controls d-flex justify-content-end align-items-center gap-2 mt-3 d-none">
                <button type="button" class="table-pagination-button table-pagination-prev" aria-label="Previous page" disabled>
                    <span class="material-symbols-outlined">
                        arrow_circle_left
                    </span>
                </button>
                <div class="d-flex align-items-center gap-1">
                    <input type="number" class="form-control table-pagination-input" value="1" min="1" />
                    <span>/</span>
                    <span class="table-pagination-total">1</span>
                </div>
                <button type="button" class="table-pagination-button table-pagination-next" aria-label="Next page" disabled>
                    <span class="material-symbols-outlined">
                        arrow_circle_right
                    </span>
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="text-center">
            <img src="/illustration/empty-search.svg" alt="No data found" class="img-fluid" style="max-height:200px;" />
            <p class="text-muted mt-2">No replace sessions found.</p>
        </div>
    }
</div>