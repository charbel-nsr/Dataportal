@model Dataportal.Models.FichierStocke
@using Dataportal.Helpers

@{
    ViewData["Title"] = "File details";
    var sanitizedDescription = RichTextSanitizer.Sanitize(Model.Description);
    var canManage = User.IsInRole("administrator") || User.IsInRole("editor") ||
                    (User.Identity.IsAuthenticated && User.FindFirst("UserId")?.Value == Model.IdUtilisateur.ToString());
}

<div class="container">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">@Model.Nom</h2>
            <p class="text-muted mb-0">@Model.NomFichierOriginal</p>
        </div>
        <div class="d-flex gap-2">
            @if (Model.AutoriserLeTelechargement)
            {
                <a class="btn btn-outline-primary" href="@Url.Action("Download", "Files", new { id = Model.Id })">
                    <i class="bi bi-download"></i> Download
                </a>
            }
            @if (canManage)
            {
                <a class="btn btn-outline-danger" href="@Url.Action("Delete", "Files", new { id = Model.Id })">
                    <i class="bi bi-trash"></i> Delete
                </a>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="bg-light p-4 rounded shadow-sm">
                <h3 class="h5 mb-3">Description</h3>
                @if (!string.IsNullOrWhiteSpace(sanitizedDescription))
                {
                    @Html.Raw(sanitizedDescription)
                }
                else
                {
                    <p class="text-muted mb-0">No description provided.</p>
                }
            </div>
        </div>
        <div class="col-lg-5">
            <div class="bg-white border rounded p-4 shadow-sm">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">Uploaded</dt>
                    <dd class="col-sm-7">@Model.DateAjout.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-5 text-muted">Size</dt>
                    <dd class="col-sm-7">@($"{Model.TailleOctets / (1024d * 1024d):0.##} MB")</dd>

                    <dt class="col-sm-5 text-muted">Downloads</dt>
                    <dd class="col-sm-7">@Model.NombreDeTelechargements</dd>

                    <dt class="col-sm-5 text-muted">License</dt>
                    <dd class="col-sm-7">@Model.Licence?.Libelle</dd>

                    <dt class="col-sm-5 text-muted">Energy type</dt>
                    <dd class="col-sm-7">@Model.TypeEnergieRenouvelable?.Libelle ?? "—"</dd>

                    <dt class="col-sm-5 text-muted">Visibility</dt>
                    <dd class="col-sm-7">@Model.Visibilite?.Libelle</dd>

                    <dt class="col-sm-5 text-muted">Downloads allowed</dt>
                    <dd class="col-sm-7">@((Model.AutoriserLeTelechargement) ? "Yes" : "No")</dd>

                    <dt class="col-sm-5 text-muted">SHA-256</dt>
                    <dd class="col-sm-7 text-break">@Model.HashSha256</dd>
                </dl>
            </div>
        </div>
    </div>
</div>