@model Dataportal.ViewModels.ResetMotDePasseViewModel

@{
    ViewData["Title"] = "Reset password";
    ViewData["HideFooter"] = true;
    ViewData["DisableScroll"] = true;
}

<div class="hero" style="background-image: url(' /background/login-background.png'); height: 100.6vh; background-attachment: fixed; background-size: cover;">
    <div class="container h-100">
        <div class="row h-100 align-items-center justify-content-center">
            <div class="col-md-6 d-flex align-items-center justify-content-center">
                <div class="p-4 bg-white rounded shadow" style="max-width: 450px; width: 100%;">
                    <h2 class="mb-4 text-center">@ViewData["Title"]</h2>
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    <form asp-action="ReinitialiserMotDePasse" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="Token" />
                        <div class="form-floating mb-3">
                            <input asp-for="NouveauMotDePasse" class="form-control" type="password" placeholder=" " />
                            <label asp-for="NouveauMotDePasse" class="floatingInput"></label>
                            <span asp-validation-for="NouveauMotDePasse" class="text-danger"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="ConfirmationMotDePasse" class="form-control" type="password" placeholder=" " />
                            <label asp-for="ConfirmationMotDePasse" class="floatingInput"></label>
                            <span asp-validation-for="ConfirmationMotDePasse" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 mt-3">
                            Save new password
                        </button>
                    </form>
                    <a href="/Compte/SeConnecter" class="btn btn-outline-primary mt-2 w-100">Back to sign in</a>
                </div>
            </div>
            <div class="col-md-6 d-flex flex-column justify-content-center align-items-center p-4 logo-fade">
                <div class="mb-3">
                    <a href="https://www.etsmtl.ca/" target="_blank">
                        <img src="~/logo/ets-logo.png" alt="ETS Logo" class="img-fluid footer-logo">
                    </a>
                </div>
                <div class="mb-3">
                    <a href="https://www.mitacs.ca/" target="_blank">
                        <img src="~/logo/Mitacs_logo.png" alt="Mitacs Logo" class="img-fluid footer-logo ms-1">
                    </a>
                </div>
                <div class="mb-3">
                    <a href="https://www.hydroquebec.com/" target="_blank">
                        <img src="~/logo/hq-footer-logo.png" alt="HQ Logo" class="img-fluid footer-logo ms-1">
                    </a>
                </div>
                <div class="mb-3">
                    <a href="https://www.powerfactors.com/" target="_blank">
                        <img src="~/logo/pf-footer-logo.png" alt="PF Logo" class="img-fluid footer-logo ms-1">
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>