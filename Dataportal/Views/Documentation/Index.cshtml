@{
    ViewData["Title"] = "Documentation";
}

<div class="documentation-page">
    <section class="documentation-hero">
        <div class="container py-5">
            <span class="badge rounded-pill text-bg-light border border-light-subtle text-uppercase tracking-wide">Documentation</span>
            <h1 class="mt-3">Data Portal guide</h1>
            <p class="lead text-muted mb-4">
                Everything you need to understand the platform rules, how the portal works, and the pages available
                for your role.
            </p>
            @if (!User.Identity.IsAuthenticated)
            {
                <a class="btn btn-danger" asp-area="" asp-controller="Compte" asp-action="SeConnecter">
                    Sign in to see role-specific access
                </a>
            }
        </div>
    </section>

    <section class="container py-4">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="doc-card h-100">
                    <div class="doc-card-icon">
                        <i class="bi bi-compass"></i>
                    </div>
                    <h3>How the portal works</h3>
                    <p class="text-muted">
                        Use the navigation bar to move between Home, Data, Notebook API, and Profile. Data discovery is
                        centered on searchable datasets with filters and visibility rules.
                    </p>
                    <ul class="doc-list">
                        <li>Home highlights announcements and collaboration context.</li>
                        <li>Data lets you search, view, and manage datasets.</li>
                        <li>Notebook API provides programmatic data access.</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="doc-card h-100">
                    <div class="doc-card-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h3>Rules &amp; governance</h3>
                    <p class="text-muted">
                        Respect data confidentiality and visibility labels. Only share datasets within the allowed
                        audience for your role and organization.
                    </p>
                    <ul class="doc-list">
                        <li>Use personal visibility for drafts and private work.</li>
                        <li>Internal visibility is reserved for approved internal roles.</li>
                        <li>External visibility follows organization agreements.</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="doc-card h-100">
                    <div class="doc-card-icon">
                        <i class="bi bi-life-preserver"></i>
                    </div>
                    <h3>Getting help</h3>
                    <p class="text-muted">
                        If you need access changes, support, or onboarding materials, contact administrators through
                        your account request flow.
                    </p>
                    <ul class="doc-list">
                        <li>Account status and profile settings live in Profile &gt; Settings.</li>
                        <li>Request access updates through your administrator.</li>
                        <li>Use the Notebook API logs (admins) to audit access.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="container pb-5">
        <div class="doc-role-card">
            <div class="d-flex flex-column flex-lg-row gap-4 justify-content-between align-items-start">
                <div>
                    <h2 class="mb-2">Your access by role</h2>
                    <p class="text-muted mb-0">
                        Role-based documentation adapts to highlight the pages and capabilities you can access.
                    </p>
                </div>
                <span class="badge rounded-pill bg-dark-subtle text-dark">Updated for your current role</span>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-lg-4">
                    <div class="doc-role-panel h-100">
                        <h3 class="h5">Core pages</h3>
                        <p class="text-muted">Available to all authenticated users.</p>
                        <ul class="doc-list">
                            <li><strong>Home:</strong> announcements and collaboration context.</li>
                            <li><strong>Data:</strong> search and view datasets you are allowed to see.</li>
                            <li><strong>Notebook API:</strong> programmatic access to approved datasets.</li>
                            <li><strong>Profile:</strong> account settings and password updates.</li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-8">
                    <div class="row g-4">
                        @if (User.Identity.IsAuthenticated && User.IsInRole("administrator"))
                        {
                            <div class="col-md-6">
                                <div class="doc-role-panel h-100">
                                    <h3 class="h5">Administrator access</h3>
                                    <p class="text-muted">Full governance and configuration tools.</p>
                                    <ul class="doc-list">
                                        <li><strong>Control:</strong> Sites, Devices, Licenses.</li>
                                        <li><strong>Management:</strong> Account Requests, Home message, API access logs.</li>
                                        <li><strong>Users &amp; Organizations:</strong> create, update, and manage roles.</li>
                                        <li><strong>Data management:</strong> approve visibility, edit metadata, and publish.</li>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="doc-role-panel h-100">
                                    <h3 class="h5">Operational checklist</h3>
                                    <ul class="doc-list">
                                        <li>Review pending account requests daily.</li>
                                        <li>Audit API access logs for compliance.</li>
                                        <li>Maintain organization and user role mappings.</li>
                                    </ul>
                                </div>
                            </div>
                        }
                        else if (User.Identity.IsAuthenticated && User.IsInRole("editor"))
                        {
                            <div class="col-md-6">
                                <div class="doc-role-panel h-100">
                                    <h3 class="h5">Editor access</h3>
                                    <p class="text-muted">Configuration and data upkeep tools.</p>
                                    <ul class="doc-list">
                                        <li><strong>Control:</strong> Sites, Devices, Licenses.</li>
                                        <li><strong>Management:</strong> Users and Organizations.</li>
                                        <li><strong>Data management:</strong> create, edit, and update datasets.</li>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="doc-role-panel h-100">
                                    <h3 class="h5">Publishing guidance</h3>
                                    <ul class="doc-list">
                                        <li>Validate metadata before publishing.</li>
                                        <li>Keep datasets aligned with visibility rules.</li>
                                        <li>Coordinate with administrators on policy updates.</li>
                                    </ul>
                                </div>
                            </div>
                        }
                        else if (User.Identity.IsAuthenticated && User.IsInRole("user"))
                        {
                            <div class="col-md-6">
                                <div class="doc-role-panel h-100">
                                    <h3 class="h5">User access</h3>
                                    <p class="text-muted">Data contribution and collaboration.</p>
                                    <ul class="doc-list">
                                        <li><strong>Data:</strong> request, submit, and view datasets you own.</li>
                                        <li><strong>Metadata tools:</strong> keep records accurate and current.</li>
                                        <li><strong>Notebook API:</strong> access approved datasets programmatically.</li>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="doc-role-panel h-100">
                                    <h3 class="h5">Best practices</h3>
                                    <ul class="doc-list">
                                        <li>Document sources and ownership clearly.</li>
                                        <li>Use internal visibility when collaborating.</li>
                                        <li>Keep personal drafts private until ready.</li>
                                    </ul>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="col-12">
                                <div class="doc-role-panel h-100">
                                    <h3 class="h5">Public overview</h3>
                                    <p class="text-muted">
                                        Sign in to see the pages and tools available for your role. The core platform
                                        includes Home, Data search, and Notebook API access for eligible users.
                                    </p>
                                    <a class="btn btn-outline-secondary" asp-area="" asp-controller="Compte" asp-action="SeConnecter">
                                        Sign in
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>