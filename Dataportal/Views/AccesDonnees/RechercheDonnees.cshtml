@model Dataportal.ViewModels.RechercheDonneesViewModel
@using Dataportal.Classes
@using System.Globalization

@{
    ViewData["Title"] = "Search data";
    var searchReturnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="container">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row bg-light rounded shadow p-4 mb-4">
        <form method="get" class="row gx-3 gy-2">
            <div class="col-12">
                <div class="row">
                    <div class="col-lg-12 d-flex flex-wrap">
                        <div class="form-check me-3 mb-2">
                            <input class="form-check-input" type="checkbox" value="true" name="seriesTemporelles" id="seriesTemporelles" @(Model.SeriesTemporelles == true ? "checked" : "")>
                            <label class="form-check-label" for="seriesTemporelles">Time series</label>
                        </div>
                        <div class="form-check me-3 mb-2">
                            <input class="form-check-input" type="checkbox" value="true" name="anonymiser" id="anonymiser" @(Model.Anonymiser == true ? "checked" : "")>
                            <label class="form-check-label" for="anonymiser">Anonymize</label>
                        </div>
                        <div class="form-check me-3 mb-2">
                            <input class="form-check-input" type="checkbox" value="true" name="autoriserLeTelechargement" id="autoriserLeTelechargement" @(Model.AutoriserLeTelechargement == true ? "checked" : "")>
                            <label class="form-check-label" for="autoriserLeTelechargement">Allow downloads</label>
                        </div>
                        <div class="form-check me-3 mb-2">
                            <input class="form-check-input" type="checkbox" value="true" name="autoriserApi" id="autoriserApi" @(Model.AutoriserApi == true ? "checked" : "")>
                            <label class="form-check-label" for="autoriserApi">API allowed</label>
                        </div>
                        <div class="form-check me-3 mb-2">
                            <input class="form-check-input" type="checkbox" value="true" name="hasEventLogs" id="hasEventLogs" @(Model.HasEventLogs == true ? "checked" : "")>
                            <label class="form-check-label" for="hasEventLogs">With event logs</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" value="true" name="hasContextEnv" id="hasContextEnv" @(Model.HasContextEnv == true ? "checked" : "")>
                            <label class="form-check-label" for="hasContextEnv">With environmental context</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mt-3">
                <div class="form-floating">
                    <input type="text" class="form-control" id="search" name="search" placeholder="Search" value="@Model.Search">
                    <label for="search">Name or description</label>
                </div>
            </div>

            <div class="col-md-6 mt-3">
                <div class="row g-2">
                    <div class="col-6">
                        <div class="form-floating">
                            <input type="number" min="0" step="0.1" class="form-control" id="minDataSizeMb" name="minDataSizeMb" value="@(Model.MinDataSizeMb?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)">
                            <label for="minDataSizeMb">Min size (MB)</label>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="form-floating">
                            <input type="number" min="0" step="0.1" class="form-control" id="maxDataSizeMb" name="maxDataSizeMb" value="@(Model.MaxDataSizeMb?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)">
                            <label for="maxDataSizeMb">Max size (MB)</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 mt-3">
                <div class="row g-3">
                    <div class="col-12 col-lg-4">
                        <div class="form-floating">
                            <select class="form-select" name="idLicence" id="idLicence">
                                <option value="">All licenses</option>
                                @foreach (var licence in Model.Licences ?? new List<Dataportal.Models.Licence>())
                                {
                                    <option value="@licence.Id" selected="@(licence.Id == Model.IdLicence ? "selected" : null)">@licence.Libelle</option>
                                }
                            </select>
                            <label for="idLicence">License</label>
                        </div>
                    </div>
                    <div class="col-12 col-lg-4">
                        <div class="form-floating">
                            <select class="form-select" name="idTypeEnergieRenouvelable" id="idTypeEnergieRenouvelable">
                                <option value="">All energy types</option>
                                @foreach (var energyType in Model.TypesEnergieRenouvelable ?? new List<Dataportal.Models.TypeEnergieRenouvelable>())
                                {
                                    <option value="@energyType.Id" selected="@(energyType.Id == Model.IdTypeEnergieRenouvelable ? "selected" :null)">@energyType.Libelle</option>
                                }
                            </select>
                            <label for="idTypeEnergieRenouvelable">Energy type</label>
                        </div>
                    </div>
                    <div class="col-12 col-lg-4">
                        <div class="form-floating">
                            <select class="form-select" name="idVisibilite" id="idVisibilite">
                                <option value="">All visibility levels</option>
                                @foreach (var visibilite in Model.Visibilites ?? Array.Empty<Dataportal.ViewModels.LookupItem>())
                                {
                                    <option value="@visibilite.Id" selected="@(visibilite.Id == Model.IdVisibilite ? "selected" : null)")>@visibilite.Label</option>
                                }
                            </select>
                            <label for="idVisibilite">Visibility</label>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6">
                        <div class="form-floating">
                            <select class="form-select" name="idCreateur" id="idCreateur">
                                <option value="">All creators</option>
                                @foreach (var creator in Model.Createurs ?? Array.Empty<Dataportal.ViewModels.LookupItem>())
                                {
                                    <option value="@creator.Id" selected="@(creator.Id == Model.IdCreateur ? "selected" : null)">@creator.Label</option>
                                }
                            </select>
                            <label for="idCreateur">Creator</label>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6">
                        <div class="form-floating">
                            <select class="form-select" name="idEntreprise" id="idEntreprise">
                                <option value="">All companies</option>
                                @foreach (var entreprise in Model.Entreprises ?? Array.Empty<Dataportal.ViewModels.LookupItem>())
                                {
                                    <option value="@entreprise.Id" selected="@(entreprise.Id == Model.IdEntreprise ? "selected" : null)">@entreprise.Label</option>
                                }
                            </select>
                            <label for="idEntreprise">Company</label>
                        </div>
                    </div>
                </div>
            </div>


            <div class="col-12 mt-3 d-flex flex-column flex-md-row">
                <button type="submit" class="btn btn-primary flex-grow-1 w-100 mb-2 mb-md-0 me-md-2">
                    Filter
                </button>
                <a href="@Url.Action("RechercheDonnees", "AccesDonnees")" class="btn btn-outline-primary flex-grow-1 w-100">
                    Reset
                </a>
            </div>
        </form>
    </div>
    
    @if (User.IsInRole("administrator") || User.IsInRole("editor"))
    {
        <div class="col-12 col-md-auto mb-3">
            <a class="btn btn-success" href="@Url.Action("CreateStep1", "Donnees")">
                <i class="bi bi-plus-circle"></i> Create data
            </a>
        </div>
    }

    
    @if (Model.Metadonnees != null && Model.Metadonnees.Any())
    {
        <div class="row">
            <div class="paginated-table-wrapper" data-page-size="20">
                <div class="table-responsive">
                    <table class="table table-hover align-middle shadow-sm paginated-table">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" data-sortable="true" data-sort-type="string">
                                <button type="button" class="table-sort-button">
                                    Name
                                    <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                </button>
                            </th>
                            <th scope="col" data-sortable="true" data-sort-type="size">
                                <button type="button" class="table-sort-button">
                                    Size
                                    <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                </button>
                            </th>
                            <th scope="col" data-sortable="true" data-sort-type="number">
                                <button type="button" class="table-sort-button">
                                    Downloads
                                    <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                </button>
                            </th>
                            <th scope="col" data-sortable="true" data-sort-type="date">
                                <button type="button" class="table-sort-button">
                                    Last updated
                                    <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                </button>
                            </th>
                            <th scope="col" data-sortable="true" data-sort-type="boolean">
                                <button type="button" class="table-sort-button">
                                    Time series
                                    <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                </button>
                            </th>
                            <th scope="col" data-sortable="true" data-sort-type="string">
                                <button type="button" class="table-sort-button">
                                    Energy type
                                    <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                </button>
                            </th>
                            <th scope="col" data-sortable="true" data-sort-type="string">
                                <button type="button" class="table-sort-button">
                                    Visibility
                                    <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                </button>
                            </th>
                            <th scope="col" data-sortable="true" data-sort-type="string">
                                <button type="button" class="table-sort-button">
                                    Creator
                                    <i class="bi bi-arrow-down-up sort-icon ms-1" aria-hidden="true"></i>
                                </button>
                            </th>
                            <th scope="col">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                            @foreach (var m in Model.Metadonnees)
                            {
                                double? sizeSortValue = null;
                                if (!string.IsNullOrWhiteSpace(m.TailleDesDonnees))
                                {
                                    var parts = m.TailleDesDonnees.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                    if (parts.Length == 2)
                                    {
                                        var numberText = parts[0];
                                        var unit = parts[1].Trim().ToUpperInvariant();
                                        if (double.TryParse(numberText, NumberStyles.Float, CultureInfo.InvariantCulture, out var parsedValue) ||
                                        double.TryParse(numberText, NumberStyles.Float, CultureInfo.CurrentCulture, out parsedValue))
                                        {
                                            sizeSortValue = unit switch
                                            {
                                                "B" => parsedValue / (1024d * 1024d),
                                                "KB" => parsedValue / 1024d,
                                                "MB" => parsedValue,
                                                "GB" => parsedValue * 1024d,
                                                "TB" => parsedValue * 1024d * 1024d,
                                                _ => parsedValue
                                            };
                                        }
                                    }
                                }

                                var energyTypeLabel = m.TypeEnergieRenouvelable?.Libelle;
                                var energyTypeDisplay = string.IsNullOrWhiteSpace(energyTypeLabel) ? "—" : energyTypeLabel;

                                string? visibilityLabel;
                                if (User.IsInRole("administrator") && m.IdVisibilite == VisibiliteIds.Interne)
                                {
                                    visibilityLabel = m.Visibilite?.Libelle + $" ({m.Utilisateur?.Entreprise?.Nom})";
                                }
                                else if (User.IsInRole("administrator") && m.IdVisibilite == VisibiliteIds.Personnelle)
                                {
                                    visibilityLabel = m.Visibilite?.Libelle + $" ({m.Utilisateur?.Prenom} {m.Utilisateur?.Nom})";
                                }
                                else
                                {
                                    visibilityLabel = m.Visibilite?.Libelle;
                                }

                                var visibilityDisplay = string.IsNullOrWhiteSpace(visibilityLabel) ? "—" : visibilityLabel;
                                var creatorLabel = $"{m.Utilisateur?.Prenom} {m.Utilisateur?.Nom}".Trim();

                                <tr>
                                    <td data-sort-value="@m.Nom">@m.Nom</td>
                                    <td data-sort-value="@(sizeSortValue?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)">@(!string.IsNullOrWhiteSpace(m.TailleDesDonnees) ? m.TailleDesDonnees : "—")</td>
                                    <td data-sort-value="@m.NombreDeTelechargements.ToString(CultureInfo.InvariantCulture)">@m.NombreDeTelechargements</td>
                                    <td data-sort-value="@(m.DernierMiseAJour?.ToString("O") ?? string.Empty)">@((m.DernierMiseAJour?.ToString("dd/MM/yyyy")) ?? "—")</td>
                                    <td data-sort-value="@(m.SeriesTemporelles ? 1 : 0)">
                                        @if (m.SeriesTemporelles)
                                        {
                                            <span class="badge bg-success">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No</span>
                                        }
                                    </td>
                                    <td data-sort-value="@energyTypeDisplay">@energyTypeDisplay</td>
                                    <td data-sort-value="@visibilityDisplay">@visibilityDisplay</td>
                                    <td data-sort-value="@creatorLabel">@creatorLabel</td>
                                    <td>
                                        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Details", "Donnees", new { id = m.Id, returnUrl = searchReturnUrl })" title="View details">
                                            <i class="bi bi-exclamation-circle"></i>
                                        </a>
                                        @{
                                            var isOwner = User.Identity.IsAuthenticated && User.FindFirst("UserId")?.Value == m.IdUtilisateur.ToString();
                                            var canManageIndex = User.IsInRole("administrator") || (User.IsInRole("editor") && isOwner);
                                            var hasUnindexedTable = m.SeriesTemporelles &&
                                            ((m.Donnees != null && !m.Donnees.IndexEnabled) ||
                                            (m.DonneesEventLogs != null && !m.DonneesEventLogs.IndexEnabled) ||
                                            (m.DonneesContexteEnvironnemental != null && !m.DonneesContexteEnvironnemental.IndexEnabled));
                                            var canRequestIndexation = m.TraitementEnCours != true;
                                        }
                                        @if (canManageIndex && hasUnindexedTable && canRequestIndexation)
                                        {
                                            <a class="btn btn-sm btn-outline-success ms-1" href="@Url.Action("CreateIndexation", "Donnees", new { id = m.Id, returnUrl = searchReturnUrl })" title="Request index">
                                                <i class="bi bi-graph-up"></i>
                                            </a>
                                        }
                                        @if (User.IsInRole("administrator") || (User.Identity.IsAuthenticated && User.FindFirst("UserId")?.Value == m.IdUtilisateur.ToString()))
                                        {
                                            <a class="btn btn-sm btn-outline-primary ms-1" href="@Url.Action("EditStep1", "ModifDonnees", new { id = m.Id })" title="Edit data">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        @if (User.IsInRole("administrator") || (User.Identity.IsAuthenticated && User.FindFirst("UserId")?.Value == m.IdUtilisateur.ToString()))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger ms-1" data-bs-toggle="modal" data-bs-target="#deleteModal" data-id="@m.Id" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                    </tbody>
                    </table>
                </div>
                <div class="table-pagination-controls d-flex justify-content-end align-items-center gap-2 mt-3 d-none">
                    <button type="button" class="table-pagination-button table-pagination-prev" aria-label="Previous page" disabled>
                        <span class="material-symbols-outlined">
                            arrow_circle_left
                        </span>
                    </button>
                    <div class="d-flex align-items-center gap-1">
                        <input type="number" class="form-control table-pagination-input" value="1" min="1" />
                        <span>/</span>
                        <span class="table-pagination-total">1</span>
                    </div>
                    <button type="button" class="table-pagination-button table-pagination-next" aria-label="Next page" disabled>
                        <span class="material-symbols-outlined">
                            arrow_circle_right
                        </span>
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center">
                <img src="/illustration/empty-search.svg" alt="No data found" class="img-fluid" style="max-height:200px;" />
                <p class="text-muted mt-2">No data found.</p>
        </div>
    }
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-controller="Donnees" asp-action="Delete">
                @Html.AntiForgeryToken()
                <input type="hidden" id="delete-id" name="id" />
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Confirm deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-danger">All data related to this subject will be permanently lost. Are you sure you want to continue?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            document.getElementById('delete-id').value = id;
        });
    </script>
}
